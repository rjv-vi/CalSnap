  document.body.style.overflow='';
  _cfrmCb=null;
}

// ══════════════════════════════════════════════════
// HAPTIC FEEDBACK — Android Chrome navigator.vibrate
// ══════════════════════════════════════════════════
let _hfxOn = localStorage.getItem('hfx_enabled') !== '0';
const HFX = {
  isOn: () => _hfxOn,
  setOn: (v) => { _hfxOn = v; localStorage.setItem('hfx_enabled', v?'1':'0'); },
  _v: (pat) => { try { if(_hfxOn && navigator.vibrate) navigator.vibrate(pat); } catch(e){} },
  light:   () => HFX._v(8),
  medium:  () => HFX._v(16),
  heavy:   () => HFX._v(30),
  success: () => HFX._v([12,40,18]),
  error:   () => HFX._v([20,60,20,60,20]),
  tick:    () => HFX._v(4),
  double:  () => HFX._v([10,50,10]),
};

function toggleHfx() {
  const newVal = !HFX.isOn();
  HFX.setOn(newVal);
  const tog = document.getElementById('hfxToggle');
  if(tog) tog.classList.toggle('on', newVal);
  if(newVal) { SFX.play('toggle'); setTimeout(()=>HFX.medium(), 80); }
}

// ─── Запуск приложения ───
init();

// ══════════════════════════════════════════════════
// BMI
// ══════════════════════════════════════════════════
function rBMI() {
  if(!U || !U.w || !U.h) return;
  const h = (U.h||170) / 100;
  const bmi = Math.round((U.w / (h*h)) * 10) / 10;
  const el  = document.getElementById('bmiVal');
  const cat = document.getElementById('bmiCat');
  const needle = document.getElementById('bmiNeedle');
  if(!el) return;

  // Animated counter
  const duration = 800;
  const start = performance.now();
  const startVal = parseFloat(el.dataset.val || '0') || 0;
  el.dataset.val = bmi;
  const tick = (now) => {
    const p = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    el.textContent = (startVal + (bmi - startVal) * ease).toFixed(1);
    if(p < 1) requestAnimationFrame(tick);
    else el.textContent = bmi;
  };
  requestAnimationFrame(tick);

  // Category
  let label, cls;
  if(bmi < 18.5)      { label='Недовес'; cls='under'; }
  else if(bmi < 25)   { label='Норма ✓'; cls='norm'; }
  else if(bmi < 30)   { label='Избыток'; cls='over'; }
  else                { label='Ожирение'; cls='obese'; }
  cat.textContent = label;
  cat.className = 'bmi-cat '+cls;

  // Needle (scale 16–40)
  const pct = Math.max(0, Math.min(96, (bmi - 16) / (40 - 16) * 100));
  if(needle) needle.style.left = pct+'%';
}

// ══════════════════════════════════════════════════
// WATER BALANCE
// ══════════════════════════════════════════════════
const DRINKS = [
  { id:'water',  icon:'💧', name:'Вода',    ml:250, hydration:1.0 },
  { id:'tea',    icon:'🍵', name:'Чай',     ml:200, hydration:0.9 },
  { id:'coffee', icon:'☕', name:'Кофе',    ml:150, hydration:0.6 },
  { id:'juice',  icon:'🧃', name:'Сок',     ml:200, hydration:0.85 },
  { id:'milk',   icon:'🥛', name:'Молоко',  ml:200, hydration:0.9 },
  { id:'other',  icon:'🫗', name:'Другое',  ml:200, hydration:0.8 },
];

function getWaterGoal() {
  const base = Math.round((U?.w||70) * 30 / 50) * 50;
  const goal = Math.max(1500, Math.min(3500, base));
  const saltWords = ['чипсы','соленый','соль','рыба','сыр','колбаса','пицца','бургер','хот-дог','соевый','рамен'];
  const hasSalt = dlog(ds()).some(i => saltWords.some(s => (i.food||'').toLowerCase().includes(s)));
  return { goal, hasSalt, adjusted: hasSalt ? Math.round(goal * 1.2 / 50) * 50 : goal };
}

function getWaterToday() {
  try { return JSON.parse(G('water_'+ds(),'[]')); } catch(e) { return []; }
}

function addWater(drinkId) {
  const drink = DRINKS.find(d => d.id === drinkId);
  if(!drink) return;
  const arr = getWaterToday();
  arr.push({ id: drinkId, ml: drink.ml, t: tnow() });
  S('water_'+ds(), JSON.stringify(arr));
  HFX.success(); SFX.play('add_food');
  rWater();
}

function undoLastWater() {
  const arr = getWaterToday();
  if(!arr.length) return;
  arr.pop();
  S('water_'+ds(), JSON.stringify(arr));
  HFX.light(); SFX.play('sheet_close');
  rWater();
}

function rWater() {
  if(!U) return;
  const { goal, hasSalt, adjusted } = getWaterGoal();
  const arr = getWaterToday();
  const hydrated = arr.reduce((s,e) => {
    const d = DRINKS.find(x => x.id === e.id);
    return s + e.ml * (d?.hydration||1);
  }, 0);
  const totalMl = arr.reduce((s,e) => s+e.ml, 0);
  const pct = Math.min(hydrated / adjusted, 1);

  const mlEl = document.getElementById('waterConsumedMl');
  const glEl = document.getElementById('waterGoalMl');
  const barEl = document.getElementById('waterBar');
  if(!mlEl) return;

  mlEl.textContent = Math.round(totalMl);
  glEl.textContent = adjusted;
  if(barEl) {
    barEl.style.width = (pct*100)+'%';
    barEl.style.background = pct >= 1
      ? 'linear-gradient(90deg,#22c55e,#16a34a)'
      : 'linear-gradient(90deg,#60a5fa,#3b82f6)';
  }

  const hint = document.getElementById('waterSaltHint');
  if(hint) {
    hint.classList.toggle('on', hasSalt);
    hint.textContent = `🧂 Солёная еда — рекомендую +20% воды (${adjusted} мл)`;
  }

  // Drink buttons with counter badge
  const dc = document.getElementById('waterDrinks');
  if(dc) {
    dc.innerHTML = DRINKS.map(d => {
      const count = arr.filter(e=>e.id===d.id).length;
      return `<div class="water-btn${count>0?' hit':''}" onclick="addWater('${d.id}')">
        ${count>0?`<div class="water-count">${count}</div>`:''}
        <span class="water-btn-icon">${d.icon}</span>
        <span class="water-btn-name">${d.name}</span>
        <span class="water-btn-ml">+${d.ml}мл</span>
      </div>`;
    }).join('');
  }

  // Drop indicators
  const drops = document.getElementById('waterDrops');
  if(drops) {
    const full = Math.min(Math.round(pct*8), 8);
    drops.innerHTML = Array.from({length:8},(_,i)=>
      `<div class="water-drop${i<full?' full':''}"></div>`
    ).join('');
  }

  // Undo button visibility
  const undoBtn = document.getElementById('waterUndoBtn');
  if(undoBtn) undoBtn.style.display = arr.length ? 'flex' : 'none';
}

// ══════════════════════════════════════════════════
// DAILY TIP (compact)
// ══════════════════════════════════════════════════
let _tipLoading = false;

async function loadDailyTip(force=false) {
  const el = document.getElementById('tipText');
  const btn = document.getElementById('tipRefreshBtn');
  if(!el) return;
  if(!key) { el.className='tip-compact-text'; el.textContent='Добавь API ключ для совета'; return; }
  const todayKey = 'tip_'+ds();
  const cached = G(todayKey);
  if(cached && !force) { el.className='tip-compact-text loaded'; el.textContent=cached; return; }
  if(_tipLoading) return;
  _tipLoading = true;
  if(btn) btn.classList.add('spin');
  // Skeleton
  el.className='tip-compact-text skeleton'; el.textContent='   ';
  const tl=dlog(ds()), t=tot(tl);
  const sys=`Ты нутрициолог. Пользователь: ${U?.name}, ${U?.age||'?'}л, ${U?.w||'?'}кг, цель: ${GL[U?.goal]||'—'}. Сегодня: ${t.k} из ${U?.kcal||2000}ккал. Один практичный совет, 1-2 предложения. Без приветствий. По-русски.`;
  try {
    const r = await gem([{text:'Совет'}], sys);
    const clean = r.replace(/\*\*(.*?)\*\*/g,'$1').split('\n')[0].trim();
    el.className='tip-compact-text loaded'; el.textContent=clean;
    S(todayKey, clean);
    HFX.light();
  } catch(e) {
    el.className='tip-compact-text'; el.textContent='Совет недоступен — проверь API ключ.';
  }
  _tipLoading=false;
  if(btn) btn.classList.remove('spin');
}

// ══════════════════════════════════════════════════
// WEEKLY ANALYSIS
// ══════════════════════════════════════════════════
let _weekLoading = false;

async function loadWeekAnalysis(force=false) {
  if(!key) { document.getElementById('weekAiBody').innerHTML='<div class="week-ai-empty">Добавь API ключ Gemini в Настройках</div>'; return; }

  const wkKey = 'week_'+new Date().toISOString().slice(0,7)+'_'+Math.floor(new Date().getDate()/7);
  const cached = G(wkKey);
  if(cached && !force) { renderWeekAnalysis(JSON.parse(cached)); return; }
  if(_weekLoading) return;
  _weekLoading = true;

  const btn = document.getElementById('weekAiBtn');
  if(btn){ btn.disabled=true; btn.textContent='...'; }
  document.getElementById('weekAiBody').innerHTML='<div class="week-ai-empty">🤖 AI анализирует питание за 7 дней...</div>';
  document.getElementById('weekAiSub').textContent='Анализирую...';

  // Собираем данные за 7 дней
  const days7 = [];
  for(let i=0;i<7;i++){
    const d=new Date(); d.setDate(d.getDate()-i);
    const dl=dlog(ds(d)), t=tot(dl);
    if(dl.length) days7.push({day:d.toLocaleDateString('ru',{weekday:'short',day:'numeric',month:'short'}), kcal:t.k, prot:Math.round(t.p), carb:Math.round(t.c), fat:Math.round(t.f), count:dl.length});
  }
  if(days7.length<2){ document.getElementById('weekAiBody').innerHTML='<div class="week-ai-empty">Нужно минимум 2 дня данных для анализа. Записывай еду каждый день!</div>'; if(btn){btn.disabled=false;btn.textContent='Анализ';} _weekLoading=false; return; }

  const daysSummary = days7.map(d=>`${d.day}: ${d.kcal}ккал (Б${d.prot}г У${d.carb}г Ж${d.fat}г, ${d.count} приёмов)`).join('\n');
  const sys=`Ты персональный нутрициолог. Данные пользователя: ${U?.name}, цель: ${GL[U?.goal]||'—'}, норма: ${U?.kcal||2000}ккал.\nДанные за последние дни:\n${daysSummary}\n\nДай анализ в формате JSON:\n{"good":"что хорошо (1-2 предложения)","warn":"что стоит улучшить (1-2 предложения)","tip":"конкретный совет на следующую неделю (1-2 предложения)"}\nТолько JSON, по-русски, кратко.`;

  try {
    const raw = await gem([{text:'Анализ питания за неделю'}], sys);
    let r; try{r=pj(raw);}catch(e){r={good:'Стабильное питание.',warn:'Старайся записывать все приёмы пищи.',tip:'Добавь больше белка в рацион.'};}
    const data = {good:r.good||'',warn:r.warn||'',tip:r.tip||'', date:ds()};
    S(wkKey, JSON.stringify(data));
    renderWeekAnalysis(data);
    HFX.success();
  } catch(e) {
    document.getElementById('weekAiBody').innerHTML='<div class="week-ai-empty">Ошибка загрузки. Проверь API ключ.</div>';
  }
  _weekLoading=false;
  if(btn){btn.disabled=false;btn.textContent='Обновить';}
  document.getElementById('weekAiSub').textContent='AI анализ питания за 7 дней';
}

function renderWeekAnalysis(data) {
  const btn = document.getElementById('weekAiBtn');
  if(btn){btn.disabled=false;btn.textContent='Обновить';}
  document.getElementById('weekAiSub').textContent='Обновлено '+data.date;
  document.getElementById('weekAiBody').innerHTML=`
    <div class="week-ai-sections">
      ${data.good?`<div class="week-ai-section good"><div class="week-ai-section-title">✓ Хорошо</div><div class="week-ai-section-text">${data.good}</div></div>`:''}
      ${data.warn?`<div class="week-ai-section warn"><div class="week-ai-section-title">⚠ Стоит улучшить</div><div class="week-ai-section-text">${data.warn}</div></div>`:''}
      ${data.tip?`<div class="week-ai-section tip"><div class="week-ai-section-title">💡 Совет на неделю</div><div class="week-ai-section-text">${data.tip}</div></div>`:''}
    </div>`;
}

// ══════════════════════════════════════════════════
// NOTIFICATIONS
// ══════════════════════════════════════════════════
const NOTIF_MSGS = [
  {title:'💧 Пора выпить воды', body:'Не забывай про водный баланс! Выпей стакан воды.'},
  {title:'🥗 Записал обед?', body:'Не забудь записать что ел — это займёт 10 секунд.'},
  {title:'🌙 Итоги дня', body:'Как прошёл день? Проверь свои калории в CalSnap.'},
  {title:'☀️ Доброе утро!', body:'Новый день — новые возможности. Записывай завтрак!'},
];

async function setupNotifications() {
  if(!('Notification' in window)){
    cfrmShow('⚠️','Уведомления недоступны','Ваш браузер не поддерживает Web Push уведомления. Попробуйте установить приложение как PWA.',null,'Понятно');
    return;
  }
  if(Notification.permission==='granted'){
    _scheduleNotifs();
    _updateNotifStatus(true);
    HFX.success(); SFX.play('save');
    return;
  }
  if(Notification.permission==='denied'){
    cfrmShow('🔕','Уведомления заблокированы','Разреши уведомления в настройках браузера: Настройки → Сайты → Уведомления',null,'Понятно');
    return;
  }
  const perm = await Notification.requestPermission();
  if(perm==='granted'){
    _scheduleNotifs();
    _updateNotifStatus(true);
    HFX.success(); SFX.play('save');
    setTimeout(()=>{
      new Notification('🍎 CalSnap', {body:'Буду напоминать о воде и питании!', icon:'icons/icon-192.png'});
    }, 500);
  } else {
    _updateNotifStatus(false);
    HFX.error();
  }
}

function _updateNotifStatus(on) {
  const st = document.getElementById('notifStatus');
  const arr = document.getElementById('notifArr');
  if(on){
    if(st) st.innerHTML='<span class="notif-dot"></span>Включены';
    if(arr) { arr.textContent='✓'; arr.style.color='var(--green)'; }
  } else {
    if(st) st.textContent='Разреши в настройках браузера';
    if(arr) { arr.textContent='›'; arr.style.color=''; }
  }
}

function _scheduleNotifs() {
  // Напоминания через Service Worker / setInterval (каждые 2ч)
  S('notif_enabled','1');
  // Простые напоминания через setInterval для текущей сессии
  const intervals = [8*60, 11*60, 14*60, 17*60, 20*60]; // минуты от 00:00
  const now = new Date();
  const nowMin = now.getHours()*60+now.getMinutes();
  intervals.forEach(min => {
    const diff = min - nowMin;
    if(diff > 2) {
      setTimeout(() => {
        if(Notification.permission==='granted') {
          const msg = NOTIF_MSGS[Math.floor(Math.random()*NOTIF_MSGS.length)];
          new Notification(msg.title, {body:msg.body, icon:'icons/icon-192.png'});
        }
      }, diff*60*1000);
    }
  });
}

// ══════════════════════════════════════════════════
// AUTHORS MODAL
// ══════════════════════════════════════════════════
function openAbout() {
  HFX.light(); SFX.play('sheet_open');
  document.getElementById('aboutOv').classList.add('on');
  document.body.style.overflow='hidden';
}
function closeAbout() {
  SFX.play('sheet_close');
  document.getElementById('aboutOv').classList.remove('on');
  document.body.style.overflow='';
}


let _isOfflineMode = false;

function checkConnection() {
  // Используем Image ping — SW его не перехватывает, в отличие от fetch
  return new Promise(resolve => {
    if (!navigator.onLine) { resolve(false); return; }
    const img = new Image();
    const ts = Date.now();
    img.onload  = () => resolve(true);
    img.onerror = () => resolve(false);
    // Случайный параметр чтобы не брать из кеша
    img.src = 'https://www.google.com/favicon.ico?_=' + ts;
    // Таймаут 4 секунды
    setTimeout(() => resolve(false), 4000);
  });
}

function showOfflineModal() {
  // Убеждаемся что кнопка "Проверить" видна
  const btn = document.getElementById('offlRetryBtn');
  if(btn){ btn.style.display=''; btn.disabled=false;
    btn.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg> Проверить соединение';
  }
  document.getElementById('offlOv').classList.add('on');
}

function hideOfflineModal() {
  document.getElementById('offlOv').classList.remove('on');
}

function enterOffline() {
  _isOfflineMode = true;
  hideOfflineModal();
  document.getElementById('offlBar').classList.add('on');
  // Блокируем AI кнопку
  document.querySelectorAll('.nb').forEach(b => {
    if(b.getAttribute('onclick')?.includes("'ai'")) {
      b.style.opacity='.35'; b.style.pointerEvents='none';
    }
  });
  // Блокируем кнопку добавить еду
  const addBtn = document.querySelector('.nb-add');
  if(addBtn){ addBtn.style.opacity='.35'; addBtn.style.pointerEvents='none'; }
}

function retryConnection() {
  const btn = document.getElementById('offlRetryBtn');
  if(btn){ btn.disabled=true; btn.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="animation:spin .7s linear infinite"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg> Проверяю...'; }
  checkConnection().then(online => {
    if(online) {
      hideOfflineModal();
    } else {
      // Нет интернета — тряска карточки
      if(btn){ btn.disabled=false; btn.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg> Проверить соединение'; }
      const card = document.querySelector('.offl-card');
      if(card){ card.classList.remove('offl-shake'); void card.offsetWidth; card.classList.add('offl-shake'); }
    }
  });
}

// Восстановление соединения
window.addEventListener('online', () => {
  setTimeout(() => {
    checkConnection().then(ok => {
      if(ok && _isOfflineMode) {
        _isOfflineMode = false;
        document.getElementById('offlBar').classList.remove('on');
        document.querySelectorAll('.nb').forEach(b => { b.style.opacity=''; b.style.pointerEvents=''; });
        const addBtn = document.querySelector('.nb-add');
        if(addBtn){ addBtn.style.opacity=''; addBtn.style.pointerEvents=''; }
      }
    });
  }, 500);
});

// Проверяем после сплэша

(function(){
  const s=document.getElementById('splashOv');
  if(!s) return;
  // Звук запуска приложения
  SFX.play('splash');
  setTimeout(()=>{
    s.classList.add('hide');
    setTimeout(()=>{
      s.style.display='none';
      // Проверяем интернет после сплэша
      if(!navigator.onLine){
        showOfflineModal();
      } else {
        checkConnection().then(ok=>{ if(!ok) showOfflineModal(); });
      }
    },550);
  },1800);
})();
</script>

  <script>
    // ── SERVICE WORKER + АВТООБНОВЛЕНИЕ ──
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./sw.js').then(reg => {

          // Проверяем обновление каждый раз при открытии приложения
          reg.update();

          // Новый SW установился и ждёт — показываем баннер обновления
          reg.addEventListener('updatefound', () => {
            const newSW = reg.installing;
            newSW.addEventListener('statechange', () => {
              if (newSW.state === 'installed' && navigator.serviceWorker.controller) {
                showUpdateBanner(newSW);
              }
            });
          });

        }).catch(e => console.log('SW error:', e));

        // Если SW взял контроль (после обновления) — перезагружаем страницу
        let refreshing = false;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (!refreshing) { refreshing = true; window.location.reload(); }
        });
      });
    }

    function showUpdateBanner(newSW) {
      const b = document.getElementById('updateBanner');
      if (!b) return;
      b.style.display = 'flex';
      document.getElementById('updateBtn').onclick = () => {
        b.style.display = 'none';
        newSW.postMessage('skipWaiting');
      };
    }

    // ── PWA INSTALL PROMPT ──
    let deferredPrompt;
    window.addEventListener('beforeinstallprompt', e => {
      e.preventDefault();
      deferredPrompt = e;
      setTimeout(() => { if (deferredPrompt) showInstallBanner(); }, 3000);
    });

    function showInstallBanner() {
      const banner = document.getElementById('installBanner');
      if (banner) banner.style.display = 'flex';
    }

    function installPWA() {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(r => {
        deferredPrompt = null;
        document.getElementById('installBanner').style.display = 'none';
      });
    }
  </script>

  <!-- БАННЕР ОБНОВЛЕНИЯ -->
  <div id="updateBanner" style="display:none;position:fixed;top:calc(env(safe-area-inset-top,0px) + 12px);left:12px;right:12px;background:var(--primary);color:#fff;border-radius:16px;padding:14px 16px;z-index:9999;align-items:center;gap:12px;box-shadow:0 4px 20px rgba(0,0,0,0.25)">
    <div style="font-size:22px">🆕</div>
    <div style="flex:1">
      <div style="font-size:14px;font-weight:800">Доступно обновление!</div>
      <div style="font-size:12px;opacity:.7;margin-top:2px">Новая версия CalSnap готова</div>
    </div>
    <button id="updateBtn" style="background:var(--orange);color:#fff;border:none;border-radius:10px;padding:8px 14px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap">Обновить</button>
    <button onclick="document.getElementById('updateBanner').style.display='none'" style="background:rgba(255,255,255,.15);border:none;border-radius:8px;color:#fff;padding:6px 8px;font-size:13px;cursor:pointer">✕</button>
  </div>

<!-- WEIGHT LOG MODAL -->
<div class="wlog-ov" id="wlogOv" onclick="if(event.target===this)closeWlog()">
  <div class="wlog-sheet">
    <div class="wlog-header">
      <div class="wlog-title">Записать вес</div>
      <button class="wlog-close" onclick="closeWlog()">✕</button>
    </div>
    <div class="wlog-sub">Введи текущий вес для отслеживания динамики</div>
    <div class="wlog-weight-row">
      <button class="wlog-step-btn" onclick="wlogStep(-0.1)">−</button>
      <div>
        <div class="wlog-weight-val" id="wlogVal">70.0</div>
      </div>
      <span class="wlog-weight-unit">кг</span>
      <button class="wlog-step-btn" onclick="wlogStep(0.1)">+</button>
    </div>
    <div class="wlog-trend" id="wlogTrend"></div>
    <button class="btn" onclick="saveWlog()" style="margin-bottom:10px">💾 Сохранить</button>
    <button class="btn2" onclick="closeWlog()">Отмена</button>
  </div>
</div>


<!-- DRUM DATE PICKER -->
<div class="drum-ov" id="drumOv">
  <div class="drum-sheet">
    <div class="drum-header">
      <button class="drum-cancel" onclick="closeDrum()">Отмена</button>
      <div class="drum-title">Дата рождения</div>
      <button class="drum-done" onclick="confirmDrum()">Готово</button>
    </div>
    <div style="display:flex;justify-content:space-around;padding:6px 24px 0">
      <div class="drum-col-label" style="flex:1">День</div>
      <div class="drum-col-label" style="flex:1.4">Месяц</div>
      <div class="drum-col-label" style="flex:1">Год</div>
    </div>
    <div class="drum-cols">
      <div class="drum-sel-line"></div>
      <div class="drum-col" id="drum_d"></div>
      <div class="drum-col" style="flex:1.4" id="drum_m"></div>
      <div class="drum-col" id="drum_y"></div>
      <div class="drum-mask-top"></div>
      <div class="drum-mask-bot"></div>
    </div>
  </div>
</div>

<!-- CUSTOM CONFIRM MODAL -->
<div class="cfrm-ov" id="cfrmOv">
  <div class="cfrm-box">
    <div class="cfrm-body">
      <span class="cfrm-icon" id="cfrmIcon">⚠️</span>
      <div class="cfrm-title" id="cfrmTitle">Подтвердить</div>
      <div class="cfrm-msg" id="cfrmMsg"></div>
    </div>
    <div class="cfrm-btns">
      <button class="cfrm-btn danger" id="cfrmOkBtn" onclick="cfrmConfirm()">Удалить</button>
      <button class="cfrm-btn cancel" onclick="cfrmCancel()">Отмена</button>
    </div>
  </div>
</div>

</body>
</html>
