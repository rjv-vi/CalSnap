<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="CalSnap">
<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)">
<meta name="theme-color" content="#F5F5F5" media="(prefers-color-scheme: light)">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<title>CalSnap</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;0,9..40,900;1,9..40,400&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   CalSnap — Cal AI Design System
   Clean · Minimal · Bold
   ═══════════════════════════════════════════════════ */

*, *::before, *::after {
  box-sizing: border-box; margin: 0; padding: 0;
  -webkit-tap-highlight-color: transparent;
}
:root {
  font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  -webkit-font-smoothing: antialiased;

  /* Cal AI Color Palette — clean white + black + orange fire */
  --bg:        #F5F5F5;
  --bg2:       #EBEBEB;
  --card:      #FFFFFF;
  --card2:     #F5F5F5;

  /* Labels */
  --lbl:       #0A0A0A;
  --lbl2:      rgba(10,10,10,.50);
  --lbl3:      rgba(10,10,10,.28);
  --lbl4:      rgba(10,10,10,.12);

  /* Fills */
  --fill1:     rgba(10,10,10,.10);
  --fill2:     rgba(10,10,10,.07);
  --fill3:     rgba(10,10,10,.04);

  /* Separators */
  --sep:       rgba(10,10,10,.12);
  --sep2:      rgba(10,10,10,.08);

  /* Cal AI accent — orange fire only */
  --ios-orange:   #FF6B00;
  --ios-green:    #22C55E;
  --ios-blue:     #3B82F6;
  --ios-red:      #EF4444;
  --ios-amber:    #F59E0B;
  --ios-indigo:   #6366F1;
  --ios-purple:   #A855F7;
  --ios-teal:     #14B8A6;
  --ios-pink:     #EC4899;

  /* Cal AI primary = BLACK, fire accent = orange */
  --primary:       #0A0A0A;
  --primary-light: rgba(10,10,10,.08);
  --orange:        #FF6B00;
  --orange-light:  rgba(255,107,0,.08);
  --orange-mid:    rgba(255,107,0,.20);
  --green:         #22C55E;
  --green-light:   rgba(34,197,94,.10);
  --blue:          #3B82F6;
  --blue-light:    rgba(59,130,246,.10);
  --red:           #EF4444;
  --red-light:     rgba(239,68,68,.10);
  --amber:         #F59E0B;
  --white:         var(--card);
  --text:          var(--lbl);
  --text2:         var(--lbl2);
  --text3:         var(--lbl3);
  --border:        var(--sep2);
  --border2:       var(--sep);
  --bg-fill:       var(--card2);

  /* Chrome bars */
  --chrome-bg:     rgba(245,245,245,.92);

  /* Radius — slightly larger for Cal AI feel */
  --r:   12px;
  --r2:  16px;
  --r3:  22px;
  --r4:  32px;

  /* Shadows — very subtle */
  --s1: 0 1px 4px rgba(0,0,0,.06);
  --s2: 0 4px 16px rgba(0,0,0,.07);
  --s3: 0 8px 28px rgba(0,0,0,.10);
  --s-orange: 0 4px 16px rgba(255,107,0,.28);

  --text:    var(--lbl);
  --text2:   var(--lbl2);
  --text3:   var(--lbl3);
  --border:  var(--sep2);
  --border2: var(--sep);
  --bg-card: var(--card);
}

/* ── DARK MODE ── */
[data-theme="dark"] {
  --bg:        #0A0A0A;
  --bg2:       #141414;
  --card:      #1A1A1A;
  --card2:     #222222;
  --lbl:       #FAFAFA;
  --lbl2:      rgba(250,250,250,.55);
  --lbl3:      rgba(250,250,250,.28);
  --lbl4:      rgba(250,250,250,.12);
  --fill1:     rgba(250,250,250,.12);
  --fill2:     rgba(250,250,250,.08);
  --fill3:     rgba(250,250,250,.05);
  --sep:       rgba(250,250,250,.12);
  --sep2:      rgba(250,250,250,.07);
  --primary:   #FAFAFA;
  --primary-light: rgba(250,250,250,.10);
  --ios-green: #4ADE80;
  --ios-blue:  #60A5FA;
  --ios-red:   #F87171;
  --ios-orange:#FF8C00;
  --orange:    #FF8C00;
  --orange-light: rgba(255,140,0,.10);
  --orange-mid:   rgba(255,140,0,.22);
  --chrome-bg: rgba(20,20,20,.92);
  --s1: 0 1px  4px rgba(0,0,0,.4);
  --s2: 0 4px 16px rgba(0,0,0,.45);
  --s3: 0 8px 28px rgba(0,0,0,.55);
}
[data-theme="dark"] .mac  { background: var(--card2) !important; }
[data-theme="dark"] .fd-mac { background: #222222 !important; }
[data-theme="dark"] .res  { background: var(--card2) !important; }
[data-theme="dark"] .rm   { background: #2A2A2A !important; }
[data-theme="dark"] .scan-box { background: var(--bg2) !important; }
[data-theme="dark"] .upzone { background: var(--bg2) !important; border-color: var(--sep) !important; }
[data-theme="dark"] .txa  { background: var(--bg2) !important; }
[data-theme="dark"] .inp  { background: var(--bg2) !important; box-shadow: none !important; }
[data-theme="dark"] input, [data-theme="dark"] textarea, [data-theme="dark"] select {
  background: var(--bg2) !important; color: var(--lbl) !important;
}

/* ── BASE ── */
html, body {
  height: 100%; overflow: hidden;
  background: var(--bg); color: var(--lbl);
  overscroll-behavior: none;
  -webkit-overflow-scrolling: touch;
}
.screen {
  position: fixed; inset: 0;
  overflow-y: auto; overflow-x: hidden;
  display: none; background: var(--bg);
  overscroll-behavior-y: contain;
}
.screen.active { display: block; }
::-webkit-scrollbar { display: none; }
input, textarea, select { font-family: inherit; font-size: 17px !important; }
.screen, .sheet, .ai-msgs { -webkit-overflow-scrolling: touch; }

/* ── TOGGLE — Cal AI style ── */
.toggle {
  width:51px; height:31px;
  background: rgba(10,10,10,.18);
  border-radius:16px; position:relative;
  transition: background .22s; flex-shrink:0; cursor:pointer;
}
.toggle.on { background:#22C55E; }
[data-theme="dark"] .toggle.on { background:#4ADE80; }
.toggle::after {
  content:''; position:absolute; top:2px; left:2px;
  width:27px; height:27px; background:#fff; border-radius:50%;
  transition: transform .25s cubic-bezier(.36,.66,.04,1);
  box-shadow: 0 2px 6px rgba(0,0,0,.20);
}
.toggle.on::after { transform:translateX(20px); }

/* ══════════════════════════════════════════════════
   ONBOARDING — Cal AI: clean, bold, minimal
   ══════════════════════════════════════════════════ */
#ob {
  background: #FFFFFF;
  display:flex; align-items:center; justify-content:center;
}
[data-theme="dark"] #ob { background: #0A0A0A; }
.ob-inner {
  width:100%; max-width:390px;
  padding: calc(env(safe-area-inset-top,44px) + 24px) 28px calc(env(safe-area-inset-bottom,0px) + 48px);
}
.ob-logo { text-align:center; margin-bottom:52px; }
.ob-logo .icon {
  font-size:68px; display:block; margin-bottom:14px;
  filter: drop-shadow(0 8px 20px rgba(255,107,0,.30));
}
.ob-logo h1 { font-size:40px; font-weight:800; letter-spacing:-2px; color:#0A0A0A; }
[data-theme="dark"] .ob-logo h1 { color:#FAFAFA; }
.ob-logo h1 b { color:var(--ios-orange); font-weight:800; }
.ob-logo p { font-size:15px; color:var(--lbl2); margin-top:6px; font-weight:400; }
.ob-step { display:none; animation: obFadeUp .35s ease; }
.ob-step.on { display:block; }
.ob-h { font-size:30px; font-weight:800; letter-spacing:-1px; margin-bottom:8px; color:var(--lbl); }
.ob-s { font-size:15px; color:var(--lbl2); margin-bottom:28px; line-height:1.6; }
.ob-prog { display:flex; gap:5px; margin-bottom:36px; }
.op {
  flex:1; height:3px; border-radius:2px;
  background:var(--fill2); transition:background .3s;
}
.op.done { background:var(--primary); }

/* Inputs — Cal AI clean style */
.inp {
  width:100%;
  background: var(--card);
  border: 1.5px solid var(--sep);
  border-radius:14px;
  padding:15px 16px;
  color:var(--lbl);
  font-size:17px; font-weight:400;
  outline:none;
  transition: border-color .2s, box-shadow .2s;
  margin-bottom:12px;
  -webkit-appearance:none;
  box-shadow: var(--s1);
}
.inp:focus {
  border-color:var(--primary);
  box-shadow: 0 0 0 3px rgba(10,10,10,.08), var(--s1);
}
[data-theme="dark"] .inp:focus { box-shadow: 0 0 0 3px rgba(250,250,250,.10); border-color: var(--lbl); }
.inp::placeholder { color:var(--lbl3); }
.inp-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px; }

/* Goal / Activity cards — Cal AI style */
.goal-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:24px; }
.goal-card {
  background:var(--card); border:2px solid var(--sep2);
  border-radius:18px; padding:20px 8px 16px;
  text-align:center; cursor:pointer;
  transition: all .2s cubic-bezier(.2,.6,.4,1);
  box-shadow: var(--s1);
}
.goal-card.on { border-color:var(--primary); background:var(--primary-light); }
.goal-card .gi { font-size:30px; display:block; margin-bottom:10px; }
.goal-card .gn { font-size:13px; font-weight:700; color:var(--lbl); }
.act-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:24px; }
.act-card {
  background:var(--card); border:2px solid var(--sep2);
  border-radius:16px; padding:16px 14px;
  cursor:pointer; transition:all .2s; box-shadow:var(--s1);
}
.act-card.on { border-color:var(--primary); background:var(--primary-light); }
.act-card .an { font-size:14px; font-weight:700; color:var(--lbl); }
.act-card .as { font-size:12px; color:var(--lbl2); margin-top:4px; }

/* Buttons — Cal AI: primary is BLACK pill */
.btn {
  width:100%; background:var(--primary);
  color:#fff; border:none; border-radius:14px;
  padding:16px; font-size:17px; font-weight:700;
  cursor:pointer; letter-spacing:-.2px;
  transition: filter .15s, transform .1s;
}
[data-theme="dark"] .btn { background: #FAFAFA; color: #0A0A0A; }
.btn:active { filter:brightness(.85); transform:scale(.98); }
.btn2 {
  width:100%; background:var(--fill2);
  color:var(--lbl); border:none; border-radius:14px;
  padding:16px; font-size:17px; font-weight:600;
  cursor:pointer; margin-top:10px;
  transition: filter .15s;
}
.btn2:active { filter:brightness(.92); }

/* ══════════════════════════════════════════════════
   BOTTOM TAB BAR — Cal AI Style
   ══════════════════════════════════════════════════ */
#nav {
  position:fixed; bottom:0; left:0; right:0;
  height: calc(58px + env(safe-area-inset-bottom));
  background: rgba(255,255,255,.95);
  -webkit-backdrop-filter: saturate(200%) blur(28px);
  backdrop-filter: saturate(200%) blur(28px);
  border-top: 1px solid var(--sep2);
  display:none; align-items:flex-start; justify-content:space-around;
  z-index:100;
  padding: 0 8px env(safe-area-inset-bottom);
}
[data-theme="dark"] #nav { background: rgba(20,20,20,.96); }
.nb {
  flex:1; display:flex; flex-direction:column;
  align-items:center; gap:4px;
  padding:10px 4px 2px;
  cursor:pointer; border:none; background:none;
  color:var(--lbl3); transition:color .2s;
  min-height:58px; justify-content:center;
}
.nb.on { color:var(--primary); }
.nb span { font-size:10px; font-weight:600; letter-spacing:.1px; margin-top:1px; opacity:.75; }
.nb.on span { opacity:1; color:var(--primary); }
.nb svg {
  width:24px; height:24px;
  stroke:currentColor; fill:none;
  stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round;
  transition: all .2s;
}
.nb.on svg { stroke-width:2.4; }
/* Cal AI center + button — large black circle */
.nb-add {
  width:52px; height:52px;
  background: var(--primary);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  border:none; cursor:pointer;
  box-shadow: 0 4px 14px rgba(0,0,0,.25);
  transition: transform .15s cubic-bezier(.2,.6,.4,1), box-shadow .15s;
  flex-shrink:0; margin-top:0px;
}
[data-theme="dark"] .nb-add {
  background: #FAFAFA;
  box-shadow: 0 4px 16px rgba(255,255,255,.12);
}
[data-theme="dark"] .nb-add svg { stroke: #0A0A0A; }
.nb-add:active { transform:scale(.88); box-shadow:0 2px 6px rgba(0,0,0,.18); }
.nb-add svg { width:22px; height:22px; stroke:#fff; fill:none; stroke-width:2.8; stroke-linecap:round; }

/* ══════════════════════════════════════════════════
   HOME SCREEN — Cal AI
   ══════════════════════════════════════════════════ */
#home { padding-bottom: calc(58px + env(safe-area-inset-bottom) + 16px); }
.h-top {
  padding: calc(env(safe-area-inset-top,44px) + 8px) 20px 12px;
  display:flex; justify-content:space-between; align-items:center;
}
.h-greet { font-size:13px; color:var(--lbl2); font-weight:500; margin-bottom:3px; }
.h-name  { font-size:28px; font-weight:800; letter-spacing:-1px; color:var(--lbl); }

/* Streak badge — Cal AI orange fire */
.streak {
  display:flex; align-items:center; gap:4px;
  background: var(--orange-light);
  border: 1.5px solid var(--orange-mid);
  border-radius:24px; padding:8px 14px; cursor:pointer;
}
.streak .sf { font-size:18px; }
.streak .sn { font-size:18px; font-weight:800; color:var(--ios-orange); letter-spacing:-0.5px; }
.streak .sl { font-size:11px; color:var(--ios-orange); font-weight:600; }

/* Calendar strip — Cal AI */
.cal-wrap { padding:4px 16px 8px; overflow-x:auto; scrollbar-width:none; }
.cal-inner { display:flex; gap:5px; min-width:max-content; }
.cd { display:flex; flex-direction:column; align-items:center; gap:4px; min-width:44px; cursor:pointer; padding:4px 0; }
.cd .cn { font-size:10px; color:var(--lbl3); font-weight:600; text-transform:uppercase; letter-spacing:.8px; }
.cd .cv {
  width:36px; height:36px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:15px; font-weight:500; color:var(--lbl2);
  transition: all .2s;
}
.cd.today .cv { background:var(--ios-orange); color:#fff; box-shadow:0 2px 10px rgba(255,107,0,.30); font-weight:800; }
.cd.has   .cv { background:var(--green-light); color:var(--ios-green); font-weight:700; }
.cd.over  .cv { background:var(--red-light); color:var(--ios-red); }
.cd.sel   .cv { background:var(--primary-light); color:var(--lbl); font-weight:700; box-shadow:inset 0 0 0 2px var(--primary); }
.cd .cdot { width:4px; height:4px; border-radius:50%; }
.cd.has .cdot { background:var(--ios-green); }
.cd.over .cdot { background:var(--ios-red); }

/* ── MAIN CALORIE CARD — Cal AI style ── */
.cal-card {
  margin: 6px 16px 14px;
  background: var(--card);
  border-radius: 24px;
  padding: 24px 20px 22px;
  box-shadow: var(--s2);
  overflow: hidden;
  position: relative;
}
.cal-card::before {
  content:'';
  position:absolute; top:-80px; right:-80px;
  width:220px; height:220px;
  border-radius:50%;
  background: radial-gradient(circle, rgba(255,107,0,.05) 0%, transparent 70%);
  pointer-events:none;
}
.cc-top { overflow:hidden; margin-bottom:22px; }
.cc-right { float:right; position:relative; }
.cc-ring { display:block; }
.cc-ring-label {
  position:absolute; inset:0;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
}
.cc-pct  { font-size:14px; font-weight:800; color:var(--lbl); letter-spacing:-.5px; }
.cc-pct-s { font-size:8px; color:var(--lbl3); font-weight:700; text-transform:uppercase; letter-spacing:.8px; margin-top:1px; }
.cc-nums { display:flex; align-items:flex-end; gap:4px; margin-bottom:3px; }
.cc-eaten { font-size:52px; font-weight:800; letter-spacing:-3px; color:var(--lbl); line-height:1; font-variant-numeric:tabular-nums; }
.cc-slash { font-size:20px; color:var(--lbl3); font-weight:300; margin-bottom:8px; margin-left:2px; }
.cc-goal  { font-size:22px; font-weight:500; color:var(--lbl2); margin-bottom:8px; font-variant-numeric:tabular-nums; }
.cc-label { font-size:13px; color:var(--lbl2); font-weight:500; letter-spacing:.1px; }
.cc-remain {
  display:inline-flex; align-items:center; gap:5px;
  background:var(--primary-light); border-radius:24px;
  padding:7px 14px; font-size:13px; font-weight:700;
  color:var(--primary); margin-top:14px;
}
.ring-bg { stroke:var(--sep); }

/* Macro mini-cards — Cal AI clean */
.macro-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:2px; }
.mac {
  background:var(--card2); border-radius:16px;
  padding:14px 12px 12px;
  border: 1px solid var(--sep2);
}
.mac-top { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; }
.mac-val  { font-size:17px; font-weight:800; font-variant-numeric:tabular-nums; }
.mac-goal { font-size:11px; color:var(--lbl3); font-weight:500; }
.mac-bar  { height:3px; border-radius:2px; background:var(--sep2); }
.mac-fill { height:3px; border-radius:2px; transition:width .6s cubic-bezier(.22,1,.36,1); }
.mac-name { font-size:11px; color:var(--lbl2); margin-top:7px; font-weight:600; text-transform:uppercase; letter-spacing:.4px; }
.mac-p .mac-val  { color:#E05020; }
.mac-p .mac-fill { background:#E05020; }
.mac-c .mac-val  { color:#C07020; }
.mac-c .mac-fill { background:#C07020; }
.mac-f .mac-val  { color:#2060D0; }
.mac-f .mac-fill { background:#2060D0; }
[data-theme="dark"] .mac-p .mac-val { color:#FF7A52; }
[data-theme="dark"] .mac-p .mac-fill { background:#FF7A52; }
[data-theme="dark"] .mac-c .mac-val { color:#FFA040; }
[data-theme="dark"] .mac-c .mac-fill { background:#FFA040; }
[data-theme="dark"] .mac-f .mac-val { color:#60A5FA; }
[data-theme="dark"] .mac-f .mac-fill { background:#60A5FA; }

/* Section header */
.sec-hdr {
  padding: 6px 20px 10px;
  display:flex; justify-content:space-between; align-items:center;
}
.sec-hdr h3 { font-size:20px; font-weight:800; letter-spacing:-.5px; }

/* ── FOOD LOG ITEMS — Cal AI style ── */
.logitem {
  background:var(--card);
  margin: 0 16px 0;
  padding: 14px 14px 14px 14px;
  display:flex; align-items:center; gap:12px;
  cursor:pointer; transition:opacity .12s; position:relative;
}
.logitem:first-child  { border-radius:18px 18px 0 0; }
.logitem:last-child   { border-radius:0 0 18px 18px; margin-bottom:10px; }
.logitem:first-child:last-child { border-radius:18px; margin-bottom:10px; }
.logitem:not(:last-child)::after {
  content:''; position:absolute; bottom:0; left:78px; right:0;
  height:.5px; background:var(--sep2);
}
.logitem:active { opacity:.65; }
.li-img {
  width:52px; height:52px; border-radius:14px; object-fit:cover;
  flex-shrink:0; background:var(--card2);
  display:flex; align-items:center; justify-content:center; font-size:24px;
  border: 1px solid var(--sep2);
}
.li-info { flex:1; min-width:0; }
.li-name { font-size:16px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--lbl); }
.li-sub  { font-size:13px; color:var(--lbl2); margin-top:2px; font-weight:400; }
.li-macs { display:flex; gap:8px; margin-top:5px; }
.li-mac  { font-size:11px; font-weight:700; }
.li-mac.p { color:#E05020; }
.li-mac.c { color:#C07020; }
.li-mac.f { color:#2060D0; }
[data-theme="dark"] .li-mac.p { color:#FF7A52; }
[data-theme="dark"] .li-mac.c { color:#FFA040; }
[data-theme="dark"] .li-mac.f { color:#60A5FA; }
.li-right { text-align:right; flex-shrink:0; }
.li-kcal  { font-size:17px; font-weight:800; color:var(--lbl); font-variant-numeric:tabular-nums; }
.li-unit  { font-size:10px; color:var(--lbl3); margin-top:1px; }
.li-del   { background:none; border:none; color:var(--lbl3); cursor:pointer; padding:6px; font-size:14px; flex-shrink:0; margin-left:2px; }
.empty    { text-align:center; padding:56px 20px; }
.empty .ei { font-size:56px; display:block; margin-bottom:16px; }
.empty p   { font-size:15px; color:var(--lbl2); line-height:1.6; }

/* API bar */
.api-bar {
  margin: 0 16px 12px;
  background:var(--orange-light); border:1.5px solid var(--orange-mid);
  border-radius:16px; padding:14px 16px;
  display:flex; align-items:center; gap:12px; cursor:pointer;
}
.api-bar .ab-ico { font-size:20px; }
.api-bar .ab-t   { flex:1; font-size:14px; font-weight:700; color:var(--ios-orange); }
.api-bar .ab-s   { font-size:12px; color:rgba(255,107,0,.7); margin-top:1px; font-weight:400; }

/* ══════════════════════════════════════════════════
   PROGRESS SCREEN — Cal AI
   ══════════════════════════════════════════════════ */
#prog { padding-bottom: calc(58px + env(safe-area-inset-bottom) + 16px); }
.pg-hdr {
  padding: calc(env(safe-area-inset-top,44px) + 10px) 20px 14px;
  background:var(--chrome-bg);
  -webkit-backdrop-filter: saturate(200%) blur(28px);
  backdrop-filter: saturate(200%) blur(28px);
  border-bottom: 1px solid var(--sep2);
  position:sticky; top:0; z-index:10;
}
.pg-hdr h2 { font-size:30px; font-weight:800; letter-spacing:-1px; }

/* Streak card — Cal AI orange gradient */
.streak-big-card {
  margin: 14px 16px 12px;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4500 100%);
  border-radius:24px; padding:22px 20px;
  display:flex; align-items:center; gap:18px;
  box-shadow: 0 6px 20px rgba(255,107,0,.35);
}
.sbc-left  { text-align:center; flex-shrink:0; }
.sbc-fire  { font-size:48px; display:block; filter:drop-shadow(0 4px 10px rgba(0,0,0,.2)); }
.sbc-days  { font-size:46px; font-weight:800; color:#fff; line-height:1; letter-spacing:-2px; font-variant-numeric:tabular-nums; }
.sbc-lbl   { font-size:11px; color:rgba(255,255,255,.8); font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-top:2px; }
.sbc-right { flex:1; }
.sbc-right p { font-size:13px; color:rgba(255,255,255,.75); margin-bottom:12px; }
.wk-dots { display:flex; gap:5px; }
.wd {
  width:34px; height:34px; border-radius:50%;
  background: rgba(255,255,255,.18);
  display:flex; align-items:center; justify-content:center;
  font-size:10px; font-weight:700; color:rgba(255,255,255,.55);
}
.wd.done  { background:rgba(255,255,255,.92); color:#FF5500; font-weight:800; }
.wd.today { background:transparent; border:2px solid rgba(255,255,255,.7); color:#fff; }

/* ── FIX: week dots no overflow ── */
.wk-dots { display:flex; gap:4px; flex-wrap:nowrap; overflow:hidden; max-width:100%; }
.wd { width:28px; height:28px; min-width:0; flex-shrink:1; font-size:9px; border-radius:50%; }

/* ══════════════════════════════════════════════════
   QUANTITY CONTROL in Food Detail
   ══════════════════════════════════════════════════ */
.fd-qty-row {
  display:flex; align-items:center; justify-content:space-between;
  background:var(--card2); border-radius:18px;
  padding:14px 20px; margin-top:18px;
  border:1px solid var(--sep2);
}
.fd-qty-label { font-size:15px; font-weight:700; color:var(--lbl); }
.fd-qty-ctrl { display:flex; align-items:center; gap:0; }
.fd-qty-btn {
  width:40px; height:40px; border-radius:50%;
  background:var(--primary); color:#fff;
  border:none; font-size:22px; font-weight:300;
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  transition: transform .15s cubic-bezier(.2,.6,.4,1), opacity .15s;
  line-height:1; flex-shrink:0;
}
[data-theme="dark"] .fd-qty-btn { background:#FAFAFA; color:#0A0A0A; }
.fd-qty-btn:active { transform:scale(.82); opacity:.7; }
.fd-qty-btn.minus { background:var(--fill2); color:var(--lbl); }
.fd-qty-num {
  min-width:48px; text-align:center;
  font-size:26px; font-weight:800; letter-spacing:-1px;
  color:var(--lbl); font-variant-numeric:tabular-nums;
  transition: transform .15s cubic-bezier(.36,.66,.04,1);
  display:inline-block;
}
.li-qty {
  display:inline-flex; align-items:center; justify-content:center;
  background:var(--primary); color:#fff;
  font-size:10px; font-weight:800;
  border-radius:10px; padding:2px 7px; margin-left:5px;
  letter-spacing:.2px; vertical-align:middle;
}
[data-theme="dark"] .li-qty { background:#FAFAFA; color:#0A0A0A; }
@keyframes popIn { from{transform:scale(0.6);opacity:0} to{transform:scale(1);opacity:1} }

/* ══════════════════════════════════════════════════
   AI TRAINER — Complete Redesign
   ══════════════════════════════════════════════════ */

/* AI suggestions chips */
.ai-sugs {
  display:flex; gap:8px; overflow-x:auto; scrollbar-width:none;
  padding:12px 16px 10px; flex-shrink:0;
  border-bottom:1px solid var(--sep2);
  background: var(--card);
}
.ai-sugs::-webkit-scrollbar { display:none; }
.ai-sg {
  flex-shrink:0; background:var(--card2); border:1px solid var(--sep);
  border-radius:24px; padding:9px 16px;
  font-size:13px; font-weight:600; color:var(--lbl);
  cursor:pointer; white-space:nowrap; transition:all .18s;
  box-shadow: var(--s1);
}
.ai-sg:active { transform:scale(.94); background:var(--primary); color:#fff; border-color:var(--primary); }

/* Messages container */
.ai-msgs {
  flex:1; overflow-y:auto; padding:20px 16px 12px;
  display:flex; flex-direction:column; gap:16px;
  min-height:0; -webkit-overflow-scrolling:touch;
}
.ai-msgs::-webkit-scrollbar { display:none; }

/* Message bubbles */
.msg { max-width:82%; animation:msgFadeUp .25s cubic-bezier(.22,1,.36,1); }
.msg-ai   { align-self:flex-start; }
.msg-user { align-self:flex-end; }
.msg-ai-wrap { display:flex; gap:10px; align-items:flex-end; }
.msg-ai-ava {
  width:30px; height:30px; border-radius:50%;
  background: var(--primary);
  display:flex; align-items:center; justify-content:center;
  font-size:14px; flex-shrink:0; margin-bottom:2px;
}
[data-theme="dark"] .msg-ai-ava { background: #FAFAFA; }
.msg-ai .bbl {
  background:var(--card); border:1px solid var(--sep2);
  border-bottom-left-radius:6px; color:var(--lbl);
  box-shadow: var(--s1);
}
.msg-user .bbl {
  background:var(--primary); border-bottom-right-radius:6px; color:#fff;
}
[data-theme="dark"] .msg-user .bbl { background:#FAFAFA; color:#0A0A0A; }
.bbl {
  padding:12px 16px; border-radius:20px;
  font-size:15px; line-height:1.6; font-weight:400;
  word-wrap:break-word;
}
.msg-ai .mn {
  font-size:10px; color:var(--lbl3); font-weight:700;
  margin-bottom:6px; margin-left:40px; letter-spacing:.8px; text-transform:uppercase;
}

/* Typing indicator */
.typing-indicator {
  display:flex; gap:5px; align-items:center;
  padding:14px 18px; background:var(--card);
  border:1px solid var(--sep2); border-radius:20px; border-bottom-left-radius:6px;
  width:fit-content;
}
.typing-dot {
  width:7px; height:7px; border-radius:50%;
  background:var(--lbl3); animation:typingBounce 1.4s infinite ease-in-out;
}
.typing-dot:nth-child(1) { animation-delay:0s; }
.typing-dot:nth-child(2) { animation-delay:.2s; }
.typing-dot:nth-child(3) { animation-delay:.4s; }
@keyframes typingBounce {
  0%,60%,100% { transform:translateY(0); opacity:.4; }
  30% { transform:translateY(-7px); opacity:1; }
}

/* AI input bar */
.ai-bar {
  flex-shrink:0; background:var(--card);
  border-top:1px solid var(--sep2);
  padding:10px 16px calc(16px + env(safe-area-inset-bottom));
  display:flex; gap:10px; align-items:flex-end;
}
.ai-inp {
  flex:1; background:var(--card2); border:1.5px solid var(--sep);
  border-radius:24px; padding:12px 18px;
  color:var(--lbl); font-size:16px; outline:none;
  -webkit-appearance:none; font-weight:400;
  line-height:1.4; font-family:inherit;
  transition: border-color .2s;
}
.ai-inp:focus { border-color:var(--primary); }
.ai-inp::placeholder { color:var(--lbl3); }
.ai-snd {
  width:44px; height:44px; background:var(--primary);
  border:none; border-radius:50%; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; transition:transform .15s cubic-bezier(.2,.6,.4,1), opacity .15s;
}
[data-theme="dark"] .ai-snd { background:#FAFAFA; }
[data-theme="dark"] .ai-snd svg { stroke:#0A0A0A; }
.ai-snd:active { transform:scale(.85); opacity:.8; }
.ai-snd svg { width:18px; height:18px; stroke:#fff; fill:none; stroke-width:2.5; }

/* AI welcome card */
.ai-welcome {
  background: linear-gradient(135deg, #0A0A0A 0%, #2A2A2A 100%);
  border-radius:24px; padding:24px 20px; margin:0 0 4px;
  color:#fff; animation:msgFadeUp .4s cubic-bezier(.22,1,.36,1);
}
[data-theme="dark"] .ai-welcome { background: linear-gradient(135deg, #2A2A2A 0%, #1A1A1A 100%); }
.ai-welcome-icon { font-size:36px; margin-bottom:12px; display:block; }
.ai-welcome-title { font-size:20px; font-weight:800; letter-spacing:-.5px; margin-bottom:6px; }
.ai-welcome-sub { font-size:14px; opacity:.7; line-height:1.6; font-weight:400; }
.ai-chips-label { font-size:11px; font-weight:700; color:var(--lbl3); letter-spacing:.5px; text-transform:uppercase; padding:12px 0 6px; }

@keyframes msgFadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }


/* ══ CUSTOM DATE DRUM PICKER ══ */
.dob-picker-btn {
  width:100%; background:var(--card2);
  border:1.5px solid var(--sep); border-radius:var(--r2);
  padding:14px 16px; color:var(--lbl);
  font-size:16px; font-weight:500; font-family:inherit;
  text-align:left; cursor:pointer; display:flex;
  align-items:center; justify-content:space-between;
  transition:border-color .2s; margin-bottom:8px;
}
.dob-picker-btn:focus,
.dob-picker-btn.filled { border-color:var(--primary); }
.dob-picker-btn .dob-placeholder { color:var(--lbl3); }
.dob-picker-btn .dob-value { color:var(--lbl); font-weight:600; }
.dob-picker-btn svg { flex-shrink:0; }

.drum-ov {
  position:fixed; inset:0; z-index:500;
  background:rgba(0,0,0,.55);
  display:none; align-items:flex-end;
  -webkit-backdrop-filter:blur(16px); backdrop-filter:blur(16px);
}
.drum-ov.on { display:flex; animation:fadeIn .18s ease; }
.drum-sheet {
  background:var(--card); border-radius:28px 28px 0 0; width:100%;
  padding:0 0 calc(24px + env(safe-area-inset-bottom));
  animation:sheetUp .32s cubic-bezier(.32,.72,0,1); overflow:hidden;
}
.drum-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 20px 16px;
  border-bottom:1px solid var(--sep2);
}
.drum-title { font-size:17px; font-weight:800; color:var(--lbl); letter-spacing:-.3px; }
.drum-done {
  background:var(--primary); color:#fff;
  border:none; border-radius:20px; padding:8px 20px;
  font-size:15px; font-weight:700; cursor:pointer;
  font-family:inherit; transition:transform .1s;
}
[data-theme="dark"] .drum-done { background:#FAFAFA; color:#0A0A0A; }
.drum-done:active { transform:scale(.93); }
.drum-cancel {
  background:none; border:none; color:var(--lbl2);
  font-size:15px; font-weight:600; cursor:pointer; font-family:inherit;
  padding:8px 4px;
}

.drum-cols { display:flex; position:relative; padding:0 16px; }
.drum-col {
  flex:1; height:220px; overflow-y:auto;
  scroll-snap-type:y mandatory;
  -webkit-overflow-scrolling:touch; scrollbar-width:none;
  position:relative;
}
.drum-col::-webkit-scrollbar { display:none; }
.drum-item {
  height:44px; display:flex; align-items:center; justify-content:center;
  font-size:18px; font-weight:500; color:var(--lbl2);
  scroll-snap-align:center; cursor:pointer; user-select:none;
  transition:color .15s, transform .15s;
  flex-shrink:0;
}
.drum-item.sel { color:var(--lbl); font-weight:800; font-size:20px; }
/* spacers */
.drum-spacer { height:88px; flex-shrink:0; }
.drum-mask-top, .drum-mask-bot {
  position:absolute; left:0; right:0; height:88px;
  pointer-events:none; z-index:2;
}
.drum-mask-top { top:0; background:linear-gradient(to bottom, var(--card), transparent); }
.drum-mask-bot { bottom:0; background:linear-gradient(to top, var(--card), transparent); }
.drum-sel-line {
  position:absolute; left:16px; right:16px;
  top:50%; transform:translateY(-50%);
  height:44px; background:var(--primary-light);
  border-radius:12px; pointer-events:none; z-index:1;
}
.drum-col-label {
  text-align:center; font-size:11px; font-weight:700;
  color:var(--lbl3); letter-spacing:.5px; text-transform:uppercase;
  padding:10px 0 4px;
}

/* ══ CUSTOM CONFIRM MODAL ══ */
.cfrm-ov {
  position:fixed; inset:0; z-index:600;
  background:rgba(0,0,0,.55);
  display:none; align-items:center; justify-content:center; padding:24px;
  -webkit-backdrop-filter:blur(16px); backdrop-filter:blur(16px);
}
.cfrm-ov.on { display:flex; animation:fadeIn .15s ease; }
.cfrm-box {
  background:var(--card); border-radius:24px; width:100%;
  max-width:360px; overflow:hidden;
  animation:cfrmPop .25s cubic-bezier(.22,1,.36,1);
  box-shadow:0 20px 60px rgba(0,0,0,.25);
}
.cfrm-body { padding:28px 24px 20px; }
.cfrm-icon { font-size:42px; margin-bottom:14px; display:block; }
.cfrm-title { font-size:20px; font-weight:800; color:var(--lbl); letter-spacing:-.4px; margin-bottom:8px; }
.cfrm-msg { font-size:15px; color:var(--lbl2); line-height:1.55; }
.cfrm-btns { display:flex; flex-direction:column; border-top:1px solid var(--sep2); }
.cfrm-btn {
  padding:17px 24px; border:none; background:none;
  font-size:17px; font-weight:600; cursor:pointer;
  font-family:inherit; transition:background .12s;
  color:var(--lbl);
}
.cfrm-btn:active { background:var(--fill2); }
.cfrm-btn.danger { color:var(--ios-red); border-top:1px solid var(--sep2); }
.cfrm-btn.cancel { color:var(--lbl2); }
@keyframes cfrmPop { from{opacity:0;transform:scale(.88)} to{opacity:1;transform:scale(1)} }

/* ══════════════════════════════════════════════════
   ENTRANCE ANIMATIONS
   ══════════════════════════════════════════════════ */
.splash-ov {
  position:fixed; inset:0; z-index:9999;
  background:#0A0A0A;
  display:flex; align-items:center; justify-content:center;
  flex-direction:column;
  pointer-events:none;
}
.splash-ov.hide {
  animation: splashOut 0.55s cubic-bezier(.4,0,.2,1) forwards;
}
.splash-icon {
  font-size:80px; display:block;
  animation: splashBounce 0.7s 0.2s cubic-bezier(.36,.66,.04,1) both;
  filter: drop-shadow(0 12px 32px rgba(255,107,0,.55));
}
.splash-title {
  font-size:44px; font-weight:800; color:#fff; letter-spacing:-2px; margin-top:18px;
  animation: splashFadeUp 0.5s 0.55s both;
}
.splash-title b { color:#FF6B00; }
.splash-sub {
  font-size:15px; color:rgba(255,255,255,.45); font-weight:400; margin-top:8px;
  animation: splashFadeUp 0.5s 0.75s both;
}
@keyframes splashBounce {
  from{transform:scale(0.3) rotate(-15deg);opacity:0}
  70%{transform:scale(1.15) rotate(5deg);opacity:1}
  to{transform:scale(1) rotate(0deg);opacity:1}
}
@keyframes splashFadeUp {
  from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)}
}
@keyframes splashOut {
  from{opacity:1;transform:scale(1)} to{opacity:0;transform:scale(1.1)}
}

.logitem { animation: logItemIn .3s cubic-bezier(.22,1,.36,1) both; }
@keyframes logItemIn {
  from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)}
}
.btn:active,.btn2:active,.wt-btn:active,.fd-del:active { transform:scale(.96); filter:brightness(.9); }

/* Stats grid */
.stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:0 16px 12px; }
.sc {
  background:var(--card); border-radius:20px;
  padding:18px 16px; box-shadow:var(--s1);
  border: 1px solid var(--sep2);
}
.sc-lbl { font-size:11px; font-weight:700; color:var(--lbl2); text-transform:uppercase; letter-spacing:.6px; margin-bottom:8px; }
.sc-val { font-size:30px; font-weight:800; letter-spacing:-1px; font-variant-numeric:tabular-nums; }
.sc-sub { font-size:11px; color:var(--lbl3); margin-top:5px; }

/* Heat map */
.heat-card {
  margin:0 16px 12px; background:var(--card);
  border-radius:20px; padding:20px; box-shadow:var(--s1);
  border: 1px solid var(--sep2);
}
.heat-card h4 { font-size:17px; font-weight:800; margin-bottom:16px; letter-spacing:-.3px; }
.hgrid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; }
.hcell { aspect-ratio:1; border-radius:6px; background:var(--fill3); }
.hcell.c1 { background:rgba(255,107,0,.12); }
.hcell.c2 { background:rgba(255,107,0,.28); }
.hcell.c3 { background:rgba(255,107,0,.54); }
.hcell.c4 { background:var(--ios-orange); }
.hcell.ov1 { background:#FCA5A5; }
.hcell.ov2 { background:#F87171; }
.hcell.ov3 { background:#EF4444; }
.hcell.ov4 { background:#B91C1C; }
.hcell.ov { background:rgba(239,68,68,.22); }
.h-legend { display:flex; align-items:center; gap:6px; margin-top:12px; }
.h-legend span { font-size:10px; color:var(--lbl3); font-weight:500; }
.h-sq { width:10px; height:10px; border-radius:3px; }

/* Weight chart */
.wt-card {
  margin:0 16px 12px; background:var(--card);
  border-radius:20px; padding:20px 20px 14px; box-shadow:var(--s1);
  border: 1px solid var(--sep2);
}
.wt-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; }
.wt-top h4 { font-size:17px; font-weight:800; letter-spacing:-.3px; }
.wt-btn {
  background:var(--primary-light); color:var(--primary);
  border:none; border-radius:24px; padding:7px 16px;
  font-size:13px; font-weight:700; cursor:pointer;
}
canvas { display:block; max-width:100%; }
#wc { border-radius:8px; }
#wempty { text-align:center; font-size:13px; color:var(--lbl3); padding:18px 0; }

/* ══════════════════════════════════════════════════
   AI TRAINER — Cal AI
   ══════════════════════════════════════════════════ */
#ai {
  position:fixed; inset:0; display:none;
  flex-direction:column; background:var(--bg); z-index:200;
}
.ai-hdr {
  padding: calc(env(safe-area-inset-top,44px) + 10px) 20px 14px;
  background:var(--chrome-bg);
  -webkit-backdrop-filter:saturate(200%) blur(28px);
  backdrop-filter:saturate(200%) blur(28px);
  border-bottom:1px solid var(--sep2);
  flex-shrink:0;
  display:flex; align-items:center; gap:14px;
}
.ai-back {
  width:36px; height:36px; border-radius:50%;
  background:var(--fill2); border:none;
  color:var(--lbl); font-size:18px; font-weight:600;
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  flex-shrink:0; line-height:1;
}
.ai-title-wrap { flex:1; }
.ai-hdr h2 { font-size:18px; font-weight:800; color:var(--lbl); letter-spacing:-.3px; }
.ai-hdr p  { font-size:13px; color:var(--lbl2); margin-top:1px; font-weight:400; }
.ai-sugs {
  display:flex; gap:8px; overflow-x:auto; scrollbar-width:none;
  padding:12px 16px; border-bottom:1px solid var(--sep2);
  flex-shrink:0;
}
.ai-sg {
  flex-shrink:0; background:var(--card); border:1px solid var(--sep);
  border-radius:24px; padding:8px 16px;
  font-size:13px; font-weight:600; color:var(--lbl2);
  cursor:pointer; white-space:nowrap; transition:all .15s;
  box-shadow: var(--s1);
}
.ai-sg:active { background:var(--primary); color:#fff; border-color:var(--primary); }
.ai-msgs {
  flex:1; overflow-y:auto; padding:16px 16px 8px;
  display:flex; flex-direction:column; gap:12px;
  min-height:0; -webkit-overflow-scrolling:touch;
}
.msg { max-width:84%; animation:obFadeUp .2s ease; }
.msg-ai   { align-self:flex-start; }
.msg-user { align-self:flex-end; }
.msg-ai   .bbl {
  background:var(--card); border:1px solid var(--sep2);
  border-bottom-left-radius:4px; color:var(--lbl);
  box-shadow:var(--s1);
}
.msg-user .bbl { background:var(--primary); border-bottom-right-radius:4px; color:#fff; }
[data-theme="dark"] .msg-user .bbl { background:#FAFAFA; color:#0A0A0A; }
.bbl { padding:12px 16px; border-radius:18px; font-size:15px; line-height:1.55; font-weight:400; }
.msg-ai .mn {
  font-size:10px; color:var(--lbl3); font-weight:700;
  margin-bottom:6px; margin-left:4px; letter-spacing:.8px; text-transform:uppercase;
}
.ai-bar {
  flex-shrink:0; background:var(--chrome-bg);
  -webkit-backdrop-filter:saturate(200%) blur(28px);
  backdrop-filter:saturate(200%) blur(28px);
  border-top:1px solid var(--sep2);
  padding:10px 16px calc(14px + env(safe-area-inset-bottom));
  display:flex; gap:10px; align-items:center;
}
.ai-inp {
  flex:1; background:var(--card); border:1px solid var(--sep);
  border-radius:24px; padding:11px 18px;
  color:var(--lbl); font-size:16px; outline:none;
  -webkit-appearance:none; font-weight:400;
  box-shadow: var(--s1);
}
.ai-inp::placeholder { color:var(--lbl3); }
.ai-snd {
  width:38px; height:38px; background:var(--primary);
  border:none; border-radius:50%; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
  transition:transform .1s;
}
[data-theme="dark"] .ai-snd { background:#FAFAFA; }
[data-theme="dark"] .ai-snd svg { stroke:#0A0A0A; }
.ai-snd:active { transform:scale(.88); }
.ai-snd svg { width:16px; height:16px; stroke:#fff; fill:none; stroke-width:2.5; }

/* ══════════════════════════════════════════════════
   SETTINGS — Cal AI
   ══════════════════════════════════════════════════ */
#sett { padding-bottom: calc(58px + env(safe-area-inset-bottom) + 16px); }
.st-hdr {
  padding: calc(env(safe-area-inset-top,44px) + 10px) 20px 14px;
  background:var(--chrome-bg);
  -webkit-backdrop-filter:saturate(200%) blur(28px);
  backdrop-filter:saturate(200%) blur(28px);
  position:sticky; top:0; z-index:10;
  border-bottom: 1px solid var(--sep2);
}
.st-hdr h2 { font-size:30px; font-weight:800; letter-spacing:-1px; }
.st-sec { margin: 12px 16px 0; }
.st-lbl { font-size:12px; color:var(--lbl2); padding:0 4px 8px; font-weight:600; letter-spacing:.3px; text-transform:uppercase; }
.st-card { background:var(--card); border-radius:18px; overflow:hidden; margin-bottom:12px; box-shadow:var(--s1); border: 1px solid var(--sep2); }
.st-row {
  display:flex; align-items:center;
  padding:13px 14px 13px 12px;
  border-bottom:.5px solid var(--sep2);
  cursor:pointer; gap:12px; min-height:50px;
  transition: background .12s;
}
.st-row:last-child { border-bottom:none; }
.st-row:active { background:var(--fill3); }

/* Colored icon squares */
.sr-ico-wrap {
  width:34px; height:34px; border-radius:9px;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; font-size:17px; line-height:1;
}
.sr-ico-wrap.orange  { background:linear-gradient(145deg,#FF9040,#FF5500); }
.sr-ico-wrap.blue    { background:linear-gradient(145deg,#60A5FA,#2563EB); }
.sr-ico-wrap.green   { background:linear-gradient(145deg,#4ADE80,#16A34A); }
.sr-ico-wrap.red     { background:linear-gradient(145deg,#F87171,#DC2626); }
.sr-ico-wrap.slate   { background:linear-gradient(145deg,#94A3B8,#475569); }
.sr-ico-wrap.indigo  { background:linear-gradient(145deg,#818CF8,#4F46E5); }
.sr-ico-wrap.purple  { background:linear-gradient(145deg,#C084FC,#9333EA); }
.sr-ico-wrap.teal    { background:linear-gradient(145deg,#2DD4BF,#0D9488); }
.sr-ico { display:none !important; }

.sr-txt { flex:1; min-width:0; }
.sr-t   { font-size:16px; font-weight:600; color:var(--lbl); letter-spacing:-.1px; }
.sr-s   { font-size:13px; color:var(--lbl2); margin-top:1px; font-weight:400; }
.sr-v   { font-size:15px; color:var(--lbl2); margin-right:2px; font-weight:400; }
.sr-arr { color:var(--lbl3); font-size:18px; flex-shrink:0; }

/* ══════════════════════════════════════════════════
   FOOD DETAIL BOTTOM SHEET — Cal AI
   ══════════════════════════════════════════════════ */
#fdOv {
  position:fixed; inset:0;
  background:rgba(0,0,0,.45); z-index:200;
  display:none; align-items:flex-end;
  -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px);
}
#fdOv.on { display:flex; }
.fd-sheet {
  background:var(--card);
  border-radius:28px 28px 0 0;
  width:100%; max-height:90vh; overflow-y:auto;
  padding:0 0 calc(32px + env(safe-area-inset-bottom));
  animation:sheetUp .32s cubic-bezier(.32,.72,0,1);
}
.fd-img { width:100%; height:220px; object-fit:cover; border-radius:28px 28px 0 0; }
.fd-nophoto {
  width:100%; height:160px;
  display:flex; align-items:center; justify-content:center;
  font-size:76px; border-radius:28px 28px 0 0;
  background:var(--card2);
}
.fd-body { padding:22px 20px; }
.fd-hdr  { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:5px; }
.fd-name { font-size:24px; font-weight:800; letter-spacing:-.8px; color:var(--lbl); flex:1; margin-right:12px; }
.fd-close {
  width:34px; height:34px; border-radius:50%;
  background:var(--fill2); border:none; font-size:13px;
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  color:var(--lbl2); flex-shrink:0;
}
.fd-portion { font-size:14px; color:var(--lbl2); margin-bottom:18px; font-weight:500; }
.fd-kcal-row { display:flex; align-items:baseline; gap:7px; margin-bottom:22px; }
.fd-kcal { font-size:56px; font-weight:800; letter-spacing:-3px; color:var(--lbl); font-variant-numeric:tabular-nums; }
.fd-kcal-unit { font-size:17px; color:var(--lbl2); font-weight:500; }
.fd-macros { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:22px; }
.fd-mac { background:var(--card2); border-radius:16px; padding:16px 10px 14px; text-align:center; border:1px solid var(--sep2); }
.fd-mac-val { font-size:24px; font-weight:800; font-variant-numeric:tabular-nums; letter-spacing:-.8px; }
.fd-mac-lbl { font-size:11px; font-weight:700; margin-top:5px; color:var(--lbl2); text-transform:uppercase; letter-spacing:.5px; }
.fd-mac.p .fd-mac-val { color:#E05020; }
.fd-mac.c .fd-mac-val { color:#C07020; }
.fd-mac.f .fd-mac-val { color:#2060D0; }
[data-theme="dark"] .fd-mac.p .fd-mac-val { color:#FF7A52; }
[data-theme="dark"] .fd-mac.c .fd-mac-val { color:#FFA040; }
[data-theme="dark"] .fd-mac.f .fd-mac-val { color:#60A5FA; }
.fd-desc { font-size:15px; color:var(--lbl2); line-height:1.65; margin-bottom:18px; }
.fd-time { font-size:12px; color:var(--lbl3); padding:12px 0; border-top:1px solid var(--sep2); }
.fd-readd { width:100%; margin-top:18px; background:var(--fill2); color:var(--lbl); border:1px solid var(--sep); border-radius:14px; padding:16px; font-size:16px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; }
.fd-readd:active { filter:brightness(.92); }
.fd-del  { width:100%; margin-top:10px; background:var(--red-light); color:var(--ios-red); border:none; border-radius:14px; padding:16px; font-size:16px; font-weight:700; cursor:pointer; }
.fd-del:active { filter:brightness(.92); }
.ingr-hdr { font-size:11px; font-weight:700; color:var(--lbl2); letter-spacing:.7px; text-transform:uppercase; margin:14px 0 8px; }
.ingr-i { display:flex; justify-content:space-between; padding:10px 0; border-bottom:.5px solid var(--sep2); font-size:14px; }
.ingr-i:last-child { border-bottom:none; }
.ingr-n { font-weight:600; color:var(--lbl); }
.ingr-c { color:var(--lbl2); }

/* ══════════════════════════════════════════════════
   ADD FOOD MODAL — Cal AI
   ══════════════════════════════════════════════════ */
.ov {
  position:fixed; inset:0;
  background:rgba(0,0,0,.45); z-index:200;
  display:none; align-items:flex-end;
  -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px);
}
.ov.on { display:flex; animation:fadeIn .15s ease; }
.sheet {
  background:var(--card);
  border-radius:28px 28px 0 0;
  width:100%; max-height:93vh; overflow-y:auto;
  animation:sheetUp .36s cubic-bezier(.32,.72,0,1);
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
}
.sh-handle { width:40px; height:4px; background:var(--sep); border-radius:2px; margin:14px auto 0; }
.sh-hdr {
  padding:18px 20px 16px;
  display:flex; justify-content:space-between; align-items:center;
  border-bottom:1px solid var(--sep2);
}
.sh-hdr h3 { font-size:18px; font-weight:800; color:var(--lbl); letter-spacing:-.3px; }
.sh-close {
  background:var(--fill2); border:none; color:var(--lbl2);
  width:32px; height:32px; border-radius:50%; cursor:pointer;
  font-size:15px; display:flex; align-items:center; justify-content:center;
}

/* Segmented Control */
.tabs {
  display:flex;
  background:var(--fill2);
  border-radius:12px;
  padding:2px;
  margin:14px 16px 0;
}
.tab {
  flex:1; padding:9px 6px; border-radius:10px;
  font-size:13px; font-weight:600;
  cursor:pointer; border:none;
  background:transparent; color:var(--lbl2);
  transition: all .22s cubic-bezier(.2,.6,.4,1);
  white-space:nowrap;
}
.tab.on {
  background:var(--card); color:var(--lbl);
  box-shadow:var(--s1);
  font-weight:700;
}
[data-theme="dark"] .tab.on { background:#2A2A2A; }
.panel { display:none; padding:16px 16px 4px; }
.panel.on { display:block; }

/* Upload zone — Cal AI */
.upzone {
  border:2px dashed var(--sep);
  border-radius:20px; padding:36px 20px;
  text-align:center; cursor:pointer;
  transition:all .2s; background:var(--card2);
}
.upzone:active, .upzone.drag { border-color:var(--primary); background:var(--primary-light); }
.upzone input { position:absolute; inset:0; opacity:0; cursor:pointer; }
.upzone .ui  { font-size:44px; display:block; margin-bottom:12px; }
.upzone h4   { font-size:16px; font-weight:700; margin-bottom:5px; color:var(--lbl); }
.upzone p    { font-size:14px; color:var(--lbl2); }
.prev-wrap   { border-radius:18px; overflow:hidden; margin-bottom:12px; position:relative; }
.prev-wrap img { width:100%; max-height:200px; object-fit:cover; display:block; }
.prev-change {
  position:absolute; top:10px; right:10px;
  background:rgba(0,0,0,.60);
  -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px);
  border:none; color:#fff; border-radius:24px;
  padding:6px 14px; font-size:12px; cursor:pointer; font-weight:600;
}

/* Loader */
.ldr { display:none; text-align:center; padding:28px; }
.ldr.on { display:block; }
.sp {
  width:36px; height:36px;
  border:3px solid var(--fill2); border-top-color:var(--primary);
  border-radius:50%; animation:spin .65s linear infinite;
  margin:0 auto 14px;
}
.ldr p { font-size:14px; color:var(--lbl2); }

/* Result card */
.res { display:none; background:var(--card2); border-radius:20px; overflow:hidden; margin-bottom:14px; border:1px solid var(--sep2); }
.res.on { display:block; animation:obFadeUp .3s ease; }
.res-img { width:100%; height:150px; object-fit:cover; display:none; }
.res-img.on { display:block; }
.res-body { padding:18px; }
.res-name { font-size:20px; font-weight:800; letter-spacing:-.5px; margin-bottom:3px; color:var(--lbl); }
.res-portion { font-size:13px; color:var(--lbl2); margin-bottom:14px; font-weight:500; }
.res-kcal { font-size:52px; font-weight:800; letter-spacing:-3px; color:var(--lbl); line-height:1; font-variant-numeric:tabular-nums; }
.res-kcal small { font-size:16px; color:var(--lbl2); font-weight:500; letter-spacing:0; }
.res-macs { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin:16px 0; }
.rm { background:var(--card); border-radius:14px; padding:12px 8px; text-align:center; border:1px solid var(--sep2); }
.rm .rv { font-size:18px; font-weight:800; font-variant-numeric:tabular-nums; }
.rm .rk { font-size:10px; color:var(--lbl2); font-weight:600; margin-top:3px; text-transform:uppercase; letter-spacing:.5px; }
.rm.p .rv { color:#E05020; }
.rm.c .rv { color:#C07020; }
.rm.f .rv { color:#2060D0; }
[data-theme="dark"] .rm.p .rv { color:#FF7A52; }
[data-theme="dark"] .rm.c .rv { color:#FFA040; }
[data-theme="dark"] .rm.f .rv { color:#60A5FA; }
.res-desc { font-size:13px; color:var(--lbl2); line-height:1.65; border-top:1px solid var(--sep2); padding-top:12px; margin-top:4px; }

/* Error */
.err {
  display:none; background:var(--red-light);
  border:1px solid rgba(239,68,68,.2);
  border-radius:14px; padding:13px 16px;
  font-size:14px; color:var(--ios-red); margin-bottom:12px; line-height:1.5;
}
.err.on { display:block; animation:obFadeUp .2s ease; }

/* Quick examples */
.exs { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:14px; }
.ex {
  background:var(--card); border:1px solid var(--sep);
  border-radius:24px; padding:7px 14px;
  font-size:13px; color:var(--lbl2);
  cursor:pointer; font-weight:600; transition:all .15s;
  box-shadow: var(--s1);
}
.ex:active { background:var(--primary); color:#fff; border-color:var(--primary); }

/* Text area */
.txa {
  width:100%; background:var(--card);
  border:1.5px solid var(--sep);
  border-radius:16px; padding:14px 16px;
  color:var(--lbl); font-size:16px;
  resize:none; outline:none; min-height:110px;
  line-height:1.6; margin-bottom:14px;
  -webkit-appearance:none; transition:border-color .2s;
  box-shadow: var(--s1);
}
.txa:focus { border-color:var(--primary); }
.txa::placeholder { color:var(--lbl3); }

/* Barcode scanner */
.scan-box { background:var(--card2); border-radius:20px; padding:32px 20px; text-align:center; margin-bottom:14px; border:1px solid var(--sep2); }
.scan-frame { width:72px; height:72px; margin:0 auto 18px; border:3px solid var(--primary); border-radius:14px; position:relative; overflow:hidden; }
.scan-line { position:absolute; top:0; left:0; right:0; height:2px; background:var(--primary); animation:scan 1.8s linear infinite; box-shadow:0 0 10px rgba(10,10,10,.25); }
.scan-box h4 { font-size:16px; font-weight:700; margin-bottom:6px; color:var(--lbl); }
.scan-box p  { font-size:14px; color:var(--lbl2); }

/* Edit / API modals */
.ed-ov {
  position:fixed; inset:0;
  background:rgba(0,0,0,.45); z-index:300;
  display:none; align-items:flex-end;
  -webkit-backdrop-filter:blur(12px); backdrop-filter:blur(12px);
}
.ed-ov.on { display:flex; animation:fadeIn .15s ease; }
.ed-sheet {
  background:var(--card);
  border-radius:28px 28px 0 0; width:100%;
  padding:26px 20px calc(32px + env(safe-area-inset-bottom));
  animation:sheetUp .32s cubic-bezier(.32,.72,0,1);
}
.ed-sheet h3 { font-size:22px; font-weight:800; margin-bottom:20px; color:var(--lbl); letter-spacing:-.5px; }
.ed-sheet p  { font-size:15px; color:var(--lbl2); margin-bottom:18px; line-height:1.55; }


/* ══ GENDER PICKER ══ */
.gender-row { display:flex; gap:12px; margin-bottom:14px; }
.gender-card {
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:6px; padding:18px 12px;
  background:var(--card2); border:2px solid var(--sep);
  border-radius:20px; cursor:pointer;
  transition:all .2s cubic-bezier(.22,1,.36,1);
  -webkit-tap-highlight-color:transparent;
}
.gender-card .gc-icon { font-size:32px; }
.gender-card .gc-lbl { font-size:14px; font-weight:700; color:var(--lbl2); }
.gender-card.on {
  background:var(--primary); border-color:var(--primary);
  transform:scale(1.03);
  box-shadow: 0 6px 20px rgba(10,10,10,.22);
}
.gender-card.on .gc-lbl { color:#fff; }
[data-theme="dark"] .gender-card.on { background:#FAFAFA; border-color:#FAFAFA; }
[data-theme="dark"] .gender-card.on .gc-lbl { color:#0A0A0A; }

/* ══ DOB FIELD ══ */
.dob-label {
  font-size:11px; font-weight:700; color:var(--lbl3);
  text-transform:uppercase; letter-spacing:.5px;
  margin-bottom:5px; display:block;
}
.inp-dob {
  width:100%; background:var(--card2);
  border:1.5px solid var(--sep);
  border-radius:var(--r2); padding:14px 16px;
  color:var(--lbl); font-size:16px; font-weight:500;
  outline:none; -webkit-appearance:none;
  transition:border-color .2s;
  font-family:inherit; margin-bottom:8px;
}
.inp-dob:focus { border-color:var(--primary); }
.dob-age-hint {
  font-size:13px; color:var(--ios-green); font-weight:600;
  margin-bottom:14px; min-height:20px; transition:opacity .2s;
}

/* ══ WEIGHT LOG MODAL ══ */
.wlog-ov {
  position:fixed; inset:0;
  background:rgba(0,0,0,.5); z-index:400;
  display:none; align-items:flex-end;
  -webkit-backdrop-filter:blur(16px); backdrop-filter:blur(16px);
}
.wlog-ov.on { display:flex; animation:fadeIn .15s ease; }
.wlog-sheet {
  background:var(--card); border-radius:28px 28px 0 0; width:100%;
  padding:28px 20px calc(36px + env(safe-area-inset-bottom));
  animation:sheetUp .32s cubic-bezier(.32,.72,0,1);
}
.wlog-header {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:8px;
}
.wlog-title { font-size:22px; font-weight:800; letter-spacing:-.5px; color:var(--lbl); }
.wlog-close {
  width:34px; height:34px; border-radius:50%;
  background:var(--fill2); border:none;
  font-size:16px; color:var(--lbl2); cursor:pointer;
  display:flex; align-items:center; justify-content:center;
}
.wlog-sub { font-size:14px; color:var(--lbl2); margin-bottom:24px; }
.wlog-weight-row {
  display:flex; align-items:center; justify-content:center;
  gap:18px; margin:20px 0 28px;
}
.wlog-step-btn {
  width:52px; height:52px; border-radius:50%;
  background:var(--fill2); border:none;
  font-size:26px; font-weight:300; color:var(--lbl);
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  transition:transform .12s, background .12s;
}
.wlog-step-btn:active { transform:scale(.87); background:var(--fill1); }
.wlog-weight-val {
  font-size:52px; font-weight:800; letter-spacing:-2px;
  color:var(--lbl); font-variant-numeric:tabular-nums;
  min-width:120px; text-align:center;
  transition:transform .12s cubic-bezier(.36,.66,.04,1);
}
.wlog-weight-unit { font-size:20px; font-weight:600; color:var(--lbl2); margin-top:8px; align-self:flex-end; }
.wlog-trend {
  text-align:center; font-size:14px; font-weight:600;
  color:var(--lbl2); margin-bottom:20px; min-height:20px;
}
.wlog-trend.up { color:var(--ios-red); }
.wlog-trend.down { color:var(--ios-green); }
.wlog-trend.same { color:var(--lbl2); }

/* ══════════════════════════════════════════════════
   ANIMATIONS
   ══════════════════════════════════════════════════ */
@keyframes obFadeUp  { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
@keyframes sheetUp   { from { transform:translateY(100%); } to { transform:translateY(0); } }
@keyframes fadeIn    { from { opacity:0; } to { opacity:1; } }
@keyframes fadeUp    { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
@keyframes slideUp   { from { transform:translateY(100%); } to { transform:translateY(0); } }
@keyframes spin      { to { transform:rotate(360deg); } }
@keyframes scan      { 0%{top:0} 100%{top:100%} }

/* ── Global micro-animations ── */
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
@keyframes ripple {
  from { transform: scale(0); opacity: .35; }
  to   { transform: scale(2.5); opacity: 0; }
}
@keyframes bounceIn {
  0%   { transform: scale(.3); opacity: 0; }
  50%  { transform: scale(1.05); }
  70%  { transform: scale(.95); }
  100% { transform: scale(1); opacity: 1; }
}
@keyframes slideInRight {
  from { opacity:0; transform: translateX(16px); }
  to   { opacity:1; transform: translateX(0); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: .55; }
}
@keyframes waterFill {
  from { transform: scaleX(0); transform-origin: left; }
  to   { transform: scaleX(1); transform-origin: left; }
}
@keyframes dropPop {
  0%   { transform: scale(0); opacity: 0; }
  60%  { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}
@keyframes needleSlide {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── Screen transitions ── */
.screen { transition: opacity .18s ease; }
.screen.active { animation: screenIn .28s cubic-bezier(.22,1,.36,1) both; }
@keyframes screenIn {
  from { opacity:0; transform: translateY(6px); }
  to   { opacity:1; transform: translateY(0); }
}

/* ── Button press ripple feedback ── */
.nb, .water-btn, .goal-card, .act-card {
  position: relative; overflow: hidden;
}

/* ── Interactive element transitions ── */
.st-row, .logitem, .ai-sg, .goal-card, .act-card, .water-btn {
  transition: background .14s ease, transform .1s cubic-bezier(.22,1,.36,1), opacity .1s;
}
.st-row:active   { background: var(--fill3) !important; transform: scale(.99); }
.logitem:active  { opacity: .6; }

/* ── Skeleton shimmer ── */
.skeleton {
  background: linear-gradient(90deg,
    var(--fill2) 25%, var(--fill1) 50%, var(--fill2) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8px;
}

/* ── Toggle — enhanced spring ── */
.toggle::after {
  transition: transform .3s cubic-bezier(.36,.66,.04,1), box-shadow .2s;
}
.toggle:active::after { transform: scaleX(1.2); }
.toggle.on:active::after { transform: translateX(20px) scaleX(1.2); }

/* ── Nav button animations ── */
.nb svg { transition: transform .2s cubic-bezier(.22,1,.36,1), stroke-width .2s; }
.nb:active svg { transform: scale(.82); }
.nb-add { transition: transform .18s cubic-bezier(.22,1,.36,1), box-shadow .18s; }
.nb-add:active { transform: scale(.88) rotate(45deg); }

/* ── Card hover/press states ── */
.cal-card, .water-card, .bmi-card, .week-ai-card, .tip-compact {
  transition: box-shadow .2s ease, transform .15s cubic-bezier(.22,1,.36,1);
}

/* ── Macro bars animated ── */
.mac-fill { transition: width .8s cubic-bezier(.22,1,.36,1); }
.mac-bar  { border-radius: 4px; overflow: hidden; }

/* ── Ring animated ── */
#hring {
  transition: stroke-dashoffset 1s cubic-bezier(.22,1,.36,1),
              stroke .35s ease;
}

/* ── Water drops ── */
.water-drop {
  transition: background .3s cubic-bezier(.22,1,.36,1),
              transform .2s cubic-bezier(.22,1,.36,1);
}
.water-drop.full { animation: dropPop .35s cubic-bezier(.22,1,.36,1) both; }

/* ── Stat cards animated ── */
.sc { transition: transform .15s cubic-bezier(.22,1,.36,1); }
.sc:active { transform: scale(.97); }

/* ── Week AI btn ── */
.week-ai-btn {
  transition: transform .12s cubic-bezier(.22,1,.36,1), opacity .12s, background .2s;
}

/* ── Food detail sheet ── */
.fd-sheet { animation: sheetUp .32s cubic-bezier(.22,1,.36,1) both; }

/* ── Log items staggered ── */
.logitem:nth-child(1) { animation-delay: .02s; }
.logitem:nth-child(2) { animation-delay: .05s; }
.logitem:nth-child(3) { animation-delay: .08s; }
.logitem:nth-child(4) { animation-delay: .11s; }
.logitem:nth-child(5) { animation-delay: .14s; }
.logitem:nth-child(6) { animation-delay: .17s; }
.logitem:nth-child(7) { animation-delay: .20s; }

/* ── Card entrance stagger enhanced ── */
.card-enter-d1 { animation-delay: .04s; }
.card-enter-d2 { animation-delay: .09s; }
.card-enter-d3 { animation-delay: .14s; }
.card-enter-d4 { animation-delay: .20s; }
.card-enter-d5 { animation-delay: .26s; }
.card-enter-d6 { animation-delay: .32s; }
@keyframes cardEntrance {
  from { opacity:0; transform: translateY(18px) scale(.98); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}
.card-enter { animation: cardEntrance .5s cubic-bezier(.22,1,.36,1) both; }

/* ── BMI needle transition ── */
.bmi-needle { transition: left .9s cubic-bezier(.22,1,.36,1); }
.bmi-value  { transition: color .3s ease; }
.bmi-cat    { transition: background .3s, color .3s; animation: bounceIn .4s .2s cubic-bezier(.22,1,.36,1) both; }

/* ── Tip compact appear ── */
.tip-compact { animation: slideInRight .4s .15s cubic-bezier(.22,1,.36,1) both; }
.tip-compact-text { transition: color .3s ease; }

/* ── About modal ── */
.about-person { animation: fadeUp .35s cubic-bezier(.22,1,.36,1) both; }
.about-person:nth-child(1) { animation-delay: .1s; }
.about-person:nth-child(2) { animation-delay: .18s; }

/* ── Notif status pulse ── */
.notif-active { color: var(--green) !important; }
.notif-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--green); display: inline-block;
  margin-right: 4px; animation: pulse 2s infinite;
}

/* ══════════════════════════════════════════════════
   WILL-CHANGE (GPU layers for animations)
   ══════════════════════════════════════════════════ */
#hring, .bmi-needle, .water-bar-fill, .mac-fill { will-change: transform, opacity; }
.screen { will-change: opacity; }

/* ══════════════════════════════════════════════════
   MEAL CATEGORY CHIPS
   ══════════════════════════════════════════════════ */
.meal-chips {
  display: flex; gap: 6px; overflow-x: auto;
  padding: 0 16px 12px; scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}
.meal-chips::-webkit-scrollbar { display: none; }
.meal-chip {
  display: flex; align-items: center; gap: 5px;
  padding: 6px 12px; border-radius: 20px;
  background: var(--fill2); border: 1.5px solid transparent;
  font-size: 12px; font-weight: 600; color: var(--text2);
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
  transition: all .15s cubic-bezier(.22,1,.36,1);
  -webkit-tap-highlight-color: transparent;
}
.meal-chip.on {
  background: var(--orange-light);
  border-color: var(--orange);
  color: var(--orange);
}
.meal-chip:active { transform: scale(.93); }

/* ══════════════════════════════════════════════════
   RECENT FOODS
   ══════════════════════════════════════════════════ */
.recents-lbl {
  font-size: 11px; font-weight: 700; letter-spacing: .5px;
  text-transform: uppercase; color: var(--text3);
  padding: 0 16px; margin-bottom: 8px;
}
.recents-chips {
  display: flex; gap: 8px; overflow-x: auto;
  padding: 0 16px 4px; scrollbar-width: none;
}
.recents-chips::-webkit-scrollbar { display: none; }
.recent-chip {
  display: flex; flex-direction: column; gap: 2px;
  background: var(--card); border: 1px solid var(--sep2);
  border-radius: 12px; padding: 8px 11px;
  cursor: pointer; flex-shrink: 0; min-width: 72px;
  transition: transform .12s cubic-bezier(.22,1,.36,1), box-shadow .15s;
  box-shadow: var(--s1);
}
.recent-chip:active { transform: scale(.93); }
.rc-name {
  font-size: 11px; font-weight: 600; color: var(--text);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 80px;
}
.rc-kcal { font-size: 10px; color: var(--orange); font-weight: 700; }
#recentsList { margin-bottom: 4px; }

/* ══════════════════════════════════════════════════
   FOOD DETAIL — FAV BUTTON
   ══════════════════════════════════════════════════ */
.fd-fav-btn {
  position: absolute; top: 14px; right: 14px;
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--fill2); border: none;
  font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: transform .15s, background .15s;
}
.fd-fav-btn:active { transform: scale(.85); }
.fd-fav-btn.faved { color: #f59e0b; }

/* ══════════════════════════════════════════════════
   EXPORT BUTTON (Settings)
   ══════════════════════════════════════════════════ */
.export-btn {
  display: flex; align-items: center; gap: 10px;
  width: 100%; background: none; border: none;
  padding: 14px 16px; cursor: pointer;
  color: var(--blue); font-size: 15px; font-weight: 600;
  border-radius: 12px; transition: background .15s;
  -webkit-tap-highlight-color: transparent;
}
.export-btn:active { background: var(--blue-light); }
.export-btn svg { width: 20px; height: 20px; stroke: var(--blue); flex-shrink: 0; }

/* ══════════════════════════════════════════════════
   COMPACT TIP (home screen)
   ══════════════════════════════════════════════════ */
.tip-compact {
  margin: 4px 16px 12px;
  background: var(--card);
  border-radius: 16px;
  padding: 12px 14px;
  display: flex; align-items: center; gap: 10px;
  box-shadow: var(--s1);
  border: 1px solid var(--sep2);
  min-height: 46px;
  animation: cardEntrance .4s cubic-bezier(.22,1,.36,1) both;
  animation-delay: .2s;
}
.tip-compact-icon { font-size: 18px; flex-shrink: 0; }
.tip-compact-text {
  flex: 1; font-size: 13px; line-height: 1.5;
  color: var(--text2); font-weight: 500;
  overflow: hidden; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.tip-compact-text.loaded { color: var(--text); }
.tip-compact-btn {
  width: 30px; height: 30px; border-radius: 50%;
  background: var(--fill2); border: none;
  color: var(--text2); font-size: 15px; cursor: pointer;
  flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  transition: transform .3s, background .15s;
}
.tip-compact-btn:active { background: var(--fill1); }
.tip-compact-btn.spin { animation: spin .6s ease; }

/* ══════════════════════════════════════════════════
   BMI CARD
   ══════════════════════════════════════════════════ */
.bmi-card {
  margin: 0 16px 12px;
  background: var(--card);
  border-radius: 20px;
  padding: 18px 18px 16px;
  box-shadow: var(--s1);
  display: flex; align-items: center; gap: 18px;
  border: 1px solid var(--sep2);
  position: relative; overflow: visible;
}
.bmi-card::before {
  content: ''; position: absolute; top: 0; right: 0; bottom: 0;
  width: 60%; border-radius: 20px;
  background: radial-gradient(ellipse at 100% 50%, rgba(255,107,0,.04) 0%, transparent 70%);
  pointer-events: none;
}
.bmi-left { flex-shrink: 0; }
.bmi-label { font-size: 11px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
.bmi-value { font-size: 36px; font-weight: 800; letter-spacing: -1.5px; color: var(--text); font-variant-numeric: tabular-nums; line-height: 1; }
.bmi-cat {
  font-size: 12px; font-weight: 700; margin-top: 5px;
  padding: 3px 8px; border-radius: 8px; display: inline-block;
}
.bmi-cat.under { background: rgba(59,130,246,.1); color: #3b82f6; }
.bmi-cat.norm  { background: rgba(34,197,94,.1);  color: #16a34a; }
.bmi-cat.over  { background: rgba(245,158,11,.1); color: #d97706; }
.bmi-cat.obese { background: rgba(239,68,68,.1);  color: #dc2626; }
.bmi-cat.none  { background: var(--fill2); color: var(--text3); }
.bmi-right { flex: 1; min-width: 0; }
.bmi-track {
  height: 8px; border-radius: 8px; position: relative; overflow: visible;
  background: linear-gradient(90deg,
    #3b82f6 0%,
    #22c55e 30%,
    #22c55e 55%,
    #f59e0b 70%,
    #ef4444 100%
  );
  margin-bottom: 8px;
}
.bmi-needle {
  position: absolute; top: -5px;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--card); border: 3px solid var(--text);
  transform: translateX(-50%);
  box-shadow: 0 2px 8px rgba(0,0,0,.2);
  transition: left .8s cubic-bezier(.22,1,.36,1);
}
.bmi-range-labels {
  display: flex; justify-content: space-between;
  font-size: 9px; color: var(--text3); font-weight: 600;
}

/* ══════════════════════════════════════════════════
   WATER WIDGET (progress screen)
   ══════════════════════════════════════════════════ */
.water-card {
  margin: 0 16px 12px;
  background: var(--card);
  border-radius: 20px;
  padding: 16px 16px 14px;
  box-shadow: var(--s1);
  border: 1px solid var(--sep2);
}
.water-top {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 10px;
}
.water-title {
  font-size: 14px; font-weight: 700; color: var(--text);
  display: flex; align-items: center; gap: 6px;
}
.water-goal-txt { font-size: 12px; color: var(--text2); font-weight: 500; }
.water-bar-wrap { height: 6px; background: var(--fill2); border-radius: 6px; overflow: hidden; margin-bottom: 12px; }
.water-bar-fill {
  height: 100%; border-radius: 6px;
  background: linear-gradient(90deg, #60a5fa, #3b82f6);
  transition: width .7s cubic-bezier(.22,1,.36,1);
}
.water-drinks { display: flex; gap: 7px; overflow-x: auto; padding-bottom: 4px; }
.water-drinks::-webkit-scrollbar { display: none; }
.water-btn {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  background: var(--fill3); border: 1.5px solid var(--sep2);
  border-radius: 14px; padding: 9px 10px;
  cursor: pointer; min-width: 54px; flex-shrink: 0;
  transition: transform .12s cubic-bezier(.22,1,.36,1), background .15s, border-color .15s;
  -webkit-tap-highlight-color: transparent;
  position: relative;
}
.water-btn:active { transform: scale(.88); }
.water-btn.hit {
  background: rgba(59,130,246,.1);
  border-color: rgba(59,130,246,.3);
}
.water-btn-icon { font-size: 20px; }
.water-btn-name { font-size: 10px; font-weight: 600; color: var(--text2); white-space: nowrap; }
.water-btn-ml { font-size: 10px; color: #3b82f6; font-weight: 700; }
.water-btn .water-count {
  position: absolute; top: -4px; right: -4px;
  width: 16px; height: 16px; border-radius: 50%;
  background: #3b82f6; color: #fff;
  font-size: 9px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  border: 1.5px solid var(--card);
}
.water-salt-hint {
  margin-top: 8px; padding: 6px 10px;
  background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.2);
  border-radius: 10px; font-size: 11px; font-weight: 600; color: var(--amber);
  display: none;
}
.water-salt-hint.on { display: block; }
.water-footer {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 10px;
}
.water-drops { display: flex; gap: 3px; }
.water-drop {
  width: 7px; height: 10px; border-radius: 50% 50% 40% 40%;
  background: var(--fill2); transition: background .25s ease;
}
.water-drop.full { background: #3b82f6; }
.water-undo-btn {
  display: flex; align-items: center; gap: 4px;
  background: none; border: none; cursor: pointer;
  font-size: 11px; font-weight: 600; color: var(--text3);
  padding: 4px 8px; border-radius: 8px;
  transition: color .15s, background .15s;
}
.water-undo-btn:active { background: var(--fill2); color: var(--text2); }


/* ══════════════════════════════════════════════════
   WEEKLY ANALYSIS
   ══════════════════════════════════════════════════ */
.week-ai-card {
  margin:0 16px 14px;
  background:var(--card);
  border-radius:20px;
  overflow:hidden;
  box-shadow:var(--s1);
}
.week-ai-header {
  padding:16px 18px 12px;
  display:flex;align-items:center;gap:10px;
  border-bottom:1px solid var(--border);
}
.week-ai-icon {
  width:38px;height:38px;
  background:linear-gradient(135deg,var(--orange),#ff9a3c);
  border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
  box-shadow:0 3px 10px rgba(255,107,0,.3);
}
.week-ai-title { font-size:15px;font-weight:800;color:var(--text); }
.week-ai-sub { font-size:11px;color:var(--text2);margin-top:1px;font-weight:500; }
.week-ai-btn {
  margin-left:auto;
  background:var(--primary);color:var(--bg);
  border:none;border-radius:10px;
  padding:7px 13px;font-size:12px;font-weight:700;
  cursor:pointer;white-space:nowrap;
  transition:transform .12s,opacity .12s;
}
.week-ai-btn:active{transform:scale(.94);opacity:.8;}
.week-ai-btn:disabled{opacity:.45;cursor:default;}
.week-ai-body { padding:14px 18px 16px; }
.week-ai-empty {
  text-align:center;padding:20px 0;
  font-size:13px;color:var(--text3);font-weight:500;line-height:1.6;
}
.week-ai-text {
  font-size:13px;line-height:1.7;color:var(--text);
  font-weight:400;
}
.week-ai-text b { color:var(--orange);font-weight:700; }
.week-ai-sections { display:flex;flex-direction:column;gap:10px; }
.week-ai-section {
  background:var(--fill3);border-radius:12px;padding:11px 13px;
  border-left:3px solid transparent;
}
.week-ai-section.good { border-left-color:var(--green); }
.week-ai-section.warn { border-left-color:var(--amber); }
.week-ai-section.tip  { border-left-color:var(--blue); }
.week-ai-section-title { font-size:11px;font-weight:800;letter-spacing:.4px;text-transform:uppercase;margin-bottom:4px;color:var(--text2); }
.week-ai-section.good .week-ai-section-title { color:var(--green); }
.week-ai-section.warn .week-ai-section-title { color:var(--amber); }
.week-ai-section.tip  .week-ai-section-title { color:var(--blue); }
.week-ai-section-text { font-size:13px;color:var(--text);line-height:1.55;font-weight:500; }

/* ══════════════════════════════════════════════════
   AUTHORS MODAL
   ══════════════════════════════════════════════════ */
.about-ov {
  position:fixed;inset:0;z-index:600;
  background:rgba(0,0,0,.55);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  display:flex;align-items:flex-end;
  opacity:0;pointer-events:none;
  transition:opacity .3s;
}
.about-ov.on{opacity:1;pointer-events:all;}
.about-sheet {
  width:100%;
  background:var(--card);
  border-radius:28px 28px 0 0;
  padding:0 0 calc(env(safe-area-inset-bottom,0px)+28px);
  transform:translateY(100%);
  transition:transform .42s cubic-bezier(.22,1,.36,1);
}
.about-ov.on .about-sheet{transform:translateY(0);}
.about-handle { width:36px;height:4px;background:var(--fill1);border-radius:2px;margin:12px auto 0; }
.about-top {
  padding:28px 24px 24px;text-align:center;
  border-bottom:1px solid var(--border);
  position:relative;overflow:hidden;
}
.about-top::before {
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%,rgba(255,107,0,.07) 0%,transparent 65%);
  pointer-events:none;
}
.about-logo { font-size:54px;margin-bottom:10px;display:block;filter:drop-shadow(0 6px 16px rgba(255,107,0,.3)); }
.about-app-name { font-size:26px;font-weight:900;letter-spacing:-1px;color:var(--text); }
.about-app-name b{color:var(--orange);}
.about-tagline { font-size:13px;color:var(--text2);margin-top:4px;font-weight:400; }
.about-version { font-size:11px;color:var(--text3);margin-top:6px;font-weight:600;letter-spacing:.5px; }
.about-team { padding:20px 20px 0; }
.about-team-lbl { font-size:11px;font-weight:800;letter-spacing:.8px;color:var(--text3);text-transform:uppercase;margin-bottom:12px;padding:0 4px; }
.about-person {
  display:flex;align-items:center;gap:14px;
  padding:14px 16px;
  background:var(--fill3);border:1px solid var(--border);
  border-radius:16px;margin-bottom:10px;
  position:relative;overflow:hidden;
}
.about-person::before {
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,107,0,.04) 0%,transparent 60%);
}
.about-avatar {
  width:48px;height:48px;border-radius:16px;
  background:linear-gradient(135deg,var(--orange),#ff9a3c);
  display:flex;align-items:center;justify-content:center;
  font-size:20px;font-weight:900;color:#fff;
  flex-shrink:0;
  box-shadow:0 4px 12px rgba(255,107,0,.3);
  letter-spacing:-1px;
}
.about-avatar.sec {
  background:linear-gradient(135deg,#6366f1,#8b5cf6);
  box-shadow:0 4px 12px rgba(99,102,241,.3);
}
.about-pinfo { flex:1; }
.about-pname { font-size:15px;font-weight:800;color:var(--text); }
.about-prole { font-size:12px;color:var(--text2);margin-top:2px;font-weight:500; }
.about-ptag {
  font-size:10px;font-weight:700;letter-spacing:.3px;
  padding:3px 8px;border-radius:6px;
  margin-left:auto;white-space:nowrap;flex-shrink:0;
}
.about-ptag.lead { background:var(--orange-light);color:var(--orange); }
.about-ptag.ideas { background:rgba(99,102,241,.12);color:#6366f1; }
.about-footer { padding:20px 20px 0;text-align:center; }
.about-footer-txt { font-size:12px;color:var(--text3);line-height:1.6; }


/* ── OFFLINE MODAL ── */
.offl-ov {
  position:fixed;inset:0;z-index:10000;
  background:rgba(0,0,0,.72);
  backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  display:flex;align-items:center;justify-content:center;
  padding:20px;
  opacity:0;pointer-events:none;
  transition:opacity .4s ease;
}
.offl-ov.on { opacity:1;pointer-events:all; }
.offl-card {
  width:100%;max-width:360px;
  background:var(--card);
  border-radius:28px;
  overflow:hidden;
  transform:scale(.88) translateY(24px);
  transition:transform .45s cubic-bezier(.22,1,.36,1);
  box-shadow:0 24px 80px rgba(0,0,0,.45);
}
.offl-ov.on .offl-card { transform:scale(1) translateY(0); }

.offl-top {
  background:#0a0a14;
  padding:36px 24px 28px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.offl-top::before {
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%, rgba(99,102,241,.25) 0%, transparent 70%);
  pointer-events:none;
}
.offl-rings {
  position:relative;width:88px;height:88px;margin:0 auto 20px;
}
.offl-ring {
  position:absolute;inset:0;border-radius:50%;
  border:1.5px solid rgba(255,255,255,.08);
  animation:offlRing 3s ease-in-out infinite;
}
.offl-ring:nth-child(2){inset:-12px;border-color:rgba(255,255,255,.05);animation-delay:.5s;}
.offl-ring:nth-child(3){inset:-24px;border-color:rgba(255,255,255,.03);animation-delay:1s;}
@keyframes offlRing {
  0%,100%{opacity:1;transform:scale(1);}
  50%{opacity:.4;transform:scale(1.04);}
}
.offl-icon-inner {
  position:absolute;inset:0;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.1);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:36px;
}
.offl-dot {
  position:absolute;top:2px;right:2px;
  width:20px;height:20px;
  background:#EF4444;border-radius:50%;
  border:2px solid #0a0a14;
  display:flex;align-items:center;justify-content:center;
  font-size:9px;color:#fff;font-weight:900;
  animation:offlDot 1.8s ease-in-out infinite;
}
@keyframes offlDot{
  0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.5);}
  50%{box-shadow:0 0 0 6px rgba(239,68,68,0);}
}
.offl-title {
  font-size:22px;font-weight:800;color:#fff;
  letter-spacing:-.4px;margin-bottom:6px;
}
.offl-sub {
  font-size:13px;color:rgba(255,255,255,.45);
  line-height:1.65;margin-bottom:18px;
}
.offl-divider {
  width:100%;height:1px;
  background:rgba(255,255,255,.07);margin:0 0 16px;
}
.offl-features {
  display:grid;grid-template-columns:1fr 1fr;gap:7px;
}
.offl-feat {
  border-radius:12px;padding:8px 10px;
  font-size:12px;font-weight:600;
  display:flex;align-items:center;gap:6px;
  text-align:left;
}
.offl-feat.ok{background:rgba(74,222,128,.1);color:#4ade80;border:1px solid rgba(74,222,128,.2);}
.offl-feat.no{background:rgba(248,113,113,.07);color:rgba(248,113,113,.7);border:1px solid rgba(248,113,113,.15);}

.offl-body { padding:18px 18px 20px; }
.offl-btn-main {
  width:100%;
  background:var(--primary);color:var(--bg);
  border:none;border-radius:16px;padding:16px;
  font-size:15px;font-weight:800;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  margin-bottom:9px;
  transition:transform .12s,opacity .12s;
  letter-spacing:-.2px;
}
.offl-btn-main:active{transform:scale(.97);opacity:.85;}
.offl-btn-sec {
  width:100%;
  background:var(--fill2);color:var(--lbl);
  border:1px solid var(--border);border-radius:16px;padding:14px;
  font-size:14px;font-weight:600;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:7px;
  transition:transform .12s,opacity .12s;
}
.offl-btn-sec:active{transform:scale(.97);opacity:.7;}
.offl-btn-sec:disabled{opacity:.45;cursor:default;}

/* shake animation */
@keyframes offlShake {
  0%,100%{transform:translateX(0);}
  20%{transform:translateX(-9px);}
  40%{transform:translateX(9px);}
  60%{transform:translateX(-6px);}
  80%{transform:translateX(6px);}
}
.offl-shake { animation:offlShake .4s ease; }

/* Полоска офлайн статуса сверху */
.offl-bar {
  position:fixed;top:0;left:0;right:0;z-index:5000;
  background:rgba(239,68,68,.95);
  backdrop-filter:blur(8px);
  color:#fff;font-size:12px;font-weight:700;
  text-align:center;letter-spacing:.2px;
  padding:calc(env(safe-area-inset-top,0px) + 5px) 16px 6px;
  transform:translateY(-100%);transition:transform .3s ease;
}
.offl-bar.on{transform:translateY(0);}
</style>
</head>
<body>

<!-- OFFLINE MODAL -->
<div class="offl-ov" id="offlOv">
  <div class="offl-card">
    <div class="offl-top">
      <div class="offl-rings">
        <div class="offl-ring"></div>
        <div class="offl-ring"></div>
        <div class="offl-ring"></div>
        <div class="offl-icon-inner">
          <span>📶</span>
          <div class="offl-dot">✕</div>
        </div>
      </div>
      <div class="offl-title">Нет интернета</div>
      <div class="offl-sub">AI-функции требуют подключения.<br>Статистика и дневник доступны офлайн.</div>
      <div class="offl-divider"></div>
      <div class="offl-features">
        <div class="offl-feat ok">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          Дневник питания
        </div>
        <div class="offl-feat ok">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          Прогресс и вес
        </div>
        <div class="offl-feat ok">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          Настройки
        </div>
        <div class="offl-feat no">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          Анализ фото / AI
        </div>
      </div>
    </div>
    <div class="offl-body">
      <button class="offl-btn-main" onclick="enterOffline()">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Войти офлайн
      </button>
      <button class="offl-btn-sec" id="offlRetryBtn" onclick="retryConnection()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
        Проверить соединение
      </button>
    </div>
  </div>
</div>

<!-- OFFLINE STATUS BAR -->
<div class="offl-bar" id="offlBar">📶 Офлайн — AI недоступен</div>

<!-- SPLASH SCREEN -->
<div class="splash-ov" id="splashOv">
  <span class="splash-icon">🍎</span>
  <div class="splash-title">Cal<b>Snap</b></div>
  <div class="splash-sub">AI-трекер калорий</div>
</div>

<!-- ONBOARDING -->
<div class="screen active" id="ob">
<div class="ob-inner">
  <div class="ob-logo"><span class="icon">🍎</span><h1>Cal<b>Snap</b></h1><p>AI-трекер калорий</p></div>
  <div class="ob-step on" id="os1">
    <div class="ob-prog"><div class="op done"></div><div class="op"></div><div class="op"></div><div class="op"></div></div>
    <div class="ob-h">Как тебя зовут?</div>
    <div class="ob-s">Настроим приложение лично под тебя</div>
    <input class="inp" id="obn" type="text" placeholder="Твоё имя" autocomplete="off">
    <button class="btn" onclick="on1()">Продолжить →</button>
  </div>
  <div class="ob-step" id="os2">
    <div class="ob-prog"><div class="op done"></div><div class="op done"></div><div class="op"></div><div class="op"></div></div>
    <div class="ob-h">Твои параметры</div>
    <div class="ob-s">Для точного расчёта нормы калорий</div>

    <!-- Gender picker -->
    <div class="gender-row">
      <div class="gender-card on" id="gen_m" onclick="pickGender('m')">
        <span class="gc-icon">♂️</span>
        <span class="gc-lbl">Мужчина</span>
      </div>
      <div class="gender-card" id="gen_f" onclick="pickGender('f')">
        <span class="gc-icon">♀️</span>
        <span class="gc-lbl">Женщина</span>
      </div>
    </div>

    <!-- Date of birth -->
    <label class="dob-label">Дата рождения</label>
    <button class="dob-picker-btn" id="ob_dob_btn" onclick="openDrum('ob')">
      <span class="dob-placeholder" id="ob_dob_disp">Выбери дату рождения</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </button>
    <div class="dob-age-hint" id="dob_hint"></div>

    <!-- Height / Weight -->
    <div class="inp-row">
      <input class="inp" style="margin:0" id="obh" type="number" placeholder="Рост (см)" inputmode="decimal">
      <input class="inp" style="margin:0" id="obw" type="number" placeholder="Вес (кг)" inputmode="decimal">
    </div>
    <div style="height:14px"></div>
    <button class="btn" onclick="on2()">Продолжить →</button>
    <button class="btn2" onclick="os(1)">← Назад</button>
  </div>
  <div class="ob-step" id="os3">
    <div class="ob-prog"><div class="op done"></div><div class="op done"></div><div class="op done"></div><div class="op"></div></div>
    <div class="ob-h">Активность</div>
    <div class="ob-s">Сколько ты двигаешься?</div>
    <div class="act-grid">
      <div class="act-card on" data-a="1.2" onclick="sa(this)"><div class="an">🛋️ Минимум</div><div class="as">Сидячая работа</div></div>
      <div class="act-card" data-a="1.375" onclick="sa(this)"><div class="an">🚶 Лёгкая</div><div class="as">1-3 дня/нед</div></div>
      <div class="act-card" data-a="1.55" onclick="sa(this)"><div class="an">🏃 Средняя</div><div class="as">3-5 дней/нед</div></div>
      <div class="act-card" data-a="1.725" onclick="sa(this)"><div class="an">💪 Высокая</div><div class="as">6-7 дней/нед</div></div>
    </div>
    <button class="btn" onclick="on3()">Продолжить →</button>
    <button class="btn2" onclick="os(2)">← Назад</button>
  </div>
  <div class="ob-step" id="os4">
    <div class="ob-prog"><div class="op done"></div><div class="op done"></div><div class="op done"></div><div class="op done"></div></div>
    <div class="ob-h">Твоя цель</div>
    <div class="ob-s">AI настроит калории под неё</div>
    <div class="goal-grid">
      <div class="goal-card" data-g="lose" onclick="sg(this)"><span class="gi">📉</span><div class="gn">Похудеть</div></div>
      <div class="goal-card on" data-g="maintain" onclick="sg(this)"><span class="gi">⚖️</span><div class="gn">Держать вес</div></div>
      <div class="goal-card" data-g="gain" onclick="sg(this)"><span class="gi">💪</span><div class="gn">Набрать массу</div></div>
    </div>
    <button class="btn" onclick="onFin()">Начать! 🚀</button>
    <button class="btn2" onclick="os(3)">← Назад</button>
  </div>
</div>
</div>

<!-- HOME -->
<div class="screen" id="home">
  <div class="h-top">
    <div>
      <div style="font-size:13px;color:var(--text2);font-weight:500;margin-bottom:2px" id="greet">Доброе утро</div>
      <div class="h-name" id="hname">Привет!</div>
    </div>
    <div class="streak" onclick="goS('prog',document.querySelectorAll('.nb')[1])">
      <span class="sf">🔥</span><span class="sn" id="snum">0</span><span class="sl">дней</span>
    </div>
  </div>

  <div class="api-bar" id="abar" onclick="openApi()" style="display:none">
    <span class="ab-ico">🔑</span>
    <div><div class="ab-t">Нужен API ключ Gemini</div><div class="ab-s">Нажми → получи бесплатно за 1 мин</div></div>
    <span style="color:var(--orange);font-size:20px">›</span>
  </div>

  <div class="cal-wrap"><div class="cal-inner" id="cals"></div></div>

  <div class="cal-card card-enter card-enter-d1">
    <div class="cc-top">
      <div class="cc-right" style="position:relative;float:right;flex-shrink:0">
        <svg class="cc-ring" width="80" height="80" viewBox="0 0 80 80" style="transform:rotate(-90deg)">
          <circle cx="40" cy="40" r="33" fill="none" stroke="var(--border2)" stroke-width="7" class="ring-bg"/>
          <circle id="hring" cx="40" cy="40" r="33" fill="none" stroke="var(--primary)" stroke-width="7" stroke-linecap="round" stroke-dasharray="207" stroke-dashoffset="207"/>
        </svg>
        <div class="cc-ring-label">
          <span class="cc-pct" id="hpct">0%</span>
          <span class="cc-pct-s">СЪЕДЕНО</span>
        </div>
      </div>
      <div class="cc-nums">
        <span class="cc-eaten" id="hkcal">0</span>
        <span class="cc-slash">/</span>
        <span class="cc-goal" id="hgoal">2000</span>
      </div>
      <div class="cc-label">Калорий съедено</div>
      <div class="cc-remain" id="hrem">Осталось 2000 ккал</div>
    </div>
    <div style="height:16px"></div>
    <div class="macro-row">
      <div class="mac mac-p">
        <div class="mac-top"><span class="mac-val" id="hprot">0г</span><span class="mac-goal" id="hpg">—г</span></div>
        <div class="mac-bar"><div class="mac-fill" id="hpbar" style="width:0%;background:var(--green)"></div></div>
        <div class="mac-name">Белки</div>
      </div>
      <div class="mac mac-c">
        <div class="mac-top"><span class="mac-val" id="hcarb">0г</span><span class="mac-goal" id="hcg">—г</span></div>
        <div class="mac-bar"><div class="mac-fill" id="hcbar" style="width:0%;background:var(--amber)"></div></div>
        <div class="mac-name">Углеводы</div>
      </div>
      <div class="mac mac-f">
        <div class="mac-top"><span class="mac-val" id="hfat">0г</span><span class="mac-goal" id="hfg">—г</span></div>
        <div class="mac-bar"><div class="mac-fill" id="hfbar" style="width:0%;background:var(--blue)"></div></div>
        <div class="mac-name">Жиры</div>
      </div>
    </div>
  </div>

  <div class="sec-hdr"><h3 id="dayLabel">Сегодня</h3></div>
  <div id="hlog"></div>

  <!-- DAILY TIP — compact -->
  <div class="tip-compact" id="tipCard">
    <div class="tip-compact-icon">💡</div>
    <div class="tip-compact-text" id="tipText">Нажми для совета от AI</div>
    <button class="tip-compact-btn" id="tipRefreshBtn" onclick="loadDailyTip(true)">↻</button>
  </div>
  <div style="height:8px"></div>
</div>

<!-- PROGRESS -->
<div class="screen" id="prog">
  <div class="pg-hdr"><h2>Прогресс</h2></div>
  <div class="streak-big-card card-enter card-enter-d1">
    <div class="sbc-left">
      <span class="sbc-fire">🔥</span>
      <div class="sbc-days" id="pstr">0</div>
      <div class="sbc-lbl">дней стрик</div>
    </div>
    <div class="sbc-right">
      <p>Эта неделя</p>
      <div class="wk-dots" id="wkd"></div>
    </div>
  </div>

  <!-- BMI CARD -->
  <div class="bmi-card card-enter card-enter-d2" id="bmiCard">
    <div class="bmi-left">
      <div class="bmi-label">Индекс массы тела</div>
      <div class="bmi-value" id="bmiVal">—</div>
      <div class="bmi-cat" id="bmiCat">Нет данных</div>
    </div>
    <div class="bmi-right">
      <div class="bmi-scale" id="bmiScale">
        <div class="bmi-track">
          <div class="bmi-fill" id="bmiFill"></div>
          <div class="bmi-needle" id="bmiNeedle" style="left:0%"></div>
        </div>
        <div class="bmi-range-labels">
          <span>16</span><span>18.5</span><span>25</span><span>30</span><span>40</span>
        </div>
      </div>
    </div>
  </div>

  <div class="stat-grid">
    <div class="sc"><div class="sc-lbl">Ср. калории</div><div class="sc-val" id="pavg">—</div><div class="sc-sub">за 7 дней</div></div>
    <div class="sc"><div class="sc-lbl">Лучший день</div><div class="sc-val" id="pbest">—</div><div class="sc-sub">ближе всего к цели</div></div>
    <div class="sc"><div class="sc-lbl">Записей</div><div class="sc-val" id="ptot">0</div><div class="sc-sub">всего приёмов</div></div>
    <div class="sc"><div class="sc-lbl">Дней с данными</div><div class="sc-val" id="pdays">0</div><div class="sc-sub">из 30</div></div>
  </div>

  <!-- WATER BALANCE — moved here from home -->
  <div class="water-card card-enter card-enter-d3" id="waterCard">
    <div class="water-top">
      <div class="water-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
        Водный баланс
      </div>
      <div class="water-goal-txt"><span id="waterConsumedMl">0</span> / <span id="waterGoalMl">2000</span> мл</div>
    </div>
    <div class="water-bar-wrap"><div class="water-bar-fill" id="waterBar" style="width:0%"></div></div>
    <div class="water-drinks" id="waterDrinks"></div>
    <div class="water-salt-hint" id="waterSaltHint"></div>
    <div class="water-footer">
      <div class="water-drops" id="waterDrops"></div>
      <button class="water-undo-btn" id="waterUndoBtn" onclick="undoLastWater()" style="display:none">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
        Отменить
      </button>
    </div>
  </div>

  <div class="heat-card card-enter card-enter-d4">
    <h4>Активность за 28 дней</h4>
    <div class="hgrid" id="hgrid"></div>
    <div class="h-legend">
      <div class="h-sq" style="background:var(--bg);border:1px solid var(--border2)"></div><span>Нет</span>
      <div class="h-sq" style="background:#FFE8DC"></div><span>Мало</span>
      <div class="h-sq" style="background:#FF9B6A"></div><span>Норма</span>
      <div class="h-sq" style="background:var(--orange)"></div><span>Цель</span>
      <div class="h-sq" style="background:#EF4444"></div><span>Перебор</span>
    </div>
  </div>
  <div class="wt-card card-enter card-enter-d5">
    <div class="wt-top"><h4>Динамика веса</h4><button class="wt-btn" onclick="logW()">+ Записать</button></div>
    <canvas id="wc" height="110"></canvas>
    <p id="wempty" style="text-align:center;font-size:13px;color:var(--text3);padding:16px 0;font-weight:500">Нет данных — записывай вес каждый день</p>
  </div>

  <!-- WEEKLY AI ANALYSIS -->
  <div class="week-ai-card card-enter card-enter-d5" id="weekAiCard">
    <div class="week-ai-header">
      <div class="week-ai-icon">🤖</div>
      <div>
        <div class="week-ai-title">Анализ недели</div>
        <div class="week-ai-sub" id="weekAiSub">AI анализирует питание за 7 дней</div>
      </div>
      <button class="week-ai-btn" id="weekAiBtn" onclick="loadWeekAnalysis(true)">Анализ</button>
    </div>
    <div class="week-ai-body" id="weekAiBody">
      <div class="week-ai-empty">Нажми «Анализ» — AI посмотрит твоё питание за 7 дней и даст обратную связь</div>
    </div>
  </div>
  <div style="height:20px"></div>
</div>


<!-- FOOD DETAIL -->
<div id="fdOv" onclick="if(event.target===this)closeFd()">
  <div class="fd-sheet" id="fdSheet">
    <div id="fdImgWrap"></div>
    <div class="fd-body">
      <div class="fd-hdr" style="position:relative">
        <div class="fd-name" id="fdName">—</div>
        <button class="fd-fav-btn" id="fdFavBtn" onclick="toggleFav(fdIdx)">☆</button>
        <button class="fd-close" onclick="closeFd()" style="position:absolute;top:0;right:0">✕</button>
      </div>
      <div class="fd-portion" id="fdPortion"></div>
      <div class="fd-kcal-row">
        <div class="fd-kcal" id="fdKcal">0</div>
        <div class="fd-kcal-unit">ккал</div>
      </div>
      <div class="fd-macros">
        <div class="fd-mac p"><div class="fd-mac-val" id="fdProt">0г</div><div class="fd-mac-lbl">Белки</div></div>
        <div class="fd-mac c"><div class="fd-mac-val" id="fdCarb">0г</div><div class="fd-mac-lbl">Углеводы</div></div>
        <div class="fd-mac f"><div class="fd-mac-val" id="fdFat">0г</div><div class="fd-mac-lbl">Жиры</div></div>
      </div>
      <div class="fd-desc" id="fdDesc"></div>
      <div id="fdIngr" style="margin-bottom:8px;display:none"></div>
      <div class="fd-time" id="fdTime"></div>
      <div class="fd-qty-row">
        <span class="fd-qty-label">Количество порций</span>
        <div class="fd-qty-ctrl">
          <button class="fd-qty-btn minus" onclick="changeQty(-1)">−</button>
          <span class="fd-qty-num" id="fdQty">1</span>
          <button class="fd-qty-btn" onclick="changeQty(1)">+</button>
        </div>
      </div>
      <button class="fd-del" id="fdDel" onclick="delFd()" style="margin-top:14px">🗑 Удалить из дневника</button>
    </div>
  </div>
</div>
<!-- AI TRAINER — Full Redesign -->
<div id="ai" style="position:fixed;inset:0;display:none;flex-direction:column;background:var(--bg);z-index:200">
  <!-- Header -->
  <div style="padding:calc(env(safe-area-inset-top,44px) + 12px) 20px 14px;background:var(--card);border-bottom:1px solid var(--sep2);flex-shrink:0;display:flex;align-items:center;gap:14px;">
    <button class="ai-back" onclick="goS('home',document.querySelector('.nb'))">
      <svg width="10" height="18" viewBox="0 0 10 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 1L1 9l8 8"/></svg>
    </button>
    <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#0A0A0A,#3A3A3A);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;position:relative;box-shadow:0 2px 10px rgba(0,0,0,.2)">
      🤖
      <span style="position:absolute;bottom:1px;right:1px;width:11px;height:11px;border-radius:50%;background:#22C55E;border:2px solid var(--card)"></span>
    </div>
    <div style="flex:1">
      <div style="font-size:16px;font-weight:800;color:var(--lbl);letter-spacing:-.3px">AI Нутрициолог</div>
      <div style="font-size:12px;color:#22C55E;font-weight:600;margin-top:1px">● Онлайн</div>
    </div>
    <button style="width:36px;height:36px;border-radius:50%;background:var(--fill2);border:none;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--lbl2)" onclick="clearAiChat()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4"/></svg>
    </button>
  </div>
  <!-- Quick suggestions -->
  <div class="ai-sugs" style="flex-shrink:0">
    <div class="ai-sg" onclick="aiSug(this)">🔥 Моя норма?</div>
    <div class="ai-sg" onclick="aiSug(this)">💡 Что съесть?</div>
    <div class="ai-sg" onclick="aiSug(this)">📊 Мой рацион</div>
    <div class="ai-sg" onclick="aiSug(this)">🏋️ Набор массы</div>
    <div class="ai-sg" onclick="aiSug(this)">⚡ Быстрый перекус</div>
    <div class="ai-sg" onclick="aiSug(this)">🥗 Дефицит калорий</div>
  </div>
  <!-- Messages -->
  <div class="ai-msgs" id="aimsg"></div>
  <!-- Input bar -->
  <div class="ai-bar">
    <input class="ai-inp" id="aiinp" placeholder="Спроси что-нибудь…"
      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();aiSend();}">
    <button class="ai-snd" onclick="aiSend()">
      <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<!-- SETTINGS -->
<div class="screen" id="sett">
  <div class="st-hdr"><h2>Настройки</h2></div>
  <div class="st-sec">
    <div class="st-lbl">Внешний вид</div>
    <div class="st-card">
      <div class="st-row" onclick="toggleTheme()">
        <div class="sr-ico-wrap slate" style="filter:drop-shadow(0 1px 1px rgba(0,0,0,.4))">🌙</div>
        <div class="sr-txt"><div class="sr-t">Тёмная тема</div></div>
        <div class="toggle" id="themeToggle"></div>
      </div>
      <div class="st-row" onclick="toggleSfx()">
        <div class="sr-ico-wrap" style="background:var(--ios-orange);filter:drop-shadow(0 1px 1px rgba(0,0,0,.3))">🔊</div>
        <div class="sr-txt"><div class="sr-t">Звуки</div><div class="sr-s">Звуки интерфейса</div></div>
        <div class="toggle" id="sfxToggle"></div>
      </div>
      <div class="st-row" onclick="toggleHfx()">
        <div class="sr-ico-wrap" style="background:linear-gradient(145deg,#a78bfa,#7c3aed)">📳</div>
        <div class="sr-txt"><div class="sr-t">Вибрация</div><div class="sr-s">Тактильный отклик</div></div>
        <div class="toggle" id="hfxToggle"></div>
      </div>
    </div>
  </div>
  <div class="st-sec">
    <div class="st-lbl">Профиль</div>
    <div class="st-card">
      <div class="st-row" onclick="ed('name')"><div class="sr-ico-wrap blue" style="font-size:14px;font-weight:700;color:#fff;letter-spacing:0">Аа</div><div class="sr-txt"><div class="sr-t">Имя</div></div><span class="sr-v" id="sname">—</span></div>
      <div class="st-row" onclick="ed('params')"><div class="sr-ico-wrap green" style="font-size:13px;font-weight:700;color:#fff">cm</div><div class="sr-txt"><div class="sr-t">Возраст / Рост / Вес</div></div><span class="sr-arr">›</span></div>
      <div class="st-row" onclick="ed('goal')"><div class="sr-ico-wrap orange" style="filter:drop-shadow(0 1px 1px rgba(0,0,0,.3))">🎯</div><div class="sr-txt"><div class="sr-t">Цель</div></div><span class="sr-v" id="sgoal">—</span></div>
    </div>
  </div>
  <div class="st-sec">
    <div class="st-lbl">Питание</div>
    <div class="st-card">
      <div class="st-row" onclick="ed('kcal')"><div class="sr-ico-wrap red" style="filter:drop-shadow(0 1px 1px rgba(0,0,0,.3))">🔥</div><div class="sr-txt"><div class="sr-t">Норма калорий</div><div class="sr-s">Авторасчёт по параметрам</div></div><span class="sr-v" id="skcal">—</span></div>
    </div>
  </div>
  <div class="st-sec">
    <div class="st-lbl">API</div>
    <div class="st-card">
      <div class="st-row" onclick="openApi()"><div class="sr-ico-wrap indigo" style="filter:drop-shadow(0 1px 1px rgba(0,0,0,.3))">🔑</div><div class="sr-txt"><div class="sr-t">Gemini API ключ</div><div class="sr-s" id="sapi">Не установлен</div></div><span class="sr-arr">›</span></div>
      <div class="st-row" onclick="openModelPicker()"><div class="sr-ico-wrap purple" style="filter:drop-shadow(0 1px 1px rgba(0,0,0,.25))">🧠</div><div class="sr-txt"><div class="sr-t">Модель Gemini</div><div class="sr-s" id="smodel">gemini-2.0-flash-lite</div></div><span class="sr-arr">›</span></div>
    </div>
  </div>
  <div class="st-sec">
    <div class="st-lbl">Уведомления</div>
    <div class="st-card">
      <div class="st-row" onclick="setupNotifications()">
        <div class="sr-ico-wrap" style="background:#3b82f6">🔔</div>
        <div class="sr-txt"><div class="sr-t">Напоминания</div><div class="sr-s" id="notifStatus">Выпей воду, запиши еду и тд</div></div>
        <span class="sr-arr" id="notifArr">›</span>
      </div>
    </div>
  </div>
  <div class="st-sec">
    <div class="st-lbl">Данные</div>
    <div class="st-card">
      <button class="export-btn" onclick="exportData()">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Экспорт данных (CSV)
      </button>
      <div class="st-row" onclick="clrAll()"><div class="sr-ico-wrap red" style="filter:drop-shadow(0 1px 1px rgba(0,0,0,.3))">🗑️</div><div class="sr-txt"><div class="sr-t" style="color:var(--red)">Сбросить все данные</div></div></div>
    </div>
  </div>
  <div class="st-sec">
    <div class="st-lbl">О приложении</div>
    <div class="st-card">
      <div class="st-row" onclick="window.open('./widget.html','_blank')">
        <div class="sr-ico-wrap" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">📊</div>
        <div class="sr-txt"><div class="sr-t">Виджеты</div><div class="sr-s">Добавить на рабочий стол</div></div>
        <span class="sr-arr">›</span>
      </div>
      <div class="st-row" onclick="openAbout()">
        <div class="sr-ico-wrap" style="background:linear-gradient(135deg,var(--orange),#ff9a3c)">🍎</div>
        <div class="sr-txt"><div class="sr-t">Авторы CalSnap</div><div class="sr-s">RJV · Rizan</div></div>
        <span class="sr-arr">›</span>
      </div>
    </div>
  </div>
</div>

<!-- AUTHORS MODAL -->
<div class="about-ov" id="aboutOv" onclick="if(event.target===this)closeAbout()">
  <div class="about-sheet">
    <div class="about-handle"></div>
    <div class="about-top">
      <span class="about-logo">🍎</span>
      <div class="about-app-name">Cal<b>Snap</b></div>
      <div class="about-tagline">AI-трекер калорий нового поколения</div>
      <div class="about-version">ВЕРСИЯ 1.0</div>
    </div>
    <div class="about-team">
      <div class="about-team-lbl">Команда</div>
      <div class="about-person">
        <div class="about-avatar">RJV</div>
        <div class="about-pinfo">
          <div class="about-pname">RJV</div>
          <div class="about-prole">Разработка · Дизайн · Идея</div>
        </div>
        <div class="about-ptag lead">Разработчик</div>
      </div>
      <div class="about-person">
        <div class="about-avatar sec" style="font-size:16px">Rz</div>
        <div class="about-pinfo">
          <div class="about-pname">Rizan</div>
          <div class="about-prole">Идеи и обратная связь</div>
        </div>
        <div class="about-ptag ideas">Идеи</div>
      </div>
    </div>
    <div class="about-footer">
      <div class="about-footer-txt">Сделано с заботой о здоровье 🫀<br>CalSnap использует Gemini AI для анализа питания</div>
    </div>
    <div style="padding:16px 20px 0">
      <button onclick="closeAbout()" style="width:100%;background:var(--fill2);border:none;border-radius:14px;padding:14px;font-size:15px;font-weight:600;color:var(--text);cursor:pointer">Закрыть</button>
    </div>
  </div>
</div>


<!-- MODEL PICKER -->
<div id="mdlOv" style="position:fixed;inset:0;background:#00000070;z-index:300;display:none;align-items:flex-end">
  <div style="background:var(--white);border-radius:24px 24px 0 0;width:100%;max-height:75vh;overflow-y:auto;padding:0 0 env(safe-area-inset-bottom)">
    <div style="padding:18px 20px 12px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--white);z-index:1">
      <div>
        <div style="font-size:17px;font-weight:800;color:var(--text)">🧠 Модель Gemini</div>
        <div style="font-size:12px;color:var(--text2);margin-top:2px" id="mdlCount">Загрузка...</div>
      </div>
      <button onclick="document.getElementById('mdlOv').style.display='none'" 
        style="width:34px;height:34px;border-radius:50%;background:var(--bg);border:none;font-size:16px;cursor:pointer;color:var(--text)">✕</button>
    </div>
    <div id="mdlList" style="padding:12px 16px;display:flex;flex-direction:column;gap:8px"></div>
  </div>
</div>

<!-- PWA INSTALL BANNER -->
<div id="installBanner" style="display:none;position:fixed;bottom:80px;left:12px;right:12px;background:var(--white);border:2px solid var(--primary);border-radius:20px;padding:14px 16px;z-index:500;align-items:center;gap:12px;box-shadow:0 4px 20px rgba(0,0,0,0.12)">
  <div style="font-size:32px">📲</div>
  <div style="flex:1">
    <div style="font-size:14px;font-weight:800;color:var(--text)">Установить CalSnap</div>
    <div style="font-size:12px;color:var(--text2);margin-top:2px">Работает без интернета</div>
  </div>
  <button onclick="installPWA()" style="background:var(--primary);color:#fff;border:none;border-radius:12px;padding:8px 16px;font-size:13px;font-weight:700;cursor:pointer">Установить</button>
  <button onclick="document.getElementById('installBanner').style.display='none'" style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--text2);padding:0 4px">✕</button>
</div>
<!-- BOTTOM NAV -->
<nav id="nav">
  <button class="nb on" onclick="goS('home',this)">
    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span>Дом</span>
  </button>
  <button class="nb" onclick="goS('prog',this)">
    <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
    <span>Прогресс</span>
  </button>
  <button class="nb-add" onclick="openAdd()">
    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
  <button class="nb" onclick="goS('ai',this)">
    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    <span>AI</span>
  </button>
  <button class="nb" onclick="goS('sett',this)">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
    <span>Настройки</span>
  </button>
</nav>

<!-- ADD MODAL -->
<div class="ov" id="addOv" onclick="if(event.target===this)closeAdd()">
  <div class="sheet">
    <div class="sh-handle"></div>
    <div class="sh-hdr"><h3>Добавить еду</h3><button class="sh-close" onclick="closeAdd()">✕</button></div>

    <!-- MEAL CATEGORY CHIPS -->
    <div class="meal-chips">
      <div class="meal-chip on" data-meal="breakfast" onclick="setMeal('breakfast')">🌅 Завтрак</div>
      <div class="meal-chip" data-meal="lunch" onclick="setMeal('lunch')">☀️ Обед</div>
      <div class="meal-chip" data-meal="dinner" onclick="setMeal('dinner')">🌙 Ужин</div>
      <div class="meal-chip" data-meal="snack" onclick="setMeal('snack')">🍎 Перекус</div>
      <div class="meal-chip" data-meal="other" onclick="setMeal('other')">🍽️ Прочее</div>
    </div>

    <!-- RECENT FOODS -->
    <div id="recentsList" style="display:none;margin-bottom:8px"></div>

    <div class="tabs">
      <button class="tab on" onclick="swTab('photo',this)">📷 Фото</button>
      <button class="tab" onclick="swTab('text',this)">✍️ Текст</button>
      <button class="tab" onclick="swTab('barcode',this)">📦 Штрихкод</button>
    </div>

    <!-- PHOTO -->
    <div class="panel on" id="tp-photo">
      <div class="upzone" id="upz" style="display:block">
        <span class="ui">📷</span>
        <h4>Добавить фото</h4>
        <p>Выбери способ</p>
        <div style="display:flex;gap:10px;margin-top:16px;position:relative;z-index:1">
          <button onclick="document.getElementById('phinp_cam').click()" style="flex:1;background:var(--primary);color:var(--bg);border:none;border-radius:var(--r);padding:13px;font-size:14px;font-weight:700;cursor:pointer">📷 Камера</button>
          <button onclick="document.getElementById('phinp_gal').click()" style="flex:1;background:var(--fill2);border:none;border-radius:12px;padding:13px;font-size:14px;font-weight:600;cursor:pointer;color:var(--lbl)">🖼 Галерея</button>
        </div>
        <input type="file" id="phinp_cam" accept="image/*" capture="environment" onchange="onPhoto(event)" style="display:none">
        <input type="file" id="phinp_gal" accept="image/*" onchange="onPhoto(event)" style="display:none">
      </div>
      <div class="prev-wrap" id="prevw" style="display:none">
        <img id="previmg" src="" alt="">
        <button class="prev-change" onclick="rstPhoto()">Изменить</button>
      </div>
      <div id="phDescWrap" style="display:none;margin-bottom:10px">
        <textarea id="phDesc" class="txa" placeholder="Необязательно: опиши блюдо для точности AI&#10;Например: домашний борщ со сметаной, большая тарелка" style="min-height:72px;font-size:14px"></textarea>
      </div>
      <div id="phAbtn" style="display:none;margin-bottom:12px">
        <button class="btn" onclick="doPhoto()">🔍 Анализировать</button>
      </div>
      <div class="ldr" id="phldr"><div class="sp"></div><p id="ldrtxt">Gemini анализирует…</p></div>
      <div class="err" id="pherr"></div>
      <div class="res" id="phres">
        <img class="res-img" id="resimg" src="" alt="">
        <div class="res-body">
          <div class="res-name" id="rn">—</div>
          <div class="res-portion" id="rp">—</div>
          <div class="res-kcal" id="rk">— <small>ккал</small></div>
          <div class="res-macs">
            <div class="rm p"><div class="rv" id="rpr">—</div><div class="rk2" style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Белки</div></div>
            <div class="rm c"><div class="rv" id="rcr">—</div><div class="rk2" style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Углев.</div></div>
            <div class="rm f"><div class="rv" id="rfr">—</div><div class="rk2" style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Жиры</div></div>
          </div>
          <div class="res-desc" id="rd"></div>
          <div id="ringrlist"></div>
        </div>
      </div>
      <div id="phAddbtn" style="display:none">
        <button class="btn" onclick="addRes('photo')" style="margin-bottom:8px">+ Добавить в дневник</button>
        <button class="btn2" onclick="rstPhoto()">Новое фото</button>
      </div>
    </div>

    <!-- TEXT -->
    <div class="panel" id="tp-text">
      <div class="exs">
        <div class="ex" onclick="fillTx(this)">1 яблоко</div>
        <div class="ex" onclick="fillTx(this)">тарелка гречки</div>
        <div class="ex" onclick="fillTx(this)">2 яйца варёных</div>
        <div class="ex" onclick="fillTx(this)">200г творога</div>
        <div class="ex" onclick="fillTx(this)">кофе с молоком</div>
        <div class="ex" onclick="fillTx(this)">бутерброд с сыром</div>
      </div>
      <textarea class="txa" id="txinp" placeholder="Напиши что съел…&#10;Например: 2 яблока и стакан кефира"></textarea>
      <div class="ldr" id="txldr"><div class="sp"></div><p>Считаю калории…</p></div>
      <div class="err" id="txerr"></div>
      <div class="res" id="txres">
        <div class="res-body">
          <div class="res-name" id="trn">—</div>
          <div class="res-portion" id="trp">—</div>
          <div class="res-kcal" id="trk">— <small>ккал</small></div>
          <div class="res-macs">
            <div class="rm p"><div class="rv" id="trpr">—</div><div style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Белки</div></div>
            <div class="rm c"><div class="rv" id="trcr">—</div><div style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Углев.</div></div>
            <div class="rm f"><div class="rv" id="trfr">—</div><div style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Жиры</div></div>
          </div>
          <div class="res-desc" id="trd"></div>
        </div>
      </div>
      <div id="txAbtn">
        <button class="btn" onclick="doText()">🔍 Рассчитать</button>
      </div>
      <div id="txAddbtn" style="display:none;margin-top:12px;padding-bottom:20px">
        <button class="btn" onclick="addRes('text')" style="margin-bottom:8px">+ Добавить в дневник</button>
        <button class="btn2" onclick="rstText()">Очистить</button>
      </div>
    </div>

    <!-- BARCODE -->
    <div class="panel" id="tp-barcode">
      <div class="scan-box">
        <div class="scan-frame"><div class="scan-line"></div></div>
        <h4 style="font-size:15px;font-weight:700;margin-bottom:6px;color:var(--text)">Сканировать штрихкод</h4>
        <p style="font-size:13px;color:var(--text2)">Gemini прочитает и найдёт данные</p>
        <div style="display:flex;gap:10px;margin-top:16px">
          <button onclick="document.getElementById('bc_cam').click()" style="flex:1;background:var(--primary);color:var(--bg);border:none;border-radius:var(--r);padding:13px;font-size:14px;font-weight:700;cursor:pointer">📷 Камера</button>
          <button onclick="document.getElementById('bc_gal').click()" style="flex:1;background:var(--fill2);border:none;border-radius:12px;padding:13px;font-size:14px;font-weight:600;cursor:pointer;color:var(--lbl)">🖼 Галерея</button>
        </div>
        <input type="file" id="bc_cam" accept="image/*" capture="environment" onchange="doBarcode(event)" style="display:none">
        <input type="file" id="bc_gal" accept="image/*" onchange="doBarcode(event)" style="display:none">
      </div>
      <div class="ldr" id="bcldr"><div class="sp"></div><p>Читаю штрихкод…</p></div>
      <div class="err" id="bcerr"></div>
      <div class="res" id="bcres">
        <div class="res-body">
          <div class="res-name" id="brn">—</div>
          <div class="res-portion" id="brp">—</div>
          <div class="res-kcal" id="brk">— <small>ккал</small></div>
          <div class="res-macs">
            <div class="rm p"><div class="rv" id="brpr">—</div><div style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Белки</div></div>
            <div class="rm c"><div class="rv" id="brcr">—</div><div style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Углев.</div></div>
            <div class="rm f"><div class="rv" id="brfr">—</div><div style="font-size:10px;color:var(--text2);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.3px">Жиры</div></div>
          </div>
          <div class="res-desc" id="brd"></div>
        </div>
      </div>
      <div id="bcAddbtn" style="display:none;margin-top:12px">
        <button class="btn" onclick="addRes('barcode')">+ Добавить в дневник</button>
      </div>
    </div>
  </div>
</div>

<!-- API MODAL -->
<div class="ed-ov" id="apiOv" onclick="if(event.target===this)closeApi()">
  <div class="ed-sheet">
    <h3>🔑 API ключ Gemini</h3>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px;line-height:1.5">Получи бесплатный ключ на <a href="https://aistudio.google.com/apikey" target="_blank" style="color:var(--orange);font-weight:600">aistudio.google.com</a></p>
    <input class="inp" type="password" id="apiinp" placeholder="AIza...">
    <button class="btn" onclick="saveApi()">Сохранить</button>
    <button class="btn2" onclick="closeApi()">Отмена</button>
  </div>
</div>

<!-- EDIT MODAL -->
<div class="ed-ov" id="edOv" onclick="if(event.target===this)closeEd()">
  <div class="ed-sheet">
    <h3 id="edtitle">Редактировать</h3>
    <div id="edcont"></div>
    <button class="btn" onclick="saveEd()">Сохранить</button>
    <button class="btn2" onclick="closeEd()">Отмена</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     CALSNAP SOUND SYSTEM
     ═══════════════════════════════════════════════════
     
     КАК ИСПОЛЬЗОВАТЬ СВОИ ЗВУКИ:
     
     1. Положи .mp3 / .ogg файлы в папку: sounds/
     
     2. Список всех звуков и куда класть файлы:
     
        sounds/welcome.mp3      — Первый запуск приложения (сплэш → онбординг)
        sounds/splash.mp3       — Каждый запуск приложения (анимация сплэш экрана)
        sounds/tab_switch.mp3   — Переключение вкладок нижней навигации
        sounds/sheet_open.mp3   — Открытие модальных окон (добавить еду, вес и тд)
        sounds/sheet_close.mp3  — Закрытие модальных окон
        sounds/drum_tick.mp3    — Скролл барабана (дата рождения, выбор значений)
        sounds/drum_confirm.mp3 — Нажатие «Готово» в барабане выбора даты
        sounds/ob_next.mp3      — Переход между шагами онбординга
        sounds/ob_finish.mp3    — Завершение онбординга (финальная кнопка)
        sounds/add_food.mp3     — Успешное добавление еды в дневник
        sounds/scan_success.mp3 — AI успешно распознал еду / штрихкод
        sounds/btn_tap.mp3      — Нажатие кнопок (общий)
        sounds/toggle.mp3       — Переключение тоглов в настройках
        sounds/save.mp3         — Сохранение данных (вес, настройки)
        sounds/error.mp3        — Ошибка (неверный API ключ и тд)
        sounds/ai_send.mp3      — Отправка сообщения AI ассистенту
        sounds/ai_reply.mp3     — AI ассистент ответил
     
     3. Рекомендуемые параметры звуков:
        - Длительность: 50–300мс (короткие, чёткие)
        - Формат: .mp3 (основной) + .ogg (запасной для Firefox)
        - Громкость при экспорте: -12dB (не слишком громко)
        - Fade out: 10–20мс чтобы не было клика
     
     4. Отключить/включить звуки пользователь может в настройках
        (тогл «Звуки» добавлен автоматически — ищи в разделе Настройки)
     
     ═══════════════════════════════════════════════════ -->

<script>
// ═══════════════════════════════════════════════════
// CALSNAP SOUND ENGINE
// ═══════════════════════════════════════════════════
const SFX = (() => {
  // Громкость каждого звука (0.0 — 1.0)
  const VOLUMES = {
    welcome:      0.7,
    splash:       0.5,
    tab_switch:   0.4,
    sheet_open:   0.45,
    sheet_close:  0.35,
    drum_tick:    0.22,
    drum_confirm: 0.55,
    ob_next:      0.5,
    ob_finish:    0.75,
    add_food:     0.65,
    scan_success: 0.65,
    btn_tap:      0.3,
    toggle:       0.35,
    save:         0.55,
    error:        0.5,
    ai_send:      0.4,
    ai_reply:     0.45,
  };

  // Пул Audio объектов для каждого звука (3 штуки — для быстрых повторов)
  const _pool = {};
  const _poolIdx = {};

  // Звуки включены?
  let _enabled = localStorage.getItem('sfx_enabled') !== '0';
  let _unlocked = false;

  const NAMES = Object.keys(VOLUMES);

  // Создать пул Audio для одного звука
  function _createPool(name) {
    const vol = VOLUMES[name] ?? 0.5;
    const count = name === 'drum_tick' ? 4 : 2; // для тика больше копий
    _pool[name] = [];
    _poolIdx[name] = 0;
    for (let i = 0; i < count; i++) {
      const a = new Audio();
      a.preload = 'auto';
      a.volume = vol;
      // Пробуем mp3 — основной формат
      a.src = `sounds/${name}.mp3`;
      _pool[name].push(a);
    }
  }

  // Предзагрузка всех звуков
  function preload() {
    NAMES.forEach(n => { if (!_pool[n]) _createPool(n); });
  }

  // Разблокировка Audio на iOS — через AudioContext без звука
  function _unlock() {
    if (_unlocked) return;
    _unlocked = true;
    // Используем AudioContext для разблокировки — без воспроизведения реальных звуков
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const buf = ctx.createBuffer(1, 1, 22050);
      const src = ctx.createBufferSource();
      src.buffer = buf;
      src.connect(ctx.destination);
      src.start(0);
      setTimeout(() => ctx.close(), 500);
    } catch(e) {}
  }

  // Воспроизвести звук
  function play(name) {
    if (!_enabled) return;
    if (!_pool[name]) _createPool(name);
    // Берём следующий из пула (round-robin) — не прерываем предыдущий
    const pool = _pool[name];
    const idx = _poolIdx[name] % pool.length;
    _poolIdx[name] = (idx + 1) % pool.length;
    const a = pool[idx];
    try {
      a.currentTime = 0;
      const p = a.play();
      if (p) p.catch(() => {});
    } catch(e) {}
  }

  // Включить/выключить
  function setEnabled(v) {
    _enabled = v;
    localStorage.setItem('sfx_enabled', v ? '1' : '0');
  }
  function isEnabled() { return _enabled; }

  // Разблокировка при первом касании + предзагрузка
  function _onFirstTouch() {
    preload();
    _unlock();
  }
  document.addEventListener('touchstart', _onFirstTouch, { once: true });
  document.addEventListener('mousedown',  _onFirstTouch, { once: true });
  document.addEventListener('touchend',   _onFirstTouch, { once: true });

  return { play, setEnabled, isEnabled, preload };
})();
</script>

<script>
// Storage
const G=(k,d='')=>{try{return localStorage.getItem(k)||d}catch(e){return d}};
const S=(k,v)=>{try{localStorage.setItem(k,v)}catch(e){}};

// State
let U=JSON.parse(G('u','null')),
    log=JSON.parse(G('log','[]')),
    wts=JSON.parse(G('wts','[]')),
    key=G('key'),
    cur={},
    edType='',
    aiReady=false,
    obAct=1.2,obGoal='maintain';

const GL={lose:'Похудеть',maintain:'Держать вес',gain:'Набрать массу'};

// INIT
function init(){
  // DOB handled by drum picker
  if(!U){
    // Первый запуск — звук приветствия (с задержкой после сплэша)
    setTimeout(()=>SFX.play('welcome'), 2000);
    ss('ob');return;
  }
  document.getElementById('nav').style.display='flex';
  ss('home');rH();rSet();if(key)setTimeout(fetchGeminiModels,800);
}

// Onboarding
function os(n){document.querySelectorAll('.ob-step').forEach(s=>s.classList.remove('on'));document.getElementById('os'+n).classList.add('on')}
function on1(){const v=document.getElementById('obn').value.trim();if(!v){alert('Введи имя');return;}HFX.medium();SFX.play('ob_next');os(2)}
let obGender='m';
function pickGender(g){
  obGender=g;
  document.getElementById('gen_m').classList.toggle('on',g==='m');
  document.getElementById('gen_f').classList.toggle('on',g==='f');
}
function calcAgeFromDob(dob){
  if(!dob)return null;
  const b=new Date(dob),n=new Date();
  let a=n.getFullYear()-b.getFullYear();
  if(n.getMonth()<b.getMonth()||(n.getMonth()===b.getMonth()&&n.getDate()<b.getDate()))a--;
  return a;
}
// onDobChange replaced by drum picker
function on2(){
  const btn=document.getElementById('ob_dob_btn');
  const dob=btn?.dataset?.dob||'';
  const h=document.getElementById('obh').value,w=document.getElementById('obw').value;
  const age=calcAgeFromDob(dob);
  if(!dob||!age||age<5||age>120){
    // Animate button to highlight
    const b=document.getElementById('ob_dob_btn');
    if(b){b.style.borderColor='var(--ios-red)';setTimeout(()=>{b.style.borderColor='';},1500);}
    return;
  }
  if(!h||!w){
    const h_el=document.getElementById('obh'),w_el=document.getElementById('obw');
    if(!h&&h_el){h_el.style.borderColor='var(--ios-red)';setTimeout(()=>{h_el.style.borderColor='';},1500);}
    if(!w&&w_el){w_el.style.borderColor='var(--ios-red)';setTimeout(()=>{w_el.style.borderColor='';},1500);}
    return;
  }
  os(3);HFX.medium();SFX.play('ob_next');
}
function on3(){HFX.medium();SFX.play('ob_next');os(4)}
function sa(el){document.querySelectorAll('[data-a]').forEach(e=>e.classList.remove('on'));el.classList.add('on');obAct=parseFloat(el.dataset.a)}
function sg(el){document.querySelectorAll('[data-g]').forEach(e=>e.classList.remove('on'));el.classList.add('on');obGoal=el.dataset.g}
function onFin(){
  const name=document.getElementById('obn').value.trim();
  const dob=document.getElementById('ob_dob_btn')?.dataset?.dob||'';
  const gen=obGender;
  const h=parseFloat(document.getElementById('obh').value);
  const w=parseFloat(document.getElementById('obw').value);
  const age=calcAgeFromDob(dob)||18;
  let bmr=gen==='m'?10*w+6.25*h-5*age+5:10*w+6.25*h-5*age-161;
  let kcal=Math.round(bmr*obAct);
  if(obGoal==='lose')kcal-=500;
  if(obGoal==='gain')kcal+=300;
  kcal=Math.max(1200,kcal);
  const pr=Math.round(w*1.8),ft=Math.round(kcal*.25/9),cb=Math.round((kcal-pr*4-ft*9)/4);
  U={name,dob,age,gen,h,w,goal:obGoal,act:obAct,kcal,pr,ft,cb};
  S('u',JSON.stringify(U));
  HFX.success();SFX.play('ob_finish');
  document.getElementById('nav').style.display='flex';
  ss('home');rH();rSet();
}

// Screens
function ss(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');if(id==='prog')rP();if(id==='ai'&&!aiReady)initAi();}
function goS(id,btn){
  HFX.light(); SFX.play('tab_switch');
  const prev = document.querySelector('.screen.active');
  if(prev) prev.classList.remove('active');
  // Hide AI overlay
  const aiEl = document.getElementById('ai');
  if(id==='ai'){
    if(aiEl) aiEl.style.display='flex';
    return; // AI is not a .screen
  } else {
    if(aiEl) aiEl.style.display='none';
  }
  // Show new screen with fresh animation
  const next = document.getElementById(id);
  if(next){
    next.style.animation='none';
    // Force reflow to restart animation
    void next.offsetWidth;
    next.style.animation='';
    next.classList.add('active');
  }
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  if(btn) btn.classList.add('on');
  // Refresh data for screen
  if(id==='home')  rH();
  if(id==='prog')  rP();
  if(id==='sett')  rSet();
}

// Date
const ds=d=>(d||new Date()).toDateString();
const tlog=()=>log.filter(e=>e.date===ds());
const dlog=d=>log.filter(e=>e.date===d);
const tot=es=>es.reduce((s,e)=>({k:s.k+(e.kcal||0),p:s.p+(e.prot||0),f:s.f+(e.fat||0),c:s.c+(e.carb||0)}),{k:0,p:0,f:0,c:0});
const tnow=()=>new Date().toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'});

// Streak
function streak(){
  let s=0;const n=new Date();
  for(let i=0;;i++){const d=new Date(n);d.setDate(d.getDate()-i);if(dlog(ds(d)).length)s++;else if(i>0)break;}
  return s;
}

// HOME
function rH(){
  if(!U)return;
  const hr=new Date().getHours();
  document.getElementById('greet').textContent=hr<12?'Доброе утро ☀️':hr<18?'Добрый день 🌤️':'Добрый вечер 🌙';
  document.getElementById('hname').textContent=U.name+'!';
  document.getElementById('abar').style.display=key?'none':'flex';
  document.getElementById('snum').textContent=streak();
  rCal();
  // Compact tip
  const cached=G('tip_'+ds());
  if(cached){
    const el=document.getElementById('tipText');
    if(el){el.className='tip-compact-text loaded';el.textContent=cached;}
  } else if(key){
    setTimeout(()=>loadDailyTip(false), 1400);
  }

  const activeDayStr=selDay||ds();
  const tl=dlog(activeDayStr),t=tot(tl),g=U.kcal||2000;
  // Update section label
  const lbl=document.getElementById('dayLabel');
  if(lbl) lbl.textContent=selDay? new Date(selDay).toLocaleDateString('ru',{day:'numeric',month:'long'}) : 'Сегодня';
  const pct=Math.min(t.k/g,1);
  const ring=document.getElementById('hring');
  const C=2*Math.PI*33;
  ring.style.strokeDasharray=C;
  ring.style.strokeDashoffset=C*(1-pct);
  ring.style.stroke=t.k>g*1.05?'var(--red)':'var(--primary)';
  document.getElementById('hpct').textContent=Math.round(pct*100)+'%';
  // Animated calorie counter
  const kcalEl=document.getElementById('hkcal');
  const prevK=parseInt(kcalEl.dataset.val||'0')||0;
  kcalEl.dataset.val=t.k;
  if(prevK!==t.k){
    const dur=600,st=performance.now();
    const animK=now=>{
      const p=Math.min((now-st)/dur,1),e=1-Math.pow(1-p,3);
      kcalEl.textContent=Math.round(prevK+(t.k-prevK)*e);
      if(p<1)requestAnimationFrame(animK); else kcalEl.textContent=t.k;
    };
    requestAnimationFrame(animK);
  } else { kcalEl.textContent=t.k; }
  document.getElementById('hgoal').textContent=g;
  document.getElementById('hrem').textContent=t.k<=g?`Осталось ${g-t.k} ккал`:`Превышено на ${t.k-g} ккал`;
  document.getElementById('hprot').textContent=Math.round(t.p)+'г';
  document.getElementById('hcarb').textContent=Math.round(t.c)+'г';
  document.getElementById('hfat').textContent=Math.round(t.f)+'г';
  document.getElementById('hpg').textContent=(U.pr||0)+'г';
  document.getElementById('hcg').textContent=(U.cb||0)+'г';
  document.getElementById('hfg').textContent=(U.ft||0)+'г';
  document.getElementById('hpbar').style.width=Math.min(t.p/(U.pr||100)*100,100)+'%';
  document.getElementById('hcbar').style.width=Math.min(t.c/(U.cb||100)*100,100)+'%';
  document.getElementById('hfbar').style.width=Math.min(t.f/(U.ft||100)*100,100)+'%';

  const logEl=document.getElementById('hlog');
  if(!tl.length){logEl.innerHTML=`<div class="empty"><span class="ei">🥗</span><p>Нажми <b>+</b> чтобы добавить<br>первый приём пищи</p></div>`;return;}
  logEl.innerHTML=tl.map(item=>{
    const idx=log.indexOf(item);
    const em=emo(item.food||'');
    const qty=item.qty||1;
    return `<div class="logitem" onclick="openFd(${idx})">
      ${item.img?`<img class="li-img" src="${item.img}" onerror="this.outerHTML='<div class=\\'li-img\\'>${em}</div>'">`:`<div class="li-img">${em}</div>`}
      <div class="li-info">
        <div class="li-name">${item.food||'Блюдо'}${qty>1?`<span class="li-qty">${qty} шт</span>`:''}</div>
        <div class="li-sub">${item.time}${item.portion?' · '+item.portion:''}</div>
        <div class="li-macs">
          <span class="li-mac p">Б:${Math.round(item.prot||0)}г</span>
          <span class="li-mac c">У:${Math.round(item.carb||0)}г</span>
          <span class="li-mac f">Ж:${Math.round(item.fat||0)}г</span>
        </div>
      </div>
      <div class="li-right">
        <div class="li-kcal">${item.kcal||0}</div>
        <div class="li-unit">ккал</div>
      </div>
      <button class="li-del" onclick="event.stopPropagation();delL(${idx})">🗑</button>
    </div>`;
  }).join('');
}

function emo(f){
  f=f.toLowerCase();
  if(f.includes('яблок'))return'🍎';if(f.includes('банан'))return'🍌';if(f.includes('курица')||f.includes('куриц'))return'🍗';
  if(f.includes('рыб')||f.includes('лосос'))return'🐟';if(f.includes('салат'))return'🥗';if(f.includes('хлеб')||f.includes('бутерброд'))return'🍞';
  if(f.includes('суп'))return'🍲';if(f.includes('пицц'))return'🍕';if(f.includes('гречк')||f.includes('рис')||f.includes('кашa'))return'🍚';
  if(f.includes('яиц')||f.includes('яйц'))return'🥚';if(f.includes('молок')||f.includes('кефир')||f.includes('творог'))return'🥛';
  if(f.includes('кофе')||f.includes('чай'))return'☕';if(f.includes('чипс'))return'🍟';if(f.includes('шоколад')||f.includes('торт'))return'🍫';
  if(f.includes('овощ'))return'🥦';if(f.includes('фрукт'))return'🍑';return'🍽️';
}

function delL(i){log.splice(i,1);S('log',JSON.stringify(log));rH();}

let fdIdx=null;
function openFd(i){
  const item=log[i];if(!item)return;
  fdIdx=i;
  // Show current qty
  const qtyEl=document.getElementById('fdQty');
  if(qtyEl) qtyEl.textContent=item.qty||1;
  // Image or emoji
  const wrap=document.getElementById('fdImgWrap');
  if(item.img) wrap.innerHTML=`<img class="fd-img" src="${item.img}" onerror="this.outerHTML='<div class=\'fd-nophoto\'>${emo(item.food||'')}</div>'">`;
  else wrap.innerHTML=`<div class="fd-nophoto">${emo(item.food||'')}</div>`;
  document.getElementById('fdName').textContent=item.food||'Блюдо';
  document.getElementById('fdPortion').textContent=item.portion||'';
  document.getElementById('fdKcal').textContent=item.kcal||0;
  document.getElementById('fdProt').textContent=Math.round(item.prot||0)+'г';
  document.getElementById('fdCarb').textContent=Math.round(item.carb||0)+'г';
  document.getElementById('fdFat').textContent=Math.round(item.fat||0)+'г';
  document.getElementById('fdDesc').textContent=item.desc||'';
  // Show ingredients if available
  const ingrEl=document.getElementById('fdIngr');
  if(ingrEl){
    if(item.ingr&&item.ingr.length>0){
      ingrEl.innerHTML='<div class="ingr-hdr">СОСТАВ</div>'+item.ingr.map(i=>`<div class="ingr-i"><span class="ingr-n">${i.name}</span><span class="ingr-c">${i.calories}ккал</span></div>`).join('');
      ingrEl.style.display='block';
    } else {
      ingrEl.style.display='none';
    }
  }
  document.getElementById('fdTime').textContent='Добавлено: '+item.date+' в '+item.time;
  document.getElementById('fdOv').classList.add('on');
  document.body.style.overflow='hidden';
  setTimeout(_updateFdFav, 50);
}
function closeFd(){document.getElementById('fdOv').classList.remove('on');document.body.style.overflow='';fdIdx=null;}
function delFd(){if(fdIdx===null)return;HFX.heavy();SFX.play('error');delL(fdIdx);closeFd();}

// Update fav button state in food detail
function _updateFdFav(){
  const btn=document.getElementById('fdFavBtn');if(!btn||fdIdx===null)return;
  const item=log[fdIdx]; if(!item)return;
  const isFav=getFavs().some(f=>f.food===item.food);
  btn.textContent=isFav?'★':'☆';
  btn.classList.toggle('faved',isFav);
}

// Calendar strip
let selDay=null; // null = today
function rCal(){
  const el=document.getElementById('cals'),n=new Date(),dns=['Вс','Пн','Вт','Ср','Чт','Пт','Сб'],g=U?.kcal||2000;
  let h='';
  for(let i=13;i>=0;i--){
    const d=new Date(n);d.setDate(d.getDate()-i);
    const dateStr=ds(d);
    const today=d.toDateString()===n.toDateString();
    const selected=selDay===dateStr||(!selDay&&today);
    const es=dlog(dateStr);const tk=tot(es).k;
    let c=today?'today':'';
    if(es.length&&!today)c+=tk>g*1.05?' over':' has';
    if(selected&&!today)c+=' sel';
    h+=`<div class="cd ${c}" onclick="selectDay('${dateStr}')"><span class="cn">${dns[d.getDay()]}</span><span class="cv">${d.getDate()}</span><span class="cdot"></span></div>`;
  }
  el.innerHTML=h;setTimeout(()=>el.parentElement.scrollLeft=9999,30);
}
function changeQty(delta){
  const item=log[fdIdx];if(!item)return;
  const base=item.baseKcal||item.kcal;
  const baseProt=item.baseProt||item.prot;
  const baseCarb=item.baseCarb||item.carb;
  const baseFat=item.baseFat||item.fat;
  // Store base values first time
  if(!item.baseKcal){item.baseKcal=item.kcal;item.baseProt=item.prot;item.baseCarb=item.carb;item.baseFat=item.fat;}
  const newQty=Math.max(1,(item.qty||1)+delta);
  item.qty=newQty;
  item.kcal=Math.round(item.baseKcal*newQty);
  item.prot=Math.round(item.baseProt*newQty*10)/10;
  item.carb=Math.round(item.baseCarb*newQty*10)/10;
  item.fat=Math.round(item.baseFat*newQty*10)/10;
  S('log',JSON.stringify(log));
  // Update UI in detail sheet
  const qtyEl=document.getElementById('fdQty');
  if(qtyEl){
    qtyEl.textContent=newQty;
    qtyEl.style.transition='transform .15s cubic-bezier(.36,.66,.04,1)';
    qtyEl.style.transform='scale(1.35)';
    setTimeout(()=>{if(qtyEl){qtyEl.style.transform='scale(1)';}},180);
  }
  document.getElementById('fdKcal').textContent=item.kcal;
  document.getElementById('fdProt').textContent=Math.round(item.prot)+'г';
  document.getElementById('fdCarb').textContent=Math.round(item.carb)+'г';
  document.getElementById('fdFat').textContent=Math.round(item.fat)+'г';
  HFX.light();
  rH();
}


function selectDay(dateStr){
  const n=new Date();
  selDay=dateStr===ds(n)?null:dateStr;
  rH();
}

// PROGRESS
function rP(){
  if(!U)return;
  const s=streak();
  document.getElementById('pstr').textContent=s;
  // Week
  const n=new Date(),dns=['Пн','Вт','Ср','Чт','Пт','Сб','Вс'];
  document.getElementById('wkd').innerHTML=Array.from({length:7},(_,i)=>{
    const d=new Date(n);d.setDate(d.getDate()-(6-i));
    const today=d.toDateString()===n.toDateString();
    const has=dlog(ds(d)).length>0;
    return `<div class="wd ${has?'done':today?'today':''}">${dns[(d.getDay()+6)%7]}</div>`;
  }).join('');
  // Stats
  const l7=Array.from({length:7},(_,i)=>{const d=new Date(n);d.setDate(d.getDate()-i);return dlog(ds(d));});
  const active=l7.filter(d=>d.length);
  const avg=active.length?Math.round(active.reduce((s,d)=>s+tot(d).k,0)/active.length):0;
  document.getElementById('pavg').textContent=avg||'—';
  const g=U.kcal||2000;
  let bd='—',bd2=Infinity;
  for(let i=0;i<30;i++){const d=new Date(n);d.setDate(d.getDate()-i);const es=dlog(ds(d));if(!es.length)continue;const diff=Math.abs(tot(es).k-g);if(diff<bd2){bd2=diff;bd=d.toLocaleDateString('ru',{day:'numeric',month:'short'});}}
  document.getElementById('pbest').textContent=bd;
  document.getElementById('ptot').textContent=log.length;
  let td=0;for(let i=0;i<30;i++){const d=new Date(n);d.setDate(d.getDate()-i);if(dlog(ds(d)).length)td++;}
  document.getElementById('pdays').textContent=td;
  // Heatmap — with overeating severity colors
  const hg=document.getElementById('hgrid');
  hg.innerHTML=Array.from({length:28},(_,i)=>{
    const d=new Date(n);d.setDate(d.getDate()-(27-i));
    const tk=tot(dlog(ds(d))).k,r=tk/g;
    let c='';
    if(tk>0){
      if(r>1.5) c='ov4';
      else if(r>1.25) c='ov3';
      else if(r>1.1) c='ov2';
      else if(r>1.0) c='ov1';
      else if(r>0.9) c='c4';
      else if(r>0.6) c='c3';
      else if(r>0.3) c='c2';
      else c='c1';
    }
    return `<div class="hcell ${c}" title="${d.toLocaleDateString('ru')}: ${tk} ккал"></div>`;
  }).join('');
  // Weight chart
  rWChart();
  // Water balance
  rWater();
  // BMI
  rBMI();
  // Load cached weekly analysis
  const wkKey = 'week_'+new Date().toISOString().slice(0,7)+'_'+Math.floor(new Date().getDate()/7);
  const cached = G(wkKey);
  if(cached) { try{ renderWeekAnalysis(JSON.parse(cached)); }catch(e){} }
}

let _wlogVal=70.0;
function logW(){
  // Initialize value from last recorded or U.w
  _wlogVal=wts.length>0?wts[0].v:(U?.w||70);
  _wlogVal=Math.round(_wlogVal*10)/10;
  document.getElementById('wlogVal').textContent=_wlogVal.toFixed(1);
  // Show trend
  const trendEl=document.getElementById('wlogTrend');
  if(wts.length>0&&trendEl){
    const diff=Math.round((_wlogVal-wts[0].v)*10)/10;
    if(diff>0){trendEl.className='wlog-trend up';trendEl.textContent='↑ +'+diff+' кг с последнего измерения';}
    else if(diff<0){trendEl.className='wlog-trend down';trendEl.textContent='↓ '+diff+' кг с последнего измерения';}
    else{trendEl.className='wlog-trend same';trendEl.textContent='Вес не изменился с прошлого раза';}
  } else if(trendEl){trendEl.textContent='Первое измерение';}
  document.getElementById('wlogOv').classList.add('on');
  SFX.play('sheet_open');
  document.body.style.overflow='hidden';
}
function wlogStep(d){
  _wlogVal=Math.round((_wlogVal+d)*10)/10;
  if(_wlogVal<20)_wlogVal=20;
  if(_wlogVal>300)_wlogVal=300;
  const el=document.getElementById('wlogVal');
  if(el){
    el.textContent=_wlogVal.toFixed(1);
    el.style.transform='scale(1.18)';
    setTimeout(()=>{if(el)el.style.transform='';},150);
  }
  // Update trend vs previous
  const trendEl=document.getElementById('wlogTrend');
  if(trendEl&&wts.length>0){
    const diff=Math.round((_wlogVal-wts[0].v)*10)/10;
    if(diff>0){trendEl.className='wlog-trend up';trendEl.textContent='↑ +'+diff+' кг с последнего измерения';}
    else if(diff<0){trendEl.className='wlog-trend down';trendEl.textContent='↓ '+diff+' кг с последнего измерения';}
    else{trendEl.className='wlog-trend same';trendEl.textContent='Вес не изменился';}
  }
  HFX.tick();
}
function closeWlog(){document.getElementById('wlogOv').classList.remove('on');document.body.style.overflow='';}
function saveWlog(){
  const v=_wlogVal;
  if(isNaN(v)||v<=0)return;
  HFX.success(); SFX.play('save');
  wts.unshift({v,d:ds(),t:tnow()});
  S('wts',JSON.stringify(wts));
  // Update user weight and recalculate
  if(U){
    U.w=v;
    rcalc();
    S('u',JSON.stringify(U));
    rH();rSet();
  }
  closeWlog();
  rWChart();
  // Show brief success feedback
  const btn=document.querySelector('.wt-btn');
  if(btn){const orig=btn.textContent;btn.textContent='✓ Сохранено!';btn.style.background='var(--green)';btn.style.color='#fff';setTimeout(()=>{btn.textContent=orig;btn.style.background='';btn.style.color='';},2000);}
}

function rWChart(){
  const cv=document.getElementById('wc'),em=document.getElementById('wempty');
  if(wts.length<2){em.style.display='block';cv.style.display='none';return;}
  em.style.display='none';cv.style.display='block';
  
  const dpr=window.devicePixelRatio||1;
  const pts=wts.slice(0,30).reverse();
  const parent=cv.parentElement;
  const W=parent.offsetWidth-40;
  const H=140;
  const padL=42,padR=16,padT=16,padB=32;
  const cW=W, cH=H;
  
  cv.style.width=cW+'px'; cv.style.height=cH+'px';
  cv.width=cW*dpr; cv.height=cH*dpr;
  
  const ctx=cv.getContext('2d');
  ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,cW,cH);
  
  const vs=pts.map(p=>p.v);
  const mn=Math.min(...vs), mx=Math.max(...vs);
  const range=mx-mn||1;
  const mnP=mn-range*0.15, mxP=mx+range*0.15;
  
  const pW=cW-padL-padR, pH=cH-padT-padB;
  const xi=i=>padL+(i/(pts.length-1))*pW;
  const yv=v=>padT+pH-(v-mnP)/(mxP-mnP)*pH;
  
  // Get computed color for chart
  const orangeColor=getComputedStyle(document.documentElement).getPropertyValue('--primary').trim()||'#0A0A0A';
  const isDark=document.documentElement.getAttribute('data-theme')==='dark';
  const gridColor=isDark?'rgba(255,255,255,.06)':'rgba(0,0,0,.05)';
  const labelColor=isDark?'rgba(255,255,255,.35)':'rgba(10,10,10,.38)';
  const cardBg=isDark?'#1A1A1A':'#FFFFFF';
  
  // Grid Y lines + Y axis labels
  const steps=4;
  ctx.font=`500 10px -apple-system,BlinkMacSystemFont,sans-serif`;
  ctx.textAlign='right';
  for(let i=0;i<=steps;i++){
    const v=mnP+(mxP-mnP)*i/steps;
    const yy=yv(v);
    ctx.strokeStyle=gridColor; ctx.lineWidth=1;
    ctx.setLineDash([3,4]);
    ctx.beginPath(); ctx.moveTo(padL,yy); ctx.lineTo(cW-padR,yy); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle=labelColor;
    ctx.fillText(Math.round(v)+'кг', padL-5, yy+3.5);
  }
  
  // Smooth curve path (catmull-rom spline)
  function cmR(pts,t=0.5){
    if(pts.length<2) return [];
    const path=[];
    for(let i=0;i<pts.length-1;i++){
      const p0=pts[Math.max(0,i-1)], p1=pts[i], p2=pts[i+1], p3=pts[Math.min(pts.length-1,i+2)];
      for(let s=0;s<=20;s++){
        const st=s/20;
        const st2=st*st, st3=st2*st;
        const x=0.5*((2*p1[0])+(-p0[0]+p2[0])*st+(2*p0[0]-5*p1[0]+4*p2[0]-p3[0])*st2+(-p0[0]+3*p1[0]-3*p2[0]+p3[0])*st3);
        const y=0.5*((2*p1[1])+(-p0[1]+p2[1])*st+(2*p0[1]-5*p1[1]+4*p2[1]-p3[1])*st2+(-p0[1]+3*p1[1]-3*p2[1]+p3[1])*st3);
        path.push([x,y]);
      }
    }
    return path;
  }
  
  const coords=pts.map((_,i)=>[xi(i),yv(vs[i])]);
  const curve=coords.length>2?cmR(coords):coords;
  
  // Gradient fill
  const grad=ctx.createLinearGradient(0,padT,0,cH-padB);
  const orangeAlpha=isDark?'rgba(250,250,250,0.10)':'rgba(10,10,10,0.07)';
  const orangeAlpha0=isDark?'rgba(250,250,250,0)':'rgba(10,10,10,0)';
  grad.addColorStop(0,orangeAlpha); grad.addColorStop(1,orangeAlpha0);
  
  ctx.beginPath();
  ctx.moveTo(curve[0][0],curve[0][1]);
  curve.forEach(([x,y])=>ctx.lineTo(x,y));
  ctx.lineTo(coords[coords.length-1][0],cH-padB);
  ctx.lineTo(coords[0][0],cH-padB);
  ctx.closePath();
  ctx.fillStyle=grad; ctx.fill();
  
  // Line
  ctx.beginPath();
  ctx.moveTo(curve[0][0],curve[0][1]);
  curve.forEach(([x,y])=>ctx.lineTo(x,y));
  ctx.strokeStyle=orangeColor.indexOf('#')===-1?'#0A0A0A':orangeColor;
  ctx.lineWidth=2.5; ctx.lineJoin='round'; ctx.lineCap='round';
  ctx.setLineDash([]); ctx.stroke();
  
  // Dots
  pts.forEach((p,i)=>{
    const dotX=xi(i), dotY=yv(vs[i]);
    // Outer ring
    ctx.beginPath(); ctx.arc(dotX,dotY,5,0,Math.PI*2);
    ctx.fillStyle=cardBg; ctx.fill();
    // Inner fill
    ctx.beginPath(); ctx.arc(dotX,dotY,3.5,0,Math.PI*2);
    ctx.fillStyle=orangeColor.indexOf('#')===-1?'#0A0A0A':orangeColor; ctx.fill();
    
    // Label above/below first and last dot
    if(i===0||i===pts.length-1){
      const above=dotY>padT+20;
      ctx.font=`600 11px -apple-system,BlinkMacSystemFont,sans-serif`;
      ctx.textAlign='center';
      ctx.fillStyle=labelColor;
      ctx.fillText(p.v+'кг', dotX, above?dotY-10:dotY+18);
      // Date label
      const d=new Date(p.d);
      const dLbl=d.toLocaleDateString('ru',{day:'numeric',month:'short'});
      ctx.font=`400 9px -apple-system,BlinkMacSystemFont,sans-serif`;
      ctx.fillStyle=isDark?'rgba(255,255,255,.2)':'rgba(60,60,67,.3)';
      ctx.fillText(dLbl, dotX, cH-padB+14);
    }
  });
}

// AI
function initAi(){
  aiReady=true;
  const tl=tlog(),t=tot(tl);
  const c=document.getElementById('aimsg');
  c.innerHTML='';
  // Welcome card
  const wcard=document.createElement('div');
  wcard.className='ai-welcome';
  wcard.innerHTML=`
    <span class="ai-welcome-icon">🤖</span>
    <div class="ai-welcome-title">Привет, ${U?.name||''}!</div>
    <div class="ai-welcome-sub">Сегодня съедено <b style="color:#FF8C00">${t.k} ккал</b> из ${U?.kcal||2000}.<br>Я помогу с питанием, КБЖУ и целью «${GL[U?.goal]||'—'}».</div>
  `;
  c.appendChild(wcard);
  const lbl=document.createElement('div');
  lbl.className='ai-chips-label';
  lbl.textContent='ПОПРОБУЙ СПРОСИТЬ';
  c.appendChild(lbl);
}
function clearAiChat(){
  showConfirm('💬','Очистить чат?','История переписки будет удалена. Контекст питания сохранится.','Очистить',()=>{
    initAi();
  });
}
function aiSug(el){document.getElementById('aiinp').value=el.textContent;aiSend();}
async function aiSend(){
  const inp=document.getElementById('aiinp'),txt=inp.value.trim();
  if(!txt)return;if(!key){openApi();return;}
  inp.value='';HFX.light();SFX.play('ai_send');aiMsg(txt,'user');
  const tl=tlog(),t=tot(tl);
  // Build full food log for AI context
  const foodLog=tl.map(item=>`  • ${item.food||'Блюдо'}${item.portion?' ('+item.portion+')':''}: ${item.kcal}ккал, Б:${Math.round(item.prot||0)}г, У:${Math.round(item.carb||0)}г, Ж:${Math.round(item.fat||0)}г`).join('\n')||'  (пусто)';
  const sys=`Ты персональный AI-нутрициолог. Данные пользователя:\n- Имя: ${U?.name}, ${U?.age||'?'} лет, рост ${U?.h||'?'}см, вес ${U?.w||'?'}кг, пол: ${U?.gen==='m'?'мужчина':'женщина'}\n- Цель: ${GL[U?.goal]||'—'}, норма: ${U?.kcal||2000}ккал\n- Активность: ${U?.act||1.375}\n- Макро цели: Б${U?.pr||0}г У${U?.cb||0}г Ж${U?.ft||0}г\nСегодня съедено:\n${foodLog}\nИтого сегодня: ${t.k}ккал (Б:${Math.round(t.p)}г У:${Math.round(t.c)}г Ж:${Math.round(t.f)}г), осталось: ${Math.max(0,(U?.kcal||2000)-t.k)}ккал.\nПоследний приём: ${tl.length>0?tl[tl.length-1].food+' в '+tl[tl.length-1].time:'нет данных'}.\nОтвечай по-русски, кратко (до 150 слов), используй эмодзи, будь конкретным и точным.`;
  // Show typing indicator
  const lm=document.createElement('div');lm.className='msg msg-ai';
  lm.innerHTML='<div class="msg-ai-wrap"><div class="msg-ai-ava">🤖</div><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>';
  const _c=document.getElementById('aimsg');_c.appendChild(lm);_c.scrollTop=_c.scrollHeight;
  try{const r=await gem([{text:txt}],sys);HFX.double();SFX.play('ai_reply');const _bbl=document.createElement('div');_bbl.className='bbl';_bbl.innerHTML=fmt(r);lm.innerHTML='<div class="msg-ai-wrap"><div class="msg-ai-ava">🤖</div></div>';lm.querySelector('.msg-ai-wrap').appendChild(_bbl);}
  catch(e){
    const msg=e.message||'';
    if(msg.includes('quota')||msg.includes('429')||msg.includes('exceeded'))
      lm.innerHTML='<div class="msg-ai-wrap"><div class="msg-ai-ava">🤖</div><div class="bbl">⚠️ Превышен лимит запросов Gemini API. Подожди 1-2 минуты и попробуй снова.</div></div>';
    else if(msg.includes('API key')||msg.includes('invalid'))
      lm.innerHTML='<div class="msg-ai-wrap"><div class="msg-ai-ava">🤖</div><div class="bbl">🔑 Неверный API ключ. Проверь в Настройках.</div></div>';
    else
      lm.innerHTML='<div class="msg-ai-wrap"><div class="msg-ai-ava">🤖</div><div class="bbl">⚠️ '+msg+'</div></div>';
  }
}
function aiMsg(txt,r){
  const el=document.createElement('div');el.className='msg msg-'+r;
  if(r==='ai'){
    el.innerHTML=`<div class="msg-ai-wrap"><div class="msg-ai-ava">🤖</div><div class="bbl">${fmt(txt)}</div></div>`;
  } else {
    el.innerHTML=`<div class="bbl">${txt}</div>`;
  }
  const c=document.getElementById('aimsg');c.appendChild(el);c.scrollTop=c.scrollHeight;return el;
}
function fmt(t){return t.replace(/\*\*(.*?)\*\*/g,'<b>$1</b>').replace(/\n/g,'<br>')}

// ADD FOOD
function openAdd(){
  if(!key){openApi();return;}
  HFX.medium(); SFX.play('sheet_open');
  // Smart meal detection by time
  const h=new Date().getHours();
  const autoMeal=h<10?'breakfast':h<14?'lunch':h<18?'snack':h<21?'dinner':'other';
  setMeal(autoMeal);
  // Show recents
  renderRecents();
  document.getElementById('addOv').classList.add('on');
}
function closeAdd(){HFX.light();SFX.play('sheet_close');document.getElementById('addOv').classList.remove('on');}
function swTab(t,btn){
  HFX.tick();SFX.play('btn_tap');
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  btn.classList.add('on');document.getElementById('tp-'+t).classList.add('on');
}

// Photo
let phFile=null;
let phDataUrl=null; // store dataURL once, reuse everywhere
function onPhoto(e){
  const file=e.target.files[0];if(!file)return;
  phFile=file;
  phDataUrl=null;
  document.getElementById('pherr').classList.remove('on');
  document.getElementById('phres').classList.remove('on');
  document.getElementById('phAddbtn').style.display='none';
  // Read file ONCE via FileReader
  const fr=new FileReader();
  fr.onload=()=>{
    phDataUrl=fr.result; // full data:image/jpeg;base64,XXX
    document.getElementById('previmg').src=phDataUrl;
    document.getElementById('prevw').style.display='block';
    document.getElementById('upz').style.display='none';
    document.getElementById('phDescWrap').style.display='block';
    document.getElementById('phAbtn').style.display='block';
  };
  fr.onerror=()=>{ showErr('pherr','Не удалось открыть файл'); };
  fr.readAsDataURL(file);
}
function rstPhoto(){
  phFile=null;phDataUrl=null;
  const c=document.getElementById('phinp_cam');if(c)c.value='';
  const g=document.getElementById('phinp_gal');if(g)g.value='';
  document.getElementById('prevw').style.display='none';
  document.getElementById('upz').style.display='block';
  document.getElementById('phAbtn').style.display='none';
  document.getElementById('phDescWrap').style.display='none';
  document.getElementById('phDesc').value='';
  document.getElementById('phres').classList.remove('on');
  document.getElementById('phAddbtn').style.display='none';
}
async function doPhoto(){
  if(!phFile)return;
  document.getElementById('phAbtn').style.display='none';
  document.getElementById('pherr').classList.remove('on');
  document.getElementById('phldr').classList.add('on');
  try{
    const imgData=await b64(phFile);
    const mime='image/jpeg';
    const previewSrc='data:image/jpeg;base64,'+imgData;
    document.getElementById('previmg').src=previewSrc;
    const userDesc=document.getElementById('phDesc').value.trim();
    const descHint=userDesc?`\nUser hint: "${userDesc}" — use this to clarify the dish name and portion.`:'';
    const p=`Analyze this food photo.${descHint}\nReturn ONLY JSON, no other text:\n{"food":"name in Russian","portion":"amount","calories":200,"protein":10,"fat":8,"carbs":20,"description":"brief description","ingredients":[{"name":"ingredient","calories":50}]}`;
    let raw='';
    try{ raw=await gem([{text:p},{inline_data:{mime_type:mime,data:imgData}}]); }
    catch(e){ throw new Error('Gemini API: '+(e.message||e)); }
    let r;
    try{ r=pj(raw); }
    catch(e){ throw new Error('Ответ Gemini: '+raw.slice(0,120)); }
    cur.photo={food:r.food,portion:r.portion,kcal:r.calories||0,prot:r.protein||0,fat:r.fat||0,carb:r.carbs||0,img:'data:image/jpeg;base64,'+imgData,time:tnow(),date:ds(),desc:r.description||'',ingr:r.ingredients||[]};
    document.getElementById('rn').textContent=r.food||'Блюдо';
    document.getElementById('rp').textContent=r.portion||'';
    document.getElementById('rk').innerHTML=(r.calories||0)+' <small>ккал</small>';
    document.getElementById('rpr').textContent=(r.protein||0)+'г';
    document.getElementById('rcr').textContent=(r.carbs||0)+'г';
    document.getElementById('rfr').textContent=(r.fat||0)+'г';
    document.getElementById('rd').textContent=r.description||'';
    document.getElementById('resimg').src=document.getElementById('previmg').src;
    document.getElementById('resimg').classList.add('on');
    if(r.ingredients?.length){
      document.getElementById('ringrlist').innerHTML='<div class="ingr-hdr">СОСТАВ</div>'+r.ingredients.slice(0,6).map(i=>`<div class="ingr-i"><span class="ingr-n">${i.name}</span><span class="ingr-c">${i.calories}ккал</span></div>`).join('');
    }
    document.getElementById('prevw').style.display='none'; // hide preview when result shown
    document.getElementById('phres').classList.add('on');
    document.getElementById('phAddbtn').style.display='block';
    HFX.success();SFX.play('scan_success');
  }catch(e){const _em=String(e.message||e||'Ошибка');
    const _msg=_em.includes('quota')||_em.includes('exceeded')||_em.includes('429')?'Превышен лимит Gemini API. Подожди 1-2 мин и попробуй снова.':_em;
    HFX.error();SFX.play('error');
    showErr('pherr',_msg);document.getElementById('phAbtn').style.display='block';}
  finally{document.getElementById('phldr').classList.remove('on');}
}

// Text
function fillTx(el){document.getElementById('txinp').value=el.textContent;}
function rstText(){document.getElementById('txinp').value='';document.getElementById('txres').classList.remove('on');document.getElementById('txAddbtn').style.display='none';document.getElementById('txAbtn').style.display='block';}
async function doText(){
  const txt=document.getElementById('txinp').value.trim();
  if(!txt){alert('Напиши что съел');return;}
  document.getElementById('txAbtn').style.display='none';
  document.getElementById('txerr').classList.remove('on');
  document.getElementById('txldr').classList.add('on');
  try{
    const p=`You are a nutrition expert. The user ate: "${txt}". Calculate calories and macros.
Respond with ONLY a valid JSON object. No text before or after. No markdown. Example format:
{"food":"Гречка с курицей","portion":"250г","calories":320,"protein":28,"fat":8,"carbs":35,"description":"Гречневая каша с куриной грудкой. Сбалансированное блюдо с высоким содержанием белка."}
Now calculate for what the user ate and return JSON in same format:`;
    const raw=await gem([{text:p}]);
    const r=pj(raw);
    cur.text={food:r.food,portion:r.portion,kcal:r.calories||0,prot:r.protein||0,fat:r.fat||0,carb:r.carbs||0,time:tnow(),date:ds(),desc:r.description||'',ingr:r.ingredients||[]};
    document.getElementById('trn').textContent=r.food||txt;
    document.getElementById('trp').textContent=r.portion||'';
    document.getElementById('trk').innerHTML=(r.calories||0)+' <small>ккал</small>';
    document.getElementById('trpr').textContent=(r.protein||0)+'г';
    document.getElementById('trcr').textContent=(r.carbs||0)+'г';
    document.getElementById('trfr').textContent=(r.fat||0)+'г';
    document.getElementById('trd').textContent=r.description||'';
    document.getElementById('txres').classList.add('on');
    document.getElementById('txAddbtn').style.display='block';
    HFX.success();SFX.play('scan_success');
  }catch(e){HFX.error();SFX.play('error');showErr('txerr', String(e.message||e||'Ошибка анализа'));document.getElementById('txAbtn').style.display='block';}
  finally{document.getElementById('txldr').classList.remove('on');}
}

// Barcode
async function doBarcode(e){
  const file=e.target.files[0];if(!file)return;
  document.getElementById('bcerr').classList.remove('on');
  document.getElementById('bcldr').classList.add('on');
  try{
    const b=await b64(file),mime=file.type||'image/jpeg';
    const p=`You are a nutrition expert. This photo shows a product barcode or packaging. Identify the product and its nutrition info per serving or per 100g.
Respond with ONLY a valid JSON object. No text before or after. No markdown. Example:
{"food":"Чипсы Lay's Сметана","portion":"30г","calories":165,"protein":2,"fat":11,"carbs":15,"description":"Картофельные чипсы. Высококалорийный снек."}
Return JSON for the product in this photo:`;
    const raw=await gem([{text:p},{inline_data:{mime_type:mime,data:b}}]);
    const r=pj(raw);
    cur.barcode={food:r.food,portion:r.portion,kcal:r.calories||0,prot:r.protein||0,fat:r.fat||0,carb:r.carbs||0,time:tnow(),date:ds()};
    document.getElementById('brn').textContent=r.food||'Продукт';
    document.getElementById('brp').textContent=r.portion||'';
    document.getElementById('brk').innerHTML=(r.calories||0)+' <small>ккал</small>';
    document.getElementById('brpr').textContent=(r.protein||0)+'г';
    document.getElementById('brcr').textContent=(r.carbs||0)+'г';
    document.getElementById('brfr').textContent=(r.fat||0)+'г';
    document.getElementById('brd').textContent=r.description||'';
    document.getElementById('bcres').classList.add('on');
    document.getElementById('bcAddbtn').style.display='block';
    HFX.success();SFX.play('scan_success');
  }catch(e){HFX.error();SFX.play('error');showErr('bcerr', String(e.message||e||'Ошибка анализа'));}
  finally{document.getElementById('bcldr').classList.remove('on');}
}

function addRes(t){
  const item=cur[t];if(!item)return;
  // Attach meal category
  item.meal = _curMeal || 'other';
  HFX.success(); SFX.play('add_food');
  log.unshift(item); S('log',JSON.stringify(log));
  // Save to recents
  _saveRecent(item);
  rH(); closeAdd();
  if(t==='photo') rstPhoto();
  if(t==='text')  rstText();
  if(t==='barcode'){document.getElementById('bcres').classList.remove('on');document.getElementById('bcAddbtn').style.display='none';}
}

// ── MEAL CATEGORY ──
let _curMeal = 'other';
const MEALS = {
  breakfast: { label:'Завтрак',  icon:'🌅' },
  lunch:     { label:'Обед',     icon:'☀️'  },
  dinner:    { label:'Ужин',     icon:'🌙'  },
  snack:     { label:'Перекус',  icon:'🍎'  },
  other:     { label:'Прочее',   icon:'🍽️'  },
};
function setMeal(id){
  _curMeal = id;
  document.querySelectorAll('.meal-chip').forEach(c=>{
    c.classList.toggle('on', c.dataset.meal===id);
  });
  HFX.light();
}

// ── RECENT FOODS ──
function _saveRecent(item){
  try{
    let r=JSON.parse(G('recents','[]'));
    // Remove duplicate by food name
    r=r.filter(x=>x.food!==item.food);
    r.unshift({food:item.food,kcal:item.kcal,prot:item.prot,carb:item.carb,fat:item.fat,portion:item.portion||''});
    r=r.slice(0,10);
    S('recents',JSON.stringify(r));
  }catch(e){}
}
function getRecents(){try{return JSON.parse(G('recents','[]'));}catch(e){return [];}}
function renderRecents(){
  const el=document.getElementById('recentsList');if(!el)return;
  const r=getRecents();
  if(!r.length){el.style.display='none';return;}
  el.style.display='block';
  el.innerHTML=`<div class="recents-lbl">Недавние</div><div class="recents-chips">`+
    r.slice(0,6).map(x=>`<div class="recent-chip" onclick="addRecent(${JSON.stringify(x).replace(/"/g,'&quot;')})">
      <span class="rc-name">${x.food}</span>
      <span class="rc-kcal">${x.kcal}ккал</span>
    </div>`).join('')+'</div>';
}
function addRecent(item){
  item.date=ds(); item.time=tnow(); item.meal=_curMeal||'other';
  log.unshift(item); S('log',JSON.stringify(log));
  HFX.success(); SFX.play('add_food');
  rH(); closeAdd();
}

// ── FAVORITES ──
function getFavs(){try{return JSON.parse(G('favs','[]'));}catch(e){return [];}}
function toggleFav(idx){
  const item=log[idx]; if(!item)return;
  let favs=getFavs();
  const exists=favs.findIndex(f=>f.food===item.food);
  if(exists>=0){ favs.splice(exists,1); HFX.light(); }
  else { favs.unshift({food:item.food,kcal:item.kcal,prot:item.prot,carb:item.carb,fat:item.fat,portion:item.portion||''}); HFX.success(); }
  S('favs',JSON.stringify(favs));
  // Update fav button in food detail
  const btn=document.getElementById('fdFavBtn');
  if(btn) btn.textContent=exists>=0?'☆':'★';
}

// ── EXPORT DATA ──
function exportData(){
  HFX.medium();
  const rows=[['Дата','Время','Блюдо','Категория','Ккал','Белки г','Углеводы г','Жиры г','Порция']];
  log.forEach(e=>{
    rows.push([
      e.date||'', e.time||'',
      (e.food||'').replace(/,/g,';'),
      MEALS[e.meal||'other']?.label||'Прочее',
      e.kcal||0, Math.round(e.prot||0),
      Math.round(e.carb||0), Math.round(e.fat||0),
      (e.portion||'').replace(/,/g,';')
    ]);
  });
  const csv=rows.map(r=>r.join(',')).join('\n');
  const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download='calsnap_export_'+new Date().toISOString().slice(0,10)+'.csv';
  document.body.appendChild(a); a.click();
  document.body.removeChild(a); URL.revokeObjectURL(url);
  SFX.play('save');
}
let ALL_MODELS=[
  {id:'gemini-2.5-flash-lite',       name:'Gemini 2.5 Flash Lite',     desc:'⚡ Быстрый · Рекомендован'},
  {id:'gemini-2.0-flash-lite',       name:'Gemini 2.0 Flash Lite',     desc:'🔹 Предыдущее поколение'},
  {id:'gemini-2.0-flash',            name:'Gemini 2.0 Flash',           desc:'🧠 Умный · Надёжный'},
  {id:'gemini-2.5-flash-preview-04-17',name:'Gemini 2.5 Flash Preview', desc:'✨ Новейший Flash'},
  {id:'gemini-2.5-pro-preview-03-25',name:'Gemini 2.5 Pro Preview',     desc:'🏆 Максимум качества'},
  {id:'gemini-2.0-flash-lite-001',   name:'Gemini 2.0 Flash Lite 001',  desc:'📌 Стабильная версия'},
];
let selModel=localStorage.getItem('model')||'gemini-2.5-flash-lite';
const MODELS=[selModel,'gemini-2.5-flash-lite','gemini-2.0-flash-lite','gemini-2.0-flash'].filter((v,i,a)=>a.indexOf(v)===i);

// Fetch all available models from Gemini API
async function fetchGeminiModels(){
  if(!key) return;
  try{
    const r=await fetch(`https://generativelanguage.googleapis.com/v1beta/models?key=${key}&pageSize=100`);
    if(!r.ok) return;
    const d=await r.json();
    if(!d.models) return;
    // Filter to generateContent-capable models only, exclude audio/video/embedding
    const skip=['audio','tts','embedding','aqa','retrieval','imagen','veo'];
    const fresh=d.models
      .filter(m=>m.supportedGenerationMethods?.includes('generateContent'))
      .filter(m=>!skip.some(s=>m.name.toLowerCase().includes(s)))
      .map(m=>{
        const id=m.name.replace('models/','');
        const dname=m.displayName||id;
        return {id, name:dname, desc:m.description?.split('.')[0]?.substring(0,50)||''};
      })
      .sort((a,b)=>a.name.localeCompare(b.name));
    if(fresh.length>0){
      ALL_MODELS=fresh;
      console.log('Loaded',fresh.length,'models from API');
    }
  }catch(e){console.log('Model fetch failed:',e.message);}
}

function openModelPicker(){
  const ov=document.getElementById('mdlOv');
  const list=document.getElementById('mdlList');
  const cnt=document.getElementById('mdlCount');
  if(cnt) cnt.textContent=ALL_MODELS.length>5?`${ALL_MODELS.length} моделей доступно`:'Обновляется...';
  list.innerHTML=ALL_MODELS.map(m=>`
    <div onclick="selectModel('${m.id}')" style="
      padding:14px 16px;border-radius:14px;cursor:pointer;
      background:${m.id===selModel?'var(--primary)':'var(--bg)'};
      border:1.5px solid ${m.id===selModel?'var(--primary)':'var(--border2)'};
      display:flex;justify-content:space-between;align-items:center;transition:all .15s">
      <div>
        <div style="font-size:14px;font-weight:700;color:${m.id===selModel?'#fff':'var(--text)'}">${m.name}</div>
        <div style="font-size:11px;margin-top:2px;color:${m.id===selModel?'rgba(255,255,255,0.8)':'var(--text2)'}">${m.desc}</div>
      </div>
      ${m.id===selModel?'<span style="font-size:18px;color:#fff">✓</span>':''}
    </div>
  `).join('');
  ov.style.display='flex';
}

function selectModel(id){
  selModel=id;
  localStorage.setItem('model',id);
  // Update MODELS array to put selected first
  MODELS.length=0;
  [id,'gemini-2.0-flash-lite','gemini-2.0-flash'].filter((v,i,a)=>a.indexOf(v)===i).forEach(m=>MODELS.push(m));
  document.getElementById('smodel').textContent=ALL_MODELS.find(m=>m.id===id)?.name||id;
  document.getElementById('mdlOv').style.display='none';
  // Re-render list
  const list=document.getElementById('mdlList');
  list.innerHTML=ALL_MODELS.map(m=>`
    <div onclick="selectModel('${m.id}')" style="
      padding:14px 16px;border-radius:14px;cursor:pointer;
      background:${m.id===selModel?'var(--primary)':'var(--bg)'};
      border:1.5px solid ${m.id===selModel?'var(--primary)':'var(--border2)'};
      display:flex;justify-content:space-between;align-items:center">
      <div>
        <div style="font-size:14px;font-weight:700;color:${m.id===selModel?'#fff':'var(--text)'}">${m.name}</div>
        <div style="font-size:11px;margin-top:2px;color:${m.id===selModel?'rgba(255,255,255,0.8)':'var(--text2)'}">${m.desc}</div>
      </div>
      ${m.id===selModel?'<span style="font-size:18px;color:#fff">✓</span>':''}
    </div>
  `).join('');
}
async function gem(parts,sys=''){
  if(!key) throw new Error('API ключ не установлен. Добавь в Настройках → API');
  const models=[selModel,'gemini-2.0-flash-lite','gemini-2.0-flash'].filter((v,i,a)=>a.indexOf(v)===i);
  let lastErr;
  for(const m of models){
    try{
      const ctrl=new AbortController();
      const t=setTimeout(()=>ctrl.abort(),20000);
      const body={contents:[{parts}],generationConfig:{temperature:0.2,maxOutputTokens:1024}};
      if(sys)body.system_instruction={parts:[{text:sys}]};
      const r=await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${m}:generateContent?key=${key}`,
        {method:'POST',signal:ctrl.signal,headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      clearTimeout(t);
      if(r.ok){
        const d=await r.json();
        const tx=d.candidates?.[0]?.content?.parts?.[0]?.text||'';
        if(!tx) throw new Error('Пустой ответ');
        return tx;
      }
      const er=await r.json().catch(()=>({}));
      const code=r.status;
      if(code===400) lastErr='Неверный API ключ';
      else if(code===429) lastErr='Превышен лимит запросов — подожди минуту';
      else if(code===403) lastErr='Доступ запрещён — проверь API ключ';
      else lastErr=er.error?.message||`Ошибка ${code}`;
    }catch(e){
      lastErr=e.name==='AbortError'?'Таймаут (20с) — проверь интернет':(e.message||'Сетевая ошибка');
    }
  }
  throw new Error(lastErr||'Ошибка Gemini API');
}
async function b64(file){
  // Use already-read dataURL if available (avoids double FileReader on Android)
  const dataUrl = phDataUrl || await new Promise((res,rej)=>{
    const fr=new FileReader();
    fr.onload=()=>res(fr.result);
    fr.onerror=()=>rej(new Error('Ошибка чтения файла'));
    fr.readAsDataURL(file);
  });
  // Resize via canvas and return pure base64
  return new Promise((resolve,reject)=>{
    const img=new Image();
    img.onload=()=>{
      try{
        const MAX=1024;
        let w=img.naturalWidth,h=img.naturalHeight;
        if(w>MAX||h>MAX){
          if(w>h){h=Math.round(h*MAX/w);w=MAX;}
          else{w=Math.round(w*MAX/h);h=MAX;}
        }
        const cv=document.createElement('canvas');
        cv.width=w;cv.height=h;
        cv.getContext('2d').drawImage(img,0,0,w,h);
        resolve(cv.toDataURL('image/jpeg',0.85).split(',')[1]);
      }catch(e){reject(new Error('Canvas: '+e.message));}
    };
    img.onerror=()=>reject(new Error('Ошибка обработки изображения'));
    img.src=dataUrl;
  });
}
function pj(raw){
  if(!raw||!raw.trim()) throw new Error('Пустой ответ');
  let c=raw.trim();
  // Strip ALL variations of code fences (backticks, unicode backticks, etc)
  c=c.replace(/[``]+json/gi,'').replace(/[``]+/g,'').trim();
  // Find outermost JSON object
  const start=c.indexOf('{'), end=c.lastIndexOf('}');
  if(start===-1||end===-1) throw new Error('JSON не найден в ответе');
  let obj;
  try{ obj=JSON.parse(c.slice(start,end+1)); }
  catch(e){
    // Try to fix common issues: unquoted values, trailing commas
    let fixed=c.slice(start,end+1)
      .replace(/,\s*}/g,'}').replace(/,\s*]/g,']')
      .replace(/:([a-zA-Zа-яА-Я][^",}\]]*?)([,}])/g,':"$1"$2');
    try{ obj=JSON.parse(fixed); }
    catch(e2){ throw new Error('Не удалось разобрать JSON'); }
  }
  // Ensure numeric fields
  ['calories','protein','fat','carbs'].forEach(k=>{
    if(typeof obj[k]==='string') obj[k]=parseFloat(obj[k])||0;
    if(typeof obj[k]!=='number'||isNaN(obj[k])) obj[k]=0;
  });
  if(!obj.food) obj.food='Блюдо';
  return obj;
}

// API modal
function openApi(){if(key)document.getElementById('apiinp').value=key;document.getElementById('apiOv').classList.add('on');}
function closeApi(){document.getElementById('apiOv').classList.remove('on');}
function saveApi(){const v=document.getElementById('apiinp').value.trim();if(!v)return;key=v;S('key',v);closeApi();document.getElementById('abar').style.display='none';rSet();fetchGeminiModels();}

// Settings
function rSet(){
  if(!U)return;
  document.getElementById('sname').textContent=U.name||'—';
  if(U.dob){const _a=calcAgeFromDob(U.dob);if(_a&&_a!==U.age){U.age=_a;rcalc();S('u',JSON.stringify(U));}}
  document.getElementById('sgoal').textContent=GL[U.goal]||'—';
  document.getElementById('skcal').textContent=(U.kcal||0)+' ккал';
  document.getElementById('sapi').textContent=key?'Установлен ✓':'Не установлен';
  const _mname=ALL_MODELS.find(m=>m.id===selModel)?.name||selModel;
  document.getElementById('smodel').textContent=_mname;
  const dark=document.documentElement.getAttribute('data-theme')==='dark';
  const tog=document.getElementById('themeToggle');if(tog)tog.classList.toggle('on',dark);
  const sfxTog=document.getElementById('sfxToggle');if(sfxTog)sfxTog.classList.toggle('on',SFX.isEnabled());
  const hfxTog=document.getElementById('hfxToggle');if(hfxTog)hfxTog.classList.toggle('on',HFX.isOn());
  // Notif status
  if(typeof Notification!=='undefined'&&Notification.permission==='granted') _updateNotifStatus(true);
}

function ed(t){
  edType=t;
  const tl=document.getElementById('edtitle'),ct=document.getElementById('edcont');
  if(t==='name'){tl.textContent='Имя';ct.innerHTML=`<input class="inp" id="ed_v" value="${U.name||''}">`;}
  else if(t==='params'){
    tl.textContent='Параметры';
    const curDob=U.dob||'';
    const curAge=curDob?calcAgeFromDob(curDob):U.age;
    const dispDob=curDob?`${String(new Date(curDob).getDate()).padStart(2,'0')}.${String(new Date(curDob).getMonth()+1).padStart(2,'0')}.${new Date(curDob).getFullYear()}`:'';
    _edGender=U.gen||'m';
    ct.innerHTML=`
      <label class="dob-label">Дата рождения</label>
      <button class="dob-picker-btn ${curDob?'filled':''}" id="ed_dob_btn" data-dob="${curDob}" onclick="openDrum('ed')">
        ${curDob?`<span class="dob-value">${dispDob}</span>`:'<span class="dob-placeholder">Выбери дату рождения</span>'}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </button>
      <div class="dob-age-hint" id="ed_dob_hint" style="margin-bottom:14px">${curAge?'Возраст: '+curAge+' лет':''}</div>
      <div class="gender-row" style="margin-bottom:14px">
        <div class="gender-card ${U.gen==='m'?'on':''}" id="ed_gen_m" onclick="edPickGender('m')"><span class="gc-icon">♂️</span><span class="gc-lbl">Мужчина</span></div>
        <div class="gender-card ${U.gen==='f'?'on':''}" id="ed_gen_f" onclick="edPickGender('f')"><span class="gc-icon">♀️</span><span class="gc-lbl">Женщина</span></div>
      </div>
      <input class="inp" type="number" id="ed_h" placeholder="Рост (см)" value="${U.h||''}" inputmode="decimal" style="margin-bottom:10px">
      <input class="inp" type="number" id="ed_w" placeholder="Вес (кг)" value="${U.w||''}" inputmode="decimal">
    `;
  }
  else if(t==='goal'){tl.textContent='Цель';ct.innerHTML=`<div class="goal-grid">${Object.entries(GL).map(([k,v])=>`<div class="goal-card ${U.goal===k?'on':''}" data-g="${k}" onclick="document.querySelectorAll('[data-g]').forEach(e=>e.classList.remove('on'));this.classList.add('on')"><div class="gn">${v}</div></div>`).join('')}</div>`;}
  else if(t==='kcal'){tl.textContent='Норма калорий';ct.innerHTML=`<input class="inp" type="number" id="ed_v" value="${U.kcal||2000}">`;}
  document.getElementById('edOv').classList.add('on');
}
function closeEd(){document.getElementById('edOv').classList.remove('on');}
function saveEd(){
  if(edType==='name'){const v=document.getElementById('ed_v')?.value.trim();if(v)U.name=v;}
  else if(edType==='params'){
    const dobBtn=document.getElementById('ed_dob_btn');
    const dob=dobBtn?.dataset?.dob||'';
    if(dob){U.dob=dob;const a=calcAgeFromDob(dob);if(a&&a>0)U.age=a;}
    const hv=parseFloat(document.getElementById('ed_h')?.value);
    const wv=parseFloat(document.getElementById('ed_w')?.value);
    if(hv>0)U.h=hv;
    if(wv>0)U.w=wv;
    U.gen=_edGender||U.gen;
    rcalc();
  }else if(edType==='goal'){const s=document.querySelector('[data-g].on');if(s){U.goal=s.dataset.g;rcalc();}}
  else if(edType==='kcal'){const v=parseInt(document.getElementById('ed_v')?.value);if(v>0)U.kcal=v;}
  S('u',JSON.stringify(U));rH();rSet();closeEd();
}
let _edGender='m';
function edPickGender(g){
  _edGender=g;
  const m=document.getElementById('ed_gen_m');
  const f=document.getElementById('ed_gen_f');
  if(m)m.classList.toggle('on',g==='m');
  if(f)f.classList.toggle('on',g==='f');
}
function edDobHint(){
  const dob=document.getElementById('ed_dob')?.value;
  const hint=document.getElementById('ed_dob_hint');
  if(!hint)return;
  const age=calcAgeFromDob(dob);
  hint.textContent=age&&age>0?'Возраст: '+age+' лет':'Проверь дату';
}
function rcalc(){
  let bmr=U.gen==='m'?10*U.w+6.25*U.h-5*U.age+5:10*U.w+6.25*U.h-5*U.age-161;
  let k=Math.round(bmr*(U.act||1.375));
  if(U.goal==='lose')k-=500;if(U.goal==='gain')k+=300;
  U.kcal=Math.max(1200,k);U.pr=Math.round(U.w*1.8);U.ft=Math.round(U.kcal*.25/9);U.cb=Math.round((U.kcal-U.pr*4-U.ft*9)/4);
}
function clrAll(){
  showConfirm('🗑️','Сбросить всё?','Все данные будут удалены безвозвратно: журнал еды, вес, профиль и настройки.','Удалить всё',()=>{
    log=[];S('log','[]');wts=[];S('wts','[]');S('u','null');U=null;S('key','');key='';S('mdl','');
    document.getElementById('nav').style.display='none';
    // Brief delay for animation
    setTimeout(()=>ss('ob'),150);
  });
}

function toggleTheme(){
  HFX.light();
  const dark=document.documentElement.getAttribute('data-theme')==='dark';
  const next=dark?'light':'dark';
  document.documentElement.setAttribute('data-theme',next);
  S('theme',next);
  document.getElementById('themeToggle').classList.toggle('on',next==='dark');
  document.querySelector('meta[name="theme-color"]').content=next==='dark'?'#000000':'#F5F5F5';
}

function toggleSfx(){
  HFX.light();
  const newVal=!SFX.isEnabled();
  SFX.setEnabled(newVal);
  const tog=document.getElementById('sfxToggle');
  if(tog)tog.classList.toggle('on',newVal);
  if(newVal) setTimeout(()=>SFX.play('toggle'),50);
}

function showErr(id,msg){const e=document.getElementById(id);e.textContent='⚠️ '+(msg||'Неизвестная ошибка');e.classList.add('on');}

// Apply saved theme
const savedTheme=G('theme','light');
if(savedTheme==='dark'){document.documentElement.setAttribute('data-theme','dark');document.querySelector('meta[name="theme-color"]').content='#000000';}

// ══════════════════════════════════════════════════════
// DRUM DATE PICKER
// ══════════════════════════════════════════════════════
const MONTHS_RU=['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
let _drumCtx='ob'; // 'ob' = onboarding, 'ed' = settings
let _drumDay=1,_drumMonth=1,_drumYear=new Date().getFullYear()-20;
let _drumScrolling=false;

function openDrum(ctx){
  _drumCtx=ctx;
  const n=new Date();
  // Load existing value
  const existingDob=ctx==='ob'
    ?(document.getElementById('ob_dob_btn')?.dataset.dob||'')
    :(U?.dob||'');
  if(existingDob){
    const d=new Date(existingDob);
    _drumDay=d.getDate();_drumMonth=d.getMonth()+1;_drumYear=d.getFullYear();
  } else {
    _drumDay=n.getDate();_drumMonth=n.getMonth()+1;_drumYear=n.getFullYear()-20;
  }
  buildDrumCols();
  SFX.play('sheet_open');
  document.getElementById('drumOv').classList.add('on');
  document.body.style.overflow='hidden';
  // Scroll to selected values
  setTimeout(()=>{
    scrollDrumTo('drum_d',_drumDay-1);
    scrollDrumTo('drum_m',_drumMonth-1);
    const minY=n.getFullYear()-120,maxY=n.getFullYear()-5;
    scrollDrumTo('drum_y',maxY-_drumYear);
  },80);
}
function closeDrum(){
  document.getElementById('drumOv').classList.remove('on');
  document.body.style.overflow='';
}
function buildDrumCols(){
  const n=new Date();
  const minY=n.getFullYear()-120, maxY=n.getFullYear()-5;
  // Days 1-31
  const dCol=document.getElementById('drum_d');
  dCol.innerHTML='<div class="drum-spacer"></div>';
  for(let i=1;i<=31;i++){
    const el=document.createElement('div');el.className='drum-item'+(i===_drumDay?' sel':'');
    el.textContent=String(i).padStart(2,'0');dCol.appendChild(el);
  }
  dCol.innerHTML+=`<div class="drum-spacer"></div>`;
  // Months
  const mCol=document.getElementById('drum_m');
  mCol.innerHTML='<div class="drum-spacer"></div>';
  MONTHS_RU.forEach((m,i)=>{
    const el=document.createElement('div');el.className='drum-item'+(i+1===_drumMonth?' sel':'');
    el.textContent=m;mCol.appendChild(el);
  });
  mCol.innerHTML+=`<div class="drum-spacer"></div>`;
  // Years
  const yCol=document.getElementById('drum_y');
  yCol.innerHTML='<div class="drum-spacer"></div>';
  for(let y=maxY;y>=minY;y--){
    const el=document.createElement('div');el.className='drum-item'+(y===_drumYear?' sel':'');
    el.textContent=y;yCol.appendChild(el);
  }
  yCol.innerHTML+=`<div class="drum-spacer"></div>`;
  // Attach scroll listeners
  attachDrumScroll('drum_d','d',1,31);
  attachDrumScroll('drum_m','m',1,12);
  attachDrumScroll('drum_y','y',minY,maxY);
}
function scrollDrumTo(colId,idx){
  const col=document.getElementById(colId);
  if(!col)return;
  col.scrollTop=idx*44;
}
function attachDrumScroll(colId,axis,min,max){
  const col=document.getElementById(colId);
  if(!col)return;
  let _t=null;
  let _lastIdx=-1;
  col.onscroll=()=>{
    clearTimeout(_t);
    // Tick sound on each new item during scroll
    const curIdx=Math.round(col.scrollTop/44);
    if(curIdx!==_lastIdx){HFX.tick();SFX.play('drum_tick');_lastIdx=curIdx;}
    _t=setTimeout(()=>{
      const idx=Math.round(col.scrollTop/44);
      col.scrollTo({top:idx*44,behavior:'smooth'});
      updateDrumVal(colId,axis,min,max,idx);
    },80);
  };
}
function updateDrumVal(colId,axis,min,max,idx){
  const col=document.getElementById(colId);
  if(!col)return;
  const val=axis==='y'?(max-idx):min+idx;
  if(axis==='d')_drumDay=Math.max(min,Math.min(max,val));
  if(axis==='m')_drumMonth=Math.max(min,Math.min(max,val));
  if(axis==='y')_drumYear=Math.max(min,Math.min(max,val));
  // Highlight selected
  col.querySelectorAll('.drum-item').forEach((el,i)=>el.classList.toggle('sel',i===idx));
}
function confirmDrum(){
  // Clamp day to valid range for month/year
  const maxDays=new Date(_drumYear,_drumMonth,0).getDate();
  _drumDay=Math.min(_drumDay,maxDays);
  const dob=`${_drumYear}-${String(_drumMonth).padStart(2,'0')}-${String(_drumDay).padStart(2,'0')}`;
  const age=calcAgeFromDob(dob);
  if(!age||age<5||age>120){closeDrum();return;}
  const dispStr=`${String(_drumDay).padStart(2,'0')}.${String(_drumMonth).padStart(2,'0')}.${_drumYear}`;
  if(_drumCtx==='ob'){
    const btn=document.getElementById('ob_dob_btn');
    if(btn){btn.dataset.dob=dob;btn.innerHTML=`<span class="dob-value">${dispStr}</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`;btn.classList.add('filled');}
    const hint=document.getElementById('dob_hint');
    if(hint)hint.textContent='✓ Тебе '+age+' лет';
  } else {
    // settings
    const btn=document.getElementById('ed_dob_btn');
    if(btn){btn.dataset.dob=dob;btn.innerHTML=`<span class="dob-value">${dispStr}</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`;btn.classList.add('filled');}
    const hint=document.getElementById('ed_dob_hint');
    if(hint)hint.style.opacity='1',hint.textContent='Возраст: '+age+' лет';
  }
  closeDrum();
  HFX.success();SFX.play('drum_confirm');
  HFX.medium();
}

// ══════════════════════════════════════════════════════
